@model List<SterlingLams.Web.Areas.Inventory.Controllers.InvProductRow>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Product List";
    string q = ViewBag.Query ?? "";
    int pg = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 30;
    int totalPages = ViewBag.TotalPages ?? 1;
    int total = ViewBag.Total ?? 0;
    int firstRow = ViewBag.FirstRow ?? 0;
    int lastRow = ViewBag.LastRow ?? 0;
    int? categoryId = ViewBag.CategoryId;
    string status = ViewBag.Status ?? "all";
    string stock = ViewBag.Stock ?? "all";
    string sort = ViewBag.Sort ?? "name_asc";
    bool archived = ViewBag.Archived ?? false;
    string variant = ViewBag.Variant ?? "all";
    string buttonColour = ViewBag.ButtonColour ?? "";
    var cats = ViewBag.Categories as List<SelectListItem> ?? new();
    var colours = ViewBag.ButtonColours as List<string> ?? new();
    string Money(decimal v) => "₦" + v.ToString("N2");
    var baseRoute = new Dictionary<string, string?> {
        ["q"] = q, ["categoryId"] = categoryId?.ToString(), ["status"] = status, ["stock"] = stock,
        ["pageSize"] = pageSize.ToString(), ["archived"] = archived.ToString().ToLower(),
        ["variant"] = variant, ["buttonColour"] = buttonColour
    };
    Dictionary<string, string?> R(params (string k, string? v)[] over) {
        var d = new Dictionary<string, string?>(baseRoute);
        foreach (var (k, v) in over) d[k] = v;
        return d;
    }
    string NextSort(string col) => sort == col + "_asc" ? col + "_desc" : col + "_asc";
    string SortIcon(string col) => sort == col + "_asc" ? "▲" : sort == col + "_desc" ? "▼" : "⇅";
    string Trunc(string? s, int n) => string.IsNullOrEmpty(s) ? "" : (s.Length > n ? s.Substring(0, n) + "…" : s);
}

@Html.AntiForgeryToken()

<!-- Header -->
<div class="flex items-start justify-between mb-5">
    <div>
        <h1 class="text-2xl font-semibold text-neutral-900">Product List</h1>
        <p class="text-sm text-neutral-500 mt-1">Product List lets you create, edit, and manage products.</p>
    </div>
    <div class="flex items-center gap-2">
        <a asp-area="Inventory" asp-controller="Products" asp-action="Create"
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Advanced Add
        </a>
        <button type="button" id="quick-add-btn"
                class="inline-flex items-center gap-2 px-4 py-2.5 border border-blue-300 text-blue-700 text-sm font-medium rounded-md hover:bg-blue-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Quick Add
        </button>
    </div>
</div>

<div class="bg-white border border-neutral-200 rounded-md">
    <!-- Tabs + search + toolbar -->
    <div class="flex flex-wrap items-center gap-3 px-4 pt-3 border-b border-neutral-100">
        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("archived","false"),("page","1"))"
           class="pb-2.5 text-sm font-medium border-b-2 @(archived ? "border-transparent text-neutral-400 hover:text-neutral-700" : "border-blue-600 text-blue-700")">Current</a>
        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("archived","true"),("page","1"))"
           class="pb-2.5 text-sm font-medium border-b-2 @(archived ? "border-blue-600 text-blue-700" : "border-transparent text-neutral-400 hover:text-neutral-700")">Archived</a>

        <form method="get" class="flex-1 min-w-[220px] max-w-md ml-2 mb-2">
            <input type="hidden" name="archived" value="@archived.ToString().ToLower()" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            <div class="relative">
                <input type="text" name="q" value="@q" autocomplete="off" placeholder="start typing to search…"
                       class="w-full border border-neutral-200 rounded-md pl-3 pr-9 py-2 text-sm focus:outline-none focus:border-blue-400" />
                <button type="submit" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-neutral-400 hover:text-neutral-700">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </button>
            </div>
        </form>

        <div class="flex items-center gap-1 ml-auto mb-2 text-neutral-600">
            <button type="button" id="image-import-btn" class="inline-flex items-center gap-1.5 px-3 py-2 text-sm rounded-md hover:bg-neutral-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Image Import
            </button>
            <a asp-area="Inventory" asp-controller="Products" asp-action="Export" asp-all-route-data="@R()"
               class="inline-flex items-center gap-1.5 px-3 py-2 text-sm rounded-md hover:bg-neutral-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
                Export
            </a>
            <button type="button" id="columns-btn" class="inline-flex items-center gap-1.5 px-3 py-2 text-sm rounded-md hover:bg-neutral-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 6v12M10 6v12M4 18h16"/></svg>
                Columns
            </button>
            <button type="button" id="filter-btn" class="inline-flex items-center gap-1.5 px-3 py-2 text-sm rounded-md hover:bg-neutral-50">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 4h18M6 12h12M10 20h4"/></svg>
                Filter
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table id="prod-table" class="w-full text-sm min-w-[820px]">
            <thead class="bg-neutral-50 text-neutral-600 text-xs">
                <tr>
                    <th data-col="name" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">
                        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("sort", NextSort("name")),("page","1"))" class="hover:text-neutral-900">Name <span class="text-neutral-300">@SortIcon("name")</span></a>
                    </th>
                    <th data-col="sku" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">SKU</th>
                    <th data-col="category" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">
                        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("sort", NextSort("category")),("page","1"))" class="hover:text-neutral-900">Category <span class="text-neutral-300">@SortIcon("category")</span></a>
                    </th>
                    <th data-col="price" draggable="true" class="prod-th text-right font-semibold px-4 py-3 select-none">
                        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("sort", NextSort("price")),("page","1"))" class="hover:text-neutral-900">Sale price <span class="text-neutral-300">@SortIcon("price")</span></a>
                    </th>
                    <th data-col="colour" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">Button<br />colour</th>
                    <th data-col="barcode" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">Barcode</th>
                    <th data-col="description" draggable="true" class="prod-th text-left font-semibold px-4 py-3 select-none">Description</th>
                    <th data-col="trackstock" draggable="true" class="prod-th text-center font-semibold px-4 py-3 select-none">Stock Tracked</th>
                    <th data-col="image" draggable="true" class="prod-th text-center font-semibold px-4 py-3 select-none">Image</th>
                    <th data-col="sellweb" draggable="true" class="prod-th text-center font-semibold px-4 py-3 select-none">Sell on Web</th>
                    <th data-col="actions" class="px-4 py-3 w-12"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                @if (!Model.Any())
                {
                    <tr><td colspan="11" class="px-4 py-16 text-center text-neutral-400">@(archived ? "No archived products." : "No products found.")</td></tr>
                }
                @foreach (var p in Model)
                {
                    <tr class="hover:bg-neutral-50">
                        <td data-col="name" class="px-4 py-3 text-neutral-800">@(string.IsNullOrWhiteSpace(p.Sku) ? p.Name : $"{p.Sku} ({p.Name})")</td>
                        <td data-col="sku" class="px-4 py-3 text-neutral-600">@(p.Sku ?? "—")</td>
                        <td data-col="category" class="px-4 py-3 text-neutral-600">@p.CategoryName</td>
                        <td data-col="price" class="px-4 py-3 text-right text-neutral-800">@Money(p.Price)</td>
                        <td data-col="colour" class="px-4 py-3 text-neutral-500">
                            @if (string.IsNullOrWhiteSpace(p.ButtonColour)) { <span>None</span> }
                            else { <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block border border-neutral-200" style="background:@p.ButtonColour"></span>@p.ButtonColour</span> }
                        </td>
                        <td data-col="barcode" class="px-4 py-3 text-neutral-500 font-mono text-xs">@(p.Barcode ?? "—")</td>
                        <td data-col="description" class="px-4 py-3 text-neutral-500">@Trunc(p.Description, 60)</td>
                        <td data-col="trackstock" class="px-4 py-3 text-center">@(p.TrackStock ? "✓" : "—")</td>
                        <td data-col="image" class="px-4 py-3 text-center">
                            @if (!string.IsNullOrEmpty(p.ImageUrl)) { <img src="@p.ImageUrl" class="w-8 h-8 object-cover rounded inline-block" alt="" /> } else { <span class="text-neutral-300">—</span> }
                        </td>
                        <td data-col="sellweb" class="px-4 py-3 text-center">@(p.IsActive ? "✓" : "—")</td>
                        <td data-col="actions" class="px-2 py-3 text-right">
                            <button type="button" class="kebab text-neutral-400 hover:text-neutral-700 px-2"
                                    data-id="@p.Id" data-archived="@archived.ToString().ToLower()" data-track="@p.TrackStock.ToString().ToLower()">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zm0 2a2 2 0 110 4 2 2 0 010-4zm0 6a2 2 0 110 4 2 2 0 010-4z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer -->
    <div class="flex flex-wrap items-center justify-end gap-4 px-4 py-3 border-t border-neutral-100 text-sm text-neutral-500">
        <div class="flex items-center gap-2">
            <span>Items per page:</span>
            <select id="page-size" class="border border-neutral-200 rounded-md px-2 py-1 text-sm bg-white">
                @foreach (var ps in new[] { 30, 50, 100 }) { <option value="@ps" selected="@(pageSize==ps)">@ps</option> }
            </select>
        </div>
        <span>@firstRow - @lastRow of @total.ToString("N0")</span>
        <div class="flex items-center gap-1">
            <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("page","1"))" class="px-2 py-1 rounded @(pg<=1 ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">«</a>
            <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("page",(pg-1).ToString()))" class="px-2 py-1 rounded @(pg<=1 ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">‹</a>
            <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("page",(pg+1).ToString()))" class="px-2 py-1 rounded @(pg>=totalPages ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">›</a>
            <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-all-route-data="@R(("page",totalPages.ToString()))" class="px-2 py-1 rounded @(pg>=totalPages ? "text-neutral-300 pointer-events-none" : "hover:bg-neutral-100")">»</a>
        </div>
    </div>
</div>

<!-- Drawer overlay -->
<div id="drawer-overlay" class="hidden fixed inset-0 bg-black/30 z-40"></div>

<!-- Filters drawer -->
<form method="get" id="filters-drawer" class="fixed inset-y-0 right-0 w-80 max-w-[90vw] bg-white shadow-2xl z-50 translate-x-full transition-transform duration-200 flex flex-col">
    <input type="hidden" name="archived" value="@archived.ToString().ToLower()" />
    <input type="hidden" name="q" value="@q" />
    <input type="hidden" name="pageSize" value="@pageSize" />
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100">
        <h3 class="text-base font-semibold text-neutral-800 flex items-center gap-2">
            <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 4h18M6 12h12M10 20h4"/></svg> Filters</h3>
        <button type="button" class="drawer-close text-neutral-400 hover:text-neutral-700">&times;</button>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4">
        <div><label class="block text-[11px] text-neutral-400 mb-1">Category</label>
            <select name="categoryId" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                <option value="">All Categories</option>
                @foreach (var c in cats) { <option value="@c.Value" selected="@(categoryId?.ToString() == c.Value)">@c.Text</option> }
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Button colour</label>
            <select name="buttonColour" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                <option value="">All Button colours</option>
                <option value="none" selected="@(buttonColour=="none")">None</option>
                @foreach (var c in colours) { <option value="@c" selected="@(buttonColour==c)">@c</option> }
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Variant</label>
            <select name="variant" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                <option value="all" selected="@(variant=="all")">All Variants</option>
                <option value="simple" selected="@(variant=="simple")">Simple products</option>
                <option value="variable" selected="@(variant=="variable")">Variable products</option>
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Status</label>
            <select name="status" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                <option value="all" selected="@(status=="all")">All</option>
                <option value="active" selected="@(status=="active")">Active (sell on web)</option>
                <option value="hidden" selected="@(status=="hidden")">Hidden</option>
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Stock</label>
            <select name="stock" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                <option value="all" selected="@(stock=="all")">All</option>
                <option value="in" selected="@(stock=="in")">In stock</option>
                <option value="low" selected="@(stock=="low")">Low</option>
                <option value="out" selected="@(stock=="out")">Out of stock</option>
            </select></div>
    </div>
    <div class="flex items-center gap-2 px-5 py-4 border-t border-neutral-100">
        <a asp-area="Inventory" asp-controller="Products" asp-action="Index" asp-route-archived="@archived.ToString().ToLower()"
           class="flex-1 text-center border border-neutral-200 rounded-md py-2 text-sm text-neutral-600 hover:border-neutral-400">Reset</a>
        <button type="submit" class="flex-1 bg-blue-600 text-white rounded-md py-2 text-sm hover:bg-blue-700">Apply</button>
    </div>
</form>

<!-- Columns drawer -->
<div id="columns-drawer" class="fixed inset-y-0 right-0 w-80 max-w-[90vw] bg-white shadow-2xl z-50 translate-x-full transition-transform duration-200 flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100">
        <h3 class="text-base font-semibold text-neutral-800 flex items-center gap-2">
            <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 6v12M10 6v12M4 18h16"/></svg> Columns</h3>
        <button type="button" class="drawer-close text-neutral-400 hover:text-neutral-700">&times;</button>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-3 space-y-1" id="columns-list"></div>
    <div class="px-5 py-4 border-t border-neutral-100">
        <button type="button" id="reset-columns" class="w-full border border-neutral-200 rounded-md py-2 text-sm text-blue-700 hover:bg-blue-50">Reset Columns</button>
    </div>
</div>

<!-- Edit Product drawer -->
<div id="edit-drawer" class="fixed inset-y-0 right-0 w-[420px] max-w-[95vw] bg-white shadow-2xl z-50 translate-x-full transition-transform duration-200 flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100">
        <h3 class="text-base font-semibold text-neutral-800">Edit Product</h3>
        <div class="flex items-center gap-1 text-neutral-400">
            <button type="button" id="edit-prev" title="Previous" class="px-2 py-1 hover:text-neutral-700 disabled:opacity-30">‹</button>
            <button type="button" id="edit-next" title="Next" class="px-2 py-1 hover:text-neutral-700 disabled:opacity-30">›</button>
            <button type="button" class="drawer-close px-2 py-1 hover:text-neutral-700 text-lg leading-none">&times;</button>
        </div>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4">
        <input type="hidden" id="edit-id" />
        <div><label class="block text-[11px] text-neutral-400 mb-1">Product Name</label>
            <input id="edit-name" class="w-full border border-neutral-200 rounded-md px-3 py-2.5 text-sm focus:outline-none focus:border-blue-400" /></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Category</label>
            <select id="edit-category" class="w-full border border-neutral-200 rounded-md px-3 py-2.5 text-sm bg-white">
                <option value="">Choose…</option>
                @foreach (var c in cats) { <option value="@c.Value">@c.Text</option> }
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Price</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 text-sm">₦</span>
                <input id="edit-price" type="number" step="any" min="0" class="w-full border border-neutral-200 rounded-md pl-7 pr-3 py-2.5 text-sm text-right focus:outline-none focus:border-blue-400" />
            </div></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Button Colour</label>
            <select id="edit-colour" class="w-full border border-neutral-200 rounded-md px-3 py-2.5 text-sm bg-white">
                <option value="">None</option>
                @foreach (var nc in new[] { "Red:#ef4444","Orange:#f97316","Amber:#f59e0b","Green:#22c55e","Teal:#14b8a6","Blue:#3b82f6","Indigo:#6366f1","Purple:#a855f7","Pink:#ec4899","Grey:#9ca3af","Black:#111827" })
                {
                    var parts = nc.Split(':');
                    <option value="@parts[1]">@parts[0]</option>
                }
                @foreach (var c in colours) { <option value="@c">@c</option> }
            </select></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Barcode (optional)</label>
            <input id="edit-barcode" class="w-full border border-neutral-200 rounded-md px-3 py-2.5 text-sm font-mono focus:outline-none focus:border-blue-400" />
            <button type="button" id="edit-genbarcode" class="mt-2 text-sm text-blue-700 hover:underline">+ Auto Generate Barcode</button></div>
        <div><label class="block text-[11px] text-neutral-400 mb-1">Image</label>
            <div id="edit-dropzone" class="border-2 border-dashed border-neutral-200 rounded-md p-5 text-center text-sm text-neutral-500 hover:border-blue-300 cursor-pointer">
                <img id="edit-image-preview" class="hidden mx-auto mb-2 w-20 h-20 object-cover rounded" alt="" />
                <svg class="w-7 h-7 mx-auto text-blue-500 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 6h16v12H4z"/></svg>
                <div id="edit-drop-text">Drag &amp; drop an image, or <span class="text-blue-700">browse files</span></div>
                <input type="file" id="edit-file" accept=".jpg,.jpeg,.png,.webp,.gif" class="hidden" />
            </div></div>
    </div>
    <div class="flex items-center justify-between gap-2 px-5 py-4 border-t border-neutral-100">
        <a id="edit-advanced" href="#" class="text-sm text-blue-700 hover:underline">Advanced Options</a>
        <button type="button" id="edit-save" class="px-6 bg-blue-600 text-white rounded-md py-2 text-sm hover:bg-blue-700">Save</button>
    </div>
</div>

<!-- Quick Add modal -->
<div id="quick-add" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg w-full max-w-sm p-6">
        <h3 class="text-lg font-medium text-neutral-900 mb-4">Quick Add product</h3>
        <form asp-area="Inventory" asp-controller="Products" asp-action="QuickAdd" method="post" class="space-y-3">
            <div><label class="block text-xs text-neutral-500 mb-1">Name *</label>
                <input name="name" required class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-blue-400" /></div>
            <div><label class="block text-xs text-neutral-500 mb-1">Category *</label>
                <select name="categoryId" required class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm bg-white">
                    <option value="">Choose…</option>
                    @foreach (var c in cats) { <option value="@c.Value">@c.Text</option> }
                </select></div>
            <div class="flex gap-3">
                <div class="flex-1"><label class="block text-xs text-neutral-500 mb-1">Price (₦)</label>
                    <input name="price" type="number" step="any" min="0" value="0" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-blue-400" /></div>
                <div class="flex-1"><label class="block text-xs text-neutral-500 mb-1">SKU</label>
                    <input name="sku" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-blue-400" /></div>
            </div>
            <div class="flex gap-2 pt-2">
                <button type="button" id="quick-cancel" class="flex-1 border border-neutral-200 rounded-md py-2 text-sm text-neutral-600 hover:border-neutral-400">Cancel</button>
                <button type="submit" class="flex-1 bg-blue-600 text-white rounded-md py-2 text-sm hover:bg-blue-700">Add product</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var token = document.querySelector('input[name="__RequestVerificationToken"]') ? document.querySelector('input[name="__RequestVerificationToken"]').value : '';
    var base = '/Inventory/Products/';
    var table = document.getElementById('prod-table');

    // ── Column registry (key → label, default visible) ──────────────────────────
    var COLS = [
        { k: 'name', t: 'Name', def: true }, { k: 'sku', t: 'SKU', def: false },
        { k: 'category', t: 'Category', def: true },
        { k: 'price', t: 'Sale price', def: true },
        { k: 'colour', t: 'Button colour', def: true }, { k: 'barcode', t: 'Barcode', def: false },
        { k: 'description', t: 'Description', def: false }, { k: 'trackstock', t: 'Stock Tracked', def: false },
        { k: 'image', t: 'Image', def: false }, { k: 'sellweb', t: 'Sell on Web', def: false }
    ];
    var VKEY = 'invprod-colvis';
    function defaultVisible() { return COLS.filter(function (c) { return c.def; }).map(function (c) { return c.k; }); }
    function getVisible() { try { var s = JSON.parse(localStorage.getItem(VKEY) || 'null'); return s && s.length ? s : defaultVisible(); } catch (e) { return defaultVisible(); } }
    function setColVisible(key, show) {
        table.querySelectorAll('[data-col="' + key + '"]').forEach(function (cell) { cell.style.display = show ? '' : 'none'; });
        if (show && table.classList.contains('table-fixed')) {
            var th = table.querySelector('th[data-col="' + key + '"]');
            if (th && (!th.style.width || th.style.width === '0px')) th.style.width = '140px';
        }
    }
    function applyVisible(vis) { COLS.forEach(function (c) { setColVisible(c.k, vis.indexOf(c.k) !== -1); }); }
    applyVisible(getVisible());

    // Build the Columns drawer list.
    var list = document.getElementById('columns-list');
    var vis = getVisible();
    list.innerHTML = COLS.map(function (c) {
        return '<label class="flex items-center gap-2.5 px-1 py-2 text-sm text-neutral-700 cursor-pointer">'
            + '<input type="checkbox" class="col-toggle accent-blue-600" data-col="' + c.k + '"' + (vis.indexOf(c.k) !== -1 ? ' checked' : '') + '/>' + c.t + '</label>';
    }).join('');
    list.querySelectorAll('.col-toggle').forEach(function (cb) {
        cb.addEventListener('change', function () {
            var v = getVisible(); var key = cb.dataset.col;
            if (cb.checked) { if (v.indexOf(key) === -1) v.push(key); } else { v = v.filter(function (x) { return x !== key; }); }
            try { localStorage.setItem(VKEY, JSON.stringify(v)); } catch (e) {}
            setColVisible(key, cb.checked);
        });
    });
    document.getElementById('reset-columns').addEventListener('click', function () {
        try { localStorage.removeItem(VKEY); } catch (e) {}
        var d = defaultVisible(); applyVisible(d);
        list.querySelectorAll('.col-toggle').forEach(function (cb) { cb.checked = d.indexOf(cb.dataset.col) !== -1; });
    });

    // ── Drawers (Filters + Columns) ─────────────────────────────────────────────
    var overlay = document.getElementById('drawer-overlay');
    var filters = document.getElementById('filters-drawer'), columns = document.getElementById('columns-drawer');
    var editDrawer = document.getElementById('edit-drawer');
    function openDrawer(d) { overlay.classList.remove('hidden'); d.classList.remove('translate-x-full'); }
    function closeDrawers() { overlay.classList.add('hidden'); filters.classList.add('translate-x-full'); columns.classList.add('translate-x-full'); editDrawer.classList.add('translate-x-full'); }
    document.getElementById('filter-btn').addEventListener('click', function () { closeDrawers(); openDrawer(filters); });
    document.getElementById('columns-btn').addEventListener('click', function () { closeDrawers(); openDrawer(columns); });
    overlay.addEventListener('click', closeDrawers);
    document.querySelectorAll('.drawer-close').forEach(function (b) { b.addEventListener('click', closeDrawers); });

    document.getElementById('image-import-btn').addEventListener('click', function () {
        alert('Image Import is coming next — bulk-match product photos by SKU/barcode.');
    });

    // ── Row kebab menu ──────────────────────────────────────────────────────────
    var menu = document.createElement('div');
    menu.className = 'hidden fixed z-[60] bg-white border border-neutral-200 rounded-md shadow-lg py-1 text-sm w-44';
    document.body.appendChild(menu);
    function closeMenu() { menu.classList.add('hidden'); }
    document.querySelectorAll('.kebab').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var id = btn.dataset.id, isArch = btn.dataset.archived === 'true', tracks = btn.dataset.track === 'true';
            function link(href, label) { return '<a href="' + href + '" class="block px-3 py-2 hover:bg-neutral-50">' + label + '</a>'; }
            function post(action, label, extra, cls, confirmMsg) {
                var onsub = confirmMsg ? ' onsubmit="return confirm(\'' + confirmMsg + '\')"' : '';
                return '<form method="post" action="' + base + action + '"' + onsub + '>'
                    + '<input type="hidden" name="__RequestVerificationToken" value="' + token + '"/>'
                    + '<input type="hidden" name="id" value="' + id + '"/>' + (extra || '')
                    + '<button type="submit" class="w-full text-left px-3 py-2 hover:bg-neutral-50 ' + (cls || '') + '">' + label + '</button></form>';
            }
            menu.innerHTML =
                  link(base + 'Edit/' + id, '✎ Advanced Edit')
                + '<button type="button" data-edit-id="' + id + '" class="w-full text-left px-3 py-2 hover:bg-neutral-50">✏ Edit</button>'
                + post('ToggleTrackStock', (tracks ? '☑ Track Stock' : '☐ Track Stock'))
                + post('Duplicate', '⧉ Duplicate')
                + post('SetArchived', (isArch ? '↩ Restore' : '🗄 Archive'), '<input type="hidden" name="archived" value="' + (isArch ? 'false' : 'true') + '"/>')
                + '<div class="border-t border-neutral-100 my-1"></div>'
                + post('Delete', '🗑 Delete', '', 'text-red-600', 'Delete this product? This cannot be undone.');
            var r = btn.getBoundingClientRect();
            menu.style.top = (r.bottom + 4) + 'px';
            menu.style.left = Math.max(8, r.right - 176) + 'px';
            menu.classList.remove('hidden');
        });
    });
    document.addEventListener('click', closeMenu);
    window.addEventListener('scroll', closeMenu, true);

    // ── Edit Product drawer ─────────────────────────────────────────────────────
    var rowIds = Array.prototype.map.call(document.querySelectorAll('.kebab'), function (b) { return b.dataset.id; });
    var editIdx = -1;
    function rowFor(id) { var b = document.querySelector('.kebab[data-id="' + id + '"]'); return b ? b.closest('tr') : null; }
    function cell(tr, col) { return tr ? tr.querySelector('[data-col="' + col + '"]') : null; }
    function el(id) { return document.getElementById(id); }

    menu.addEventListener('click', function (e) {
        var b = e.target.closest('[data-edit-id]');
        if (b) { e.preventDefault(); closeMenu(); openEdit(b.getAttribute('data-edit-id')); }
    });

    function openEdit(id) {
        editIdx = rowIds.indexOf(String(id));
        el('edit-prev').disabled = editIdx <= 0;
        el('edit-next').disabled = editIdx === -1 || editIdx >= rowIds.length - 1;
        fetch(base + 'EditData?id=' + encodeURIComponent(id), { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d || !d.found) { alert('Could not load product.'); return; }
                el('edit-id').value = d.id;
                el('edit-name').value = d.name || '';
                el('edit-category').value = d.categoryId || '';
                el('edit-price').value = d.price;
                el('edit-colour').value = d.buttonColour || '';
                el('edit-barcode').value = d.barcode || '';
                el('edit-advanced').href = base + 'Edit/' + d.id;
                var prev = el('edit-image-preview');
                if (d.imageUrl) { prev.src = d.imageUrl; prev.classList.remove('hidden'); el('edit-drop-text').textContent = 'Drag & drop to replace, or browse'; }
                else { prev.classList.add('hidden'); prev.removeAttribute('src'); el('edit-drop-text').innerHTML = 'Drag &amp; drop an image, or <span class="text-blue-700">browse files</span>'; }
                closeDrawers(); openDrawer(editDrawer);
            })
            .catch(function () { alert('Could not load product.'); });
    }
    el('edit-prev').addEventListener('click', function () { if (editIdx > 0) openEdit(rowIds[editIdx - 1]); });
    el('edit-next').addEventListener('click', function () { if (editIdx > -1 && editIdx < rowIds.length - 1) openEdit(rowIds[editIdx + 1]); });

    el('edit-genbarcode').addEventListener('click', function () {
        fetch(base + 'GenerateBarcode', { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (d) { if (d && d.ok) el('edit-barcode').value = d.barcode; else alert((d && d.error) || 'Could not generate.'); });
    });

    function renderColour(td, colour) {
        if (!td) return;
        if (!colour) { td.innerHTML = '<span>None</span>'; return; }
        td.innerHTML = '<span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-full inline-block border border-neutral-200" style="background:' + colour + '"></span>' + colour + '</span>';
    }
    el('edit-save').addEventListener('click', function () {
        var id = el('edit-id').value;
        var fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('id', id);
        fd.append('name', el('edit-name').value);
        fd.append('categoryId', el('edit-category').value);
        fd.append('price', el('edit-price').value || '0');
        fd.append('buttonColour', el('edit-colour').value);
        fd.append('barcode', el('edit-barcode').value);
        var btn = el('edit-save'); btn.disabled = true; btn.textContent = 'Saving…';
        fetch(base + 'QuickEdit', { method: 'POST', body: fd })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                btn.disabled = false; btn.textContent = 'Save';
                if (!d || !d.ok) { alert((d && d.error) || 'Save failed.'); return; }
                var tr = rowFor(id);
                if (tr) {
                    if (cell(tr, 'name')) cell(tr, 'name').textContent = d.displayName;
                    if (cell(tr, 'sku')) cell(tr, 'sku').textContent = d.sku || '—';
                    if (cell(tr, 'category')) cell(tr, 'category').textContent = d.categoryName;
                    if (cell(tr, 'price')) cell(tr, 'price').textContent = d.priceText;
                    renderColour(cell(tr, 'colour'), d.buttonColour);
                    if (cell(tr, 'barcode')) cell(tr, 'barcode').textContent = d.barcode || '—';
                }
                closeDrawers();
            })
            .catch(function () { btn.disabled = false; btn.textContent = 'Save'; alert('Save failed.'); });
    });

    // Image upload (drag/drop + browse)
    var dz = el('edit-dropzone'), fileInput = el('edit-file');
    dz.addEventListener('click', function () { fileInput.click(); });
    dz.addEventListener('dragover', function (e) { e.preventDefault(); dz.classList.add('border-blue-400'); });
    dz.addEventListener('dragleave', function () { dz.classList.remove('border-blue-400'); });
    dz.addEventListener('drop', function (e) { e.preventDefault(); dz.classList.remove('border-blue-400'); if (e.dataTransfer.files[0]) uploadImage(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function () { if (fileInput.files[0]) uploadImage(fileInput.files[0]); });
    function uploadImage(file) {
        var id = el('edit-id').value;
        var fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('id', id); fd.append('file', file);
        el('edit-drop-text').textContent = 'Uploading…';
        fetch(base + 'UploadImage', { method: 'POST', body: fd })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d || !d.ok) { alert((d && d.error) || 'Upload failed.'); el('edit-drop-text').textContent = 'Drag & drop an image, or browse'; return; }
                var prev = el('edit-image-preview'); prev.src = d.url; prev.classList.remove('hidden');
                el('edit-drop-text').textContent = 'Image added ✓ — drag to replace';
                var tr = rowFor(id), ic = cell(tr, 'image');
                if (ic) ic.innerHTML = '<img src="' + d.url + '" class="w-8 h-8 object-cover rounded inline-block" alt="" />';
            })
            .catch(function () { alert('Upload failed.'); el('edit-drop-text').textContent = 'Drag & drop an image, or browse'; });
    }

    // ── Quick Add modal ─────────────────────────────────────────────────────────
    var qa = document.getElementById('quick-add');
    document.getElementById('quick-add-btn').addEventListener('click', function () { qa.classList.remove('hidden'); });
    document.getElementById('quick-cancel').addEventListener('click', function () { qa.classList.add('hidden'); });
    qa.addEventListener('click', function (e) { if (e.target === qa) qa.classList.add('hidden'); });

    // ── Items per page ──────────────────────────────────────────────────────────
    document.getElementById('page-size').addEventListener('change', function () {
        var u = new URL(window.location.href); u.searchParams.set('pageSize', this.value); u.searchParams.set('page', '1'); window.location.href = u.toString();
    });

    // ── Drag-to-reorder columns (persisted per device) ──────────────────────────
    var KEY = 'invprod-colorder';
    function allRows() { return [table.tHead.rows[0]].concat(Array.prototype.slice.call(table.tBodies[0].rows)); }
    function currentOrder() { return Array.prototype.map.call(table.tHead.rows[0].cells, function (c) { return c.dataset.col; }); }
    function applyOrder(order) {
        if (!order || !order.length) return;
        allRows().forEach(function (row) {
            var map = {};
            Array.prototype.forEach.call(row.cells, function (c) { if (c.dataset.col) map[c.dataset.col] = c; });
            order.forEach(function (col) { if (map[col]) row.appendChild(map[col]); });
            if (map['actions']) row.appendChild(map['actions']);
        });
    }
    try { var savedOrder = JSON.parse(localStorage.getItem(KEY) || 'null'); if (savedOrder) applyOrder(savedOrder); } catch (e) {}
    var dragCol = null;
    table.querySelectorAll('th.prod-th[draggable="true"]').forEach(function (th) {
        th.style.cursor = 'grab';
        th.addEventListener('dragstart', function (e) { dragCol = th.dataset.col; e.dataTransfer.effectAllowed = 'move'; });
        th.addEventListener('dragover', function (e) { e.preventDefault(); th.classList.add('bg-blue-50'); });
        th.addEventListener('dragleave', function () { th.classList.remove('bg-blue-50'); });
        th.addEventListener('drop', function (e) {
            e.preventDefault(); th.classList.remove('bg-blue-50');
            var targetCol = th.dataset.col;
            if (!dragCol || dragCol === targetCol) return;
            var order = currentOrder().filter(function (c) { return c !== 'actions'; });
            order.splice(order.indexOf(dragCol), 1);
            order.splice(order.indexOf(targetCol), 0, dragCol);
            order.push('actions');
            applyOrder(order);
            try { localStorage.setItem(KEY, JSON.stringify(order)); } catch (e2) {}
            dragCol = null;
        });
    });

    // ── Excel-style column resize (drag the right border; widths persisted) ──────
    var WKEY = 'invprod-colwidths';
    var headThs = Array.prototype.slice.call(table.tHead.rows[0].cells);
    // Capture natural widths under auto layout, then lock to fixed layout so widths stick.
    var saved = {}; try { saved = JSON.parse(localStorage.getItem(WKEY) || '{}') || {}; } catch (e) {}
    var measured = {};
    headThs.forEach(function (th) { if (th.offsetWidth > 0) measured[th.dataset.col] = th.offsetWidth; });
    table.classList.add('table-fixed');
    headThs.forEach(function (th) {
        var k = th.dataset.col;
        if (k === 'actions') return;                  // let the last column flex to fill width
        var w = saved[k] || measured[k] || 140;
        th.style.width = w + 'px';
    });
    function saveWidths() {
        var o = {};
        headThs.forEach(function (th) { if (th.style.width && th.dataset.col !== 'actions') o[th.dataset.col] = parseInt(th.style.width, 10); });
        try { localStorage.setItem(WKEY, JSON.stringify(o)); } catch (e) {}
    }
    headThs.forEach(function (th) {
        if (th.dataset.col === 'actions') return;
        th.style.position = 'relative';
        var grip = document.createElement('div');
        grip.style.cssText = 'position:absolute;top:0;right:0;width:7px;height:100%;cursor:col-resize;z-index:5;';
        grip.addEventListener('dragstart', function (e) { e.preventDefault(); e.stopPropagation(); });
        grip.addEventListener('click', function (e) { e.stopPropagation(); });
        grip.addEventListener('mousedown', function (e) {
            e.preventDefault(); e.stopPropagation();
            var startX = e.pageX, startW = th.offsetWidth;
            th.draggable = false;                      // suspend reorder-drag while resizing
            document.body.style.cursor = 'col-resize';
            function mv(ev) { th.style.width = Math.max(56, startW + (ev.pageX - startX)) + 'px'; }
            function up() {
                document.removeEventListener('mousemove', mv);
                document.removeEventListener('mouseup', up);
                document.body.style.cursor = '';
                th.draggable = true;
                saveWidths();
            }
            document.addEventListener('mousemove', mv);
            document.addEventListener('mouseup', up);
        });
        th.appendChild(grip);
    });
}());
</script>
}
