@model List<SterlingLams.Web.Areas.Inventory.Controllers.StocktakeRow>
@{
    ViewData["Title"] = "Stock-take";
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    var categories = ViewBag.Categories as List<SterlingLams.Web.Models.Domain.Category> ?? new();
    int? storeId = ViewBag.StoreId;
    string q = ViewBag.Q ?? "";
    int pg = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int? categoryId = ViewBag.CategoryId;
    var storeName = stores.FirstOrDefault(s => s.Id == storeId)?.Name;
    var selectCls = "border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white focus:outline-none focus:border-emerald-400";
}
@Html.AntiForgeryToken()

<div class="mb-2">
    <h1 class="text-lg font-medium text-neutral-800">Stock-take</h1>
    <p class="text-xs text-neutral-400">Count a branch, enter the physical quantities, and reconcile any variance through the ledger.</p>
</div>

<!-- Branch + search picker -->
<form asp-area="Inventory" asp-controller="Stocktake" asp-action="Index" method="get" class="flex flex-wrap items-end gap-3 bg-white border border-neutral-100 rounded-sm p-4 mb-4">
    <div>
        <label class="block text-xs text-neutral-500 mb-1">Branch</label>
        <select name="storeId" onchange="this.form.submit()" class="border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white">
            <option value="">— Select a branch —</option>
            @foreach (var s in stores)
            {
                <option value="@s.Id" selected="@(storeId == s.Id)">@s.Name</option>
            }
        </select>
    </div>
    @if (storeId != null)
    {
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Search</label>
            <input id="stocktake-scan" type="text" name="q" value="@q" autofocus autocomplete="off" placeholder="Scan barcode or search…" class="border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:border-emerald-400 focus:outline-none" />
        </div>
        <div>
            <label class="block text-xs text-neutral-500 mb-1">Category</label>
            <select name="categoryId" onchange="this.form.submit()" class="@selectCls">
                <option value="">All categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(categoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="px-4 py-2 text-sm border border-neutral-200 rounded-sm hover:border-neutral-400">Go</button>
    }
</form>

@if (storeId == null)
{
    <div class="bg-white border border-neutral-100 rounded-sm p-12 text-center text-sm text-neutral-400">Choose a branch to start counting.</div>
}
else
{
    <div class="flex items-center justify-between mb-3">
        <p class="text-xs text-neutral-500">Counting <strong>@storeName</strong> — <span id="entered-count">0</span> counted</p>
        <button type="button" id="apply-stocktake" class="px-4 py-2 bg-emerald-600 text-white text-xs rounded-sm hover:bg-emerald-700 transition-colors">Apply stock-take</button>
    </div>

    <div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-neutral-50 text-neutral-500 text-xs uppercase tracking-wide">
                <tr>
                    <th class="text-left font-medium px-4 py-3">Product</th>
                    <th class="text-right font-medium px-4 py-3">System</th>
                    <th class="text-center font-medium px-4 py-3">Counted</th>
                    <th class="text-right font-medium px-4 py-3">Variance</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                @if (!Model.Any()) { <tr><td colspan="4" class="px-4 py-10 text-center text-neutral-400">No products.</td></tr> }
                @foreach (var r in Model)
                {
                    <tr class="hover:bg-neutral-50" data-row-pid="@r.ProductId">
                        <td class="px-4 py-2.5">
                            <p class="text-xs text-neutral-800">@r.Name</p>
                            @if (!string.IsNullOrEmpty(r.Sku)) { <p class="text-[10px] text-neutral-400 font-mono">@r.Sku</p> }
                            @if (r.HasVariants) { <p class="text-[10px] text-amber-600">@r.Variants.Count variant(s) — row is unallocated pool</p> }
                        </td>
                        <td class="px-4 py-2.5 text-right text-neutral-600">@r.System</td>
                        <td class="px-4 py-2.5 text-center">
                            <input type="number" min="0" placeholder="—"
                                   data-pid="@r.ProductId" data-vid="" data-system="@r.System"
                                   class="count-cell w-20 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400" />
                        </td>
                        <td class="px-4 py-2.5 text-right text-xs variance-cell" data-pid="@r.ProductId" data-vid="">—</td>
                    </tr>
                    @foreach (var v in r.Variants)
                    {
                        <tr class="bg-neutral-50/60" data-row-pid="@r.ProductId" data-row-vid="@v.VariantId">
                            <td class="px-4 py-1.5 pl-10">
                                <p class="text-[11px] text-neutral-600">↳ @v.Name</p>
                                @if (!string.IsNullOrEmpty(v.Sku)) { <p class="text-[10px] text-neutral-400 font-mono">@v.Sku</p> }
                            </td>
                            <td class="px-4 py-1.5 text-right text-neutral-500">@v.System</td>
                            <td class="px-4 py-1.5 text-center">
                                <input type="number" min="0" placeholder="—"
                                       data-pid="@r.ProductId" data-vid="@v.VariantId" data-system="@v.System"
                                       class="count-cell w-20 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400" />
                            </td>
                            <td class="px-4 py-1.5 text-right text-xs variance-cell" data-pid="@r.ProductId" data-vid="@v.VariantId">—</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="flex items-center justify-center gap-1.5 mt-4 flex-wrap text-xs text-neutral-500">
            <span>Page @pg of @totalPages</span>
            @if (pg > 1) { <a asp-area="Inventory" asp-controller="Stocktake" asp-action="Index" asp-route-storeId="@storeId" asp-route-q="@q" asp-route-categoryId="@categoryId" asp-route-page="@(pg-1)" class="px-3 py-1.5 border border-neutral-200 rounded-sm hover:border-neutral-400">‹ Prev</a> }
            @if (pg < totalPages) { <a asp-area="Inventory" asp-controller="Stocktake" asp-action="Index" asp-route-storeId="@storeId" asp-route-q="@q" asp-route-categoryId="@categoryId" asp-route-page="@(pg+1)" class="px-3 py-1.5 border border-neutral-200 rounded-sm hover:border-neutral-400">Next ›</a> }
        </div>
        <p class="text-center text-[11px] text-amber-600 mt-2">Counts you enter are saved only when you click “Apply stock-take”. Apply before changing page.</p>
    }

    <script>
    (function () {
        const storeId = @storeId;
        const btn = document.getElementById('apply-stocktake');
        const enteredEl = document.getElementById('entered-count');
        const token = document.querySelector('input[name="__RequestVerificationToken"]');
        const counted = () => [...document.querySelectorAll('input.count-cell')].filter(i => i.value !== '');
        function refresh() {
            enteredEl.textContent = counted().length;
            document.querySelectorAll('input.count-cell').forEach(i => {
                const vc = document.querySelector(`.variance-cell[data-pid="${i.dataset.pid}"][data-vid="${i.dataset.vid || ''}"]`);
                if (!vc) return;
                if (i.value === '') { vc.textContent = '—'; vc.className = 'px-4 py-2.5 text-right text-xs variance-cell text-neutral-300'; return; }
                const v = (+i.value) - (+i.dataset.system);
                vc.textContent = (v > 0 ? '+' : '') + v;
                vc.className = 'px-4 py-2.5 text-right text-xs variance-cell ' + (v === 0 ? 'text-neutral-400' : v > 0 ? 'text-emerald-600' : 'text-red-600');
            });
        }
        document.addEventListener('input', e => { if (e.target.classList && e.target.classList.contains('count-cell')) refresh(); });
        refresh();
        btn.addEventListener('click', async () => {
            const counts = counted().map(i => ({ productId: +i.dataset.pid, variantId: i.dataset.vid ? +i.dataset.vid : null, counted: +i.value }));
            if (!counts.length) { alert('Enter at least one count.'); return; }
            if (!confirm('Reconcile ' + counts.length + ' product(s) to the counted quantities? This adjusts stock via the ledger.')) return;
            btn.disabled = true; btn.textContent = 'Applying…';
            try {
                const res = await fetch('/Inventory/Stocktake/Apply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ? token.value : '' },
                    body: JSON.stringify({ storeId: storeId, counts: counts })
                });
                const data = await res.json();
                if (data.success) { alert(data.count + ' product(s) reconciled.'); location.reload(); }
                else { alert(data.message || 'Failed.'); btn.disabled = false; btn.textContent = 'Apply stock-take'; }
            } catch { alert('Failed. Please try again.'); btn.disabled = false; btn.textContent = 'Apply stock-take'; }
        });

        // ── Scan box ────────────────────────────────────────────────────────────
        // Exact barcode/SKU match → jump to / insert the row inline (no reload, so
        // unsaved counts above survive). Anything else falls back to the normal search.
        const scanBox = document.getElementById('stocktake-scan');
        const tbody = document.querySelector('table tbody');
        const esc = s => String(s).replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));

        function buildRow(data) {
            const tr = document.createElement('tr');
            tr.className = 'hover:bg-neutral-50';
            tr.setAttribute('data-row-pid', data.productId);
            tr.innerHTML = `<td class="px-4 py-2.5">
                    <p class="text-xs text-neutral-800">${esc(data.name)}</p>
                    ${data.sku ? `<p class="text-[10px] text-neutral-400 font-mono">${esc(data.sku)}</p>` : ''}
                </td>
                <td class="px-4 py-2.5 text-right text-neutral-600">${data.system}</td>
                <td class="px-4 py-2.5 text-center">
                    <input type="number" min="0" placeholder="—" data-pid="${data.productId}" data-vid="" data-system="${data.system}"
                           class="count-cell w-20 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400" />
                </td>
                <td class="px-4 py-2.5 text-right text-xs variance-cell" data-pid="${data.productId}" data-vid="">—</td>`;
            return tr;
        }

        scanBox.addEventListener('keydown', async (e) => {
            if (e.key !== 'Enter') return;
            // Always swallow Enter on this box: an empty submit would reload the page
            // and silently discard unsaved counts.
            e.preventDefault();
            const code = scanBox.value.trim();
            if (!code) return;
            if (!tbody) { scanBox.closest('form').submit(); return; }
            const res = await fetch(`/Inventory/Stocktake/ScanLookup?code=${encodeURIComponent(code)}&storeId=${storeId}`);
            const data = await res.json();
            if (!data.found) { scanBox.closest('form').submit(); return; }
            scanBox.value = '';
            let row = tbody.querySelector(`tr[data-row-pid="${data.productId}"]`);
            if (!row) {
                const placeholder = tbody.querySelector('td[colspan]');
                if (placeholder) placeholder.closest('tr').remove();
                row = buildRow(data);
                tbody.prepend(row);
                refresh();
            }
            row.scrollIntoView({ behavior: 'smooth', block: 'center' });
            row.classList.add('bg-emerald-50');
            setTimeout(() => row.classList.remove('bg-emerald-50'), 1500);
            row.querySelector('.count-cell')?.focus();
        });
    })();
    </script>
}
