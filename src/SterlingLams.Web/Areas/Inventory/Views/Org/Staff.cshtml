@model List<SterlingLams.Web.Areas.Inventory.Controllers.StaffRow>
@{
    ViewData["Title"] = "Staff & roles";
    var canManageOrg = ViewData["CanManageOrg"] as bool? == true; // Owner is view-only here
    var roleCounts = ViewBag.RoleCounts as Dictionary<string, int> ?? new();
    string RoleBadge(string r) => r switch
    {
        "Admin" => "bg-red-50 text-red-700", "Manager" => "bg-indigo-50 text-indigo-700",
        "Inventory" => "bg-emerald-50 text-emerald-700", "Cashier" => "bg-blue-50 text-blue-700",
        _ => "bg-neutral-100 text-neutral-600"
    };
}

<div class="flex items-center justify-between mb-4">
    <h1 class="font-cormorant text-2xl font-light text-neutral-900">Staff &amp; roles</h1>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index" target="_blank"
       class="text-xs text-neutral-500 hover:text-neutral-800 border border-neutral-200 rounded-sm px-3 py-1.5">Manage in Website Admin ↗</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 text-sm text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-lg px-4 py-2.5">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 text-sm text-red-700 bg-red-50 border border-red-100 rounded-lg px-4 py-2.5">@TempData["Error"]</div>
}

@if (roleCounts.Any())
{
    <div class="flex flex-wrap gap-3 mb-4">
        @foreach (var rc in roleCounts)
        {
            <div class="bg-white border border-neutral-100 rounded-sm px-4 py-3">
                <span class="px-2 py-0.5 rounded-sm text-[11px] @RoleBadge(rc.Key)">@rc.Key</span>
                <span class="text-lg font-light text-neutral-800 ml-2">@rc.Value</span>
            </div>
        }
    </div>
}

<div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
    <table class="w-full text-sm min-w-[560px]">
        <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100 text-xs text-neutral-400">
                <th class="text-left px-4 py-3 font-medium">Staff</th>
                <th class="text-left px-4 py-3 font-medium">Roles</th>
                <th class="text-left px-4 py-3 font-medium">POS PIN</th>
                <th class="text-left px-4 py-3 font-medium">Last login</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (Model.Any())
            {
                @foreach (var s in Model)
                {
                    <tr class="hover:bg-neutral-50">
                        <td class="px-4 py-3">
                            <div class="text-neutral-800">@(string.IsNullOrWhiteSpace(s.Name) ? "—" : s.Name)</div>
                            <div class="text-[11px] text-neutral-400">@s.Email</div>
                        </td>
                        <td class="px-4 py-3">
                            @foreach (var r in s.Roles)
                            {
                                <span class="px-2 py-0.5 rounded-sm text-[11px] mr-1 @RoleBadge(r)">@r</span>
                            }
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">
                            @if (s.HasPin)
                            {
                                <span class="text-[11px] text-emerald-600 mr-2">● Set</span>
                            }
                            else
                            {
                                <span class="text-[11px] text-neutral-400 mr-2">Not set</span>
                            }
                            @if (canManageOrg)
                            {
                                <button type="button" onclick="cashierPin('@s.Id')" class="text-xs text-neutral-600 hover:text-neutral-900 transition-colors">@(s.HasPin ? "Change" : "Set PIN")</button>
                                @if (s.HasPin)
                                {
                                    <form asp-area="Inventory" asp-controller="Org" asp-action="SetCashierPin" method="post" class="inline ml-2"
                                          onsubmit="return confirm('Remove this staff member’s POS PIN?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <input type="hidden" name="pin" value="" />
                                        <button type="submit" class="text-xs text-red-500 hover:text-red-700 transition-colors">Clear</button>
                                    </form>
                                }
                            }
                        </td>
                        <td class="px-4 py-3 text-neutral-400 text-xs">@(s.LastLogin?.ToLocalTime().ToString("dd MMM yyyy, HH:mm") ?? "Never")</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="px-4 py-10 text-center text-sm text-neutral-400">No staff accounts found.</td></tr>
            }
        </tbody>
    </table>
</div>

@{
    var cashiers = ViewBag.Cashiers as List<SterlingLams.Web.Areas.Inventory.Controllers.CashierRow> ?? new();
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    string Branch(string n) => n.Replace("Sterlin Glams ", "");
}

<!-- ── Cashiers (POS logins) ───────────────────────────────────────────── -->
<div class="mt-10 mb-3">
    <h2 class="font-cormorant text-2xl font-light text-neutral-900">Cashiers</h2>
    <p class="text-xs text-neutral-400">Staff who sign into the POS app with a PIN. They have no back-office access.</p>
</div>

@if (canManageOrg)
{
<!-- Add cashier -->
<div class="bg-white rounded-sm border border-neutral-100 p-5 mb-5">
    <h3 class="text-sm font-semibold text-neutral-700 mb-3">Add cashier</h3>
    <form asp-area="Inventory" asp-controller="Org" asp-action="AddCashier" method="post" class="flex flex-wrap gap-3 items-end">
        @Html.AntiForgeryToken()
        <input type="text" name="firstName" placeholder="First name" required
               class="border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
        <input type="text" name="lastName" placeholder="Last name"
               class="border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
        <input type="tel" name="phone" placeholder="Phone"
               class="border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
        <select name="storeId" required
                class="border border-neutral-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:border-emerald-500">
            <option value="">— Branch —</option>
            @foreach (var s in stores)
            {
                <option value="@s.Id">@Branch(s.Name)</option>
            }
        </select>
        <input type="text" name="pin" inputmode="numeric" pattern="\d{4,8}" placeholder="PIN (4–8 digits)" required
               class="w-32 border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
        <button type="submit" class="px-4 py-2 bg-emerald-600 text-white text-sm rounded-lg hover:bg-emerald-700 transition-colors">Add cashier</button>
    </form>
</div>
}

<div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
        <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100 text-xs text-neutral-400">
                <th class="text-left px-4 py-3 font-medium">Cashier</th>
                <th class="text-left px-4 py-3 font-medium">Branch</th>
                <th class="text-left px-4 py-3 font-medium">Last login</th>
                <th class="text-right px-4 py-3 font-medium">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (cashiers.Any())
            {
                @foreach (var c in cashiers)
                {
                    <tr class="hover:bg-neutral-50">
                        <td class="px-4 py-3">
                            <div class="text-neutral-800">@(string.IsNullOrWhiteSpace(c.Name) ? "—" : c.Name)</div>
                            @if (!string.IsNullOrEmpty(c.Phone))
                            {
                                <div class="text-[11px] text-neutral-400">@c.Phone</div>
                            }
                        </td>
                        <td class="px-4 py-3">
                            @if (canManageOrg)
                            {
                                <form asp-area="Inventory" asp-controller="Org" asp-action="SetCashierStore" method="post" class="flex items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <select name="storeId" onchange="this.form.submit()"
                                            class="border border-neutral-200 rounded-lg px-2 py-1 text-xs bg-white focus:outline-none focus:border-emerald-500">
                                        <option value="0">All branches</option>
                                        @foreach (var s in stores)
                                        {
                                            <option value="@s.Id" selected="@(c.StoreId == s.Id)">@Branch(s.Name)</option>
                                        }
                                    </select>
                                </form>
                            }
                            else
                            {
                                <span class="text-xs text-neutral-600">@(c.StoreId == 0 ? "All branches" : Branch(stores.FirstOrDefault(s => s.Id == c.StoreId)?.Name ?? "—"))</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-neutral-400 text-xs">@(c.LastLogin?.ToLocalTime().ToString("dd MMM yyyy, HH:mm") ?? "Never")</td>
                        <td class="px-4 py-3 text-right whitespace-nowrap">
                            @if (canManageOrg)
                            {
                                <button type="button" onclick="cashierPin('@c.Id')" class="text-xs text-neutral-600 hover:text-neutral-900 transition-colors mr-3">Change PIN</button>
                                <form asp-area="Inventory" asp-controller="Org" asp-action="SetCashierPin" method="post" class="inline"
                                      onsubmit="return confirm('Remove POS access for this cashier?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <input type="hidden" name="pin" value="" />
                                    <button type="submit" class="text-xs text-red-500 hover:text-red-700 transition-colors">Remove access</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-[10px] text-neutral-300">—</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="px-4 py-10 text-center text-sm text-neutral-400">No cashiers yet. Add one above.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Hidden form used by the Change-PIN prompt -->
<form asp-area="Inventory" asp-controller="Org" asp-action="SetCashierPin" method="post" id="cashier-pin-form" class="hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="cashier-pin-id" />
    <input type="hidden" name="pin" id="cashier-pin-value" />
</form>

@section Scripts {
<script>
    function cashierPin(id) {
        const pin = prompt('Enter a new 4–8 digit POS PIN for this cashier:');
        if (pin === null) return;
        if (!/^\d{4,8}$/.test(pin.trim())) { alert('PIN must be 4–8 digits.'); return; }
        document.getElementById('cashier-pin-id').value = id;
        document.getElementById('cashier-pin-value').value = pin.trim();
        document.getElementById('cashier-pin-form').submit();
    }
</script>
}
