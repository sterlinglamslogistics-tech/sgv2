@model SterlingLams.Web.Areas.Admin.ViewModels.AdminInventoryViewModel
@{
    ViewData["Title"] = "Stock";
    Dictionary<string, string> rd(int pg) => new() { ["q"] = Model.SearchQuery ?? "", ["categoryId"] = Model.CategoryFilter ?? "", ["page"] = pg.ToString() };
    var baseCls = "px-3 py-1.5 text-xs rounded-sm border border-neutral-200 text-neutral-600 hover:border-neutral-400 transition-colors";
    var selectCls = "border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white focus:outline-none focus:border-emerald-400";
}
@Html.AntiForgeryToken()

<div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
    <form asp-area="Inventory" asp-controller="Stock" asp-action="Index" method="get" class="flex gap-2 flex-wrap">
        <input id="stock-scan" type="text" name="q" value="@Model.SearchQuery" autofocus autocomplete="off" placeholder="Scan barcode or search…"
               class="w-72 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-emerald-400" />
        <select name="categoryId" onchange="this.form.submit()" class="@selectCls">
            <option value="">All categories</option>
            @foreach (var c in Model.AvailableCategories)
            {
                <option value="@c.Id" selected="@(Model.CategoryFilter == c.Id.ToString())">@c.Name</option>
            }
        </select>
        <button type="submit" class="px-4 py-2 text-sm border border-neutral-200 rounded-sm hover:border-neutral-400">Search</button>
    </form>
    <div class="flex gap-2 items-center">
        <a asp-area="Inventory" asp-controller="Stock" asp-action="ExportCsv" asp-route-q="@Model.SearchQuery" asp-route-categoryId="@Model.CategoryFilter"
           class="px-4 py-2 border border-neutral-200 text-neutral-700 text-xs rounded-sm hover:border-neutral-400 transition-colors">Export CSV</a>
        <select id="adjust-reason" title="Reason for the stock change" class="border border-neutral-200 rounded-sm px-2 py-2 text-xs bg-white">
            <option value="Stock count">Stock count</option>
            <option value="Received">Received</option>
            <option value="Damage">Damage</option>
            <option value="Loss / theft">Loss / theft</option>
            <option value="Correction">Correction</option>
            <option value="Other">Other</option>
        </select>
        <button type="button" id="save-all-stock"
                class="px-4 py-2 bg-emerald-600 text-white text-xs rounded-sm hover:bg-emerald-700 transition-colors">
            Save all changes<span id="stock-change-count"></span>
        </button>
    </div>
</div>

@if (!Model.Products.Any())
{
    <div class="bg-white border border-neutral-100 rounded-sm p-16 text-center text-sm text-neutral-400">No products found.</div>
}
else
{
    <div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
        <table class="w-full text-sm min-w-[640px]">
            <thead>
                <tr class="bg-neutral-50 border-b border-neutral-100">
                    <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Product</th>
                    <th class="text-center px-4 py-3 text-xs text-neutral-400 font-medium">Total</th>
                    @foreach (var s in Model.Stores)
                    {
                        <th class="text-center px-3 py-3 text-xs text-neutral-400 font-medium whitespace-nowrap">@s.Name.Replace("Sterlin Glams ", "")</th>
                    }
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-50">
                @foreach (var row in Model.Products)
                {
                    var total = row.TotalStock;
                    <tr class="hover:bg-neutral-50 @(row.HasVariants ? "product-row cursor-pointer" : "")" data-row-pid="@row.ProductId">
                        <td class="px-4 py-3">
                            <div class="flex items-start gap-1.5">
                                @if (row.HasVariants)
                                {
                                    <svg class="variant-chevron w-3 h-3 text-neutral-400 mt-0.5 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                }
                                <div>
                                    <p class="text-xs font-medium text-neutral-800 leading-snug">@row.ProductName</p>
                                    @if (!string.IsNullOrEmpty(row.Sku)) { <p class="text-[10px] text-neutral-400 font-mono mt-0.5">@row.Sku</p> }
                                    @if (row.HasVariants) { <p class="text-[10px] text-emerald-600 mt-0.5">@row.Variants.Count variant(s) — click to set stock per variant</p> }
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span class="text-sm font-medium @(total == 0 ? "text-red-600" : "text-neutral-800")">@total</span>
                        </td>
                        @foreach (var s in Model.Stores)
                        {
                            @if (row.HasVariants)
                            {
                                @* Variant products: product figure is read-only — it just rolls up the variants. *@
                                var vsum = row.Variants.Sum(v => v.StockByStore.TryGetValue(s.Id, out var vv) && vv > 0 ? vv : 0);
                                <td class="px-3 py-3 text-center text-xs @(vsum == 0 ? "text-red-500" : "text-neutral-500")" title="Sum of variants — set per variant below">@vsum</td>
                            }
                            else
                            {
                                var qty = row.StockByStore.TryGetValue(s.Id, out var q2) ? q2 : -1;
                                <td class="px-3 py-2 text-center">
                                    <input type="number" min="0"
                                           placeholder="@(qty == -1 ? "—" : "")"
                                           value="@(qty == -1 ? "" : qty.ToString())"
                                           data-pid="@row.ProductId" data-vid="" data-sid="@s.Id" data-orig="@(qty == -1 ? "" : qty.ToString())"
                                           class="stock-cell w-16 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400 bg-white @(qty == 0 ? "text-red-600 border-red-200" : "")" />
                                </td>
                            }
                        }
                    </tr>
                    @foreach (var v in row.Variants)
                    {
                        <tr class="bg-neutral-50/60 hidden" data-row-pid="@row.ProductId" data-row-vid="@v.VariantId">
                            <td class="px-4 py-1.5 pl-10">
                                <p class="text-[11px] text-neutral-600 leading-snug">↳ @v.Name</p>
                                @if (!string.IsNullOrEmpty(v.Sku)) { <p class="text-[10px] text-neutral-400 font-mono">@v.Sku</p> }
                            </td>
                            <td class="px-4 py-1.5 text-center text-[11px] text-neutral-400">@v.StockByStore.Values.Where(q => q >= 0).Sum()</td>
                            @foreach (var s in Model.Stores)
                            {
                                var vq = v.StockByStore.TryGetValue(s.Id, out var q3) ? q3 : -1;
                                <td class="px-3 py-1.5 text-center">
                                    <input type="number" min="0"
                                           placeholder="@(vq == -1 ? "—" : "")"
                                           value="@(vq == -1 ? "" : vq.ToString())"
                                           data-pid="@row.ProductId" data-vid="@v.VariantId" data-sid="@s.Id" data-orig="@(vq == -1 ? "" : vq.ToString())"
                                           class="stock-cell w-16 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400 bg-white @(vq == 0 ? "text-red-600 border-red-200" : "")" />
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        var cur = Model.CurrentPage; var last = Model.TotalPages;
        var start = Math.Max(1, cur - 2); var end = Math.Min(last, cur + 2);
        <div class="flex items-center justify-center gap-1.5 mt-4 flex-wrap">
            <span class="text-[11px] text-neutral-400 mr-1">Page @cur of @last</span>
            @if (cur > 1)
            {
                <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-all-route-data="rd(1)" class="@baseCls">« First</a>
                <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-all-route-data="rd(cur - 1)" class="@baseCls">‹ Prev</a>
            }
            @for (int pg = start; pg <= end; pg++)
            {
                <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-all-route-data="rd(pg)"
                   class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(pg == cur ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">@pg</a>
            }
            @if (cur < last)
            {
                <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-all-route-data="rd(cur + 1)" class="@baseCls">Next ›</a>
                <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-all-route-data="rd(last)" class="@baseCls">Last »</a>
            }
        </div>
    }

    <script>
    (function () {
        const btn = document.getElementById('save-all-stock');
        const countEl = document.getElementById('stock-change-count');
        const token = document.querySelector('input[name="__RequestVerificationToken"]');
        const changed = () => [...document.querySelectorAll('input.stock-cell')]
            .filter(i => i.value !== '' && i.value !== i.getAttribute('data-orig'));
        const refresh = () => { const n = changed().length; countEl.textContent = n ? ' (' + n + ')' : ''; };
        document.addEventListener('input', e => { if (e.target.classList && e.target.classList.contains('stock-cell')) refresh(); });
        refresh();

        // Expand/collapse a variant product's per-variant rows when its product row is clicked.
        document.querySelectorAll('tr.product-row').forEach(prow => {
            prow.addEventListener('click', (e) => {
                if (e.target.closest('input, a, button')) return;
                const pid = prow.getAttribute('data-row-pid');
                prow.querySelector('.variant-chevron')?.classList.toggle('rotate-90');
                document.querySelectorAll(`tr[data-row-pid="${pid}"][data-row-vid]`).forEach(vr => vr.classList.toggle('hidden'));
            });
        });

        btn.addEventListener('click', async () => {
            const edits = changed().map(i => ({
                productId: +i.dataset.pid,
                variantId: i.dataset.vid ? +i.dataset.vid : null,
                storeId: +i.dataset.sid,
                quantity: +i.value
            }));
            if (!edits.length) { alert('No changes to save.'); return; }
            btn.disabled = true; btn.textContent = 'Saving…';
            try {
                const res = await fetch('/Inventory/Stock/SetAll', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ? token.value : '' },
                    body: JSON.stringify({ reason: document.getElementById('adjust-reason').value, edits: edits })
                });
                const data = await res.json();
                if (data.success) { location.reload(); }
                else { alert('Save failed.'); btn.disabled = false; btn.textContent = 'Save all changes'; }
            } catch { alert('Save failed. Please try again.'); btn.disabled = false; btn.textContent = 'Save all changes'; }
        });

        // ── Scan box ────────────────────────────────────────────────────────────
        // Exact barcode/SKU match → jump to / insert the row inline (no reload, so
        // unsaved edits above survive). Anything else falls back to the normal search.
        const storeIds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stores.Select(s => s.Id)));
        const scanBox = document.getElementById('stock-scan');
        const tbody = document.querySelector('table tbody');
        const esc = s => String(s).replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));

        function buildRow(data) {
            const total = storeIds.reduce((s, id) => s + (data.stock[id] ?? 0), 0);
            const tr = document.createElement('tr');
            tr.className = 'hover:bg-neutral-50';
            tr.setAttribute('data-row-pid', data.productId);
            let cells = `<td class="px-4 py-3">
                <p class="text-xs font-medium text-neutral-800 leading-snug">${esc(data.productName)}</p>
                ${data.sku ? `<p class="text-[10px] text-neutral-400 font-mono mt-0.5">${esc(data.sku)}</p>` : ''}
            </td>
            <td class="px-4 py-3 text-center"><span class="text-sm font-medium ${total === 0 ? 'text-red-600' : 'text-neutral-800'}">${total}</span></td>`;
            storeIds.forEach(id => {
                const qty = data.stock[id] ?? 0;
                cells += `<td class="px-3 py-2 text-center"><input type="number" min="0" value="${qty}"
                    data-pid="${data.productId}" data-sid="${id}" data-orig="${qty}"
                    class="stock-cell w-16 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-emerald-400 bg-white ${qty === 0 ? 'text-red-600 border-red-200' : ''}" /></td>`;
            });
            tr.innerHTML = cells;
            return tr;
        }

        scanBox.addEventListener('keydown', async (e) => {
            if (e.key !== 'Enter') return;
            // Always swallow Enter on this box: an empty submit would reload the page
            // and silently discard unsaved grid edits.
            e.preventDefault();
            const code = scanBox.value.trim();
            if (!code) return;
            if (!tbody) { scanBox.closest('form').submit(); return; }
            const res = await fetch('/Inventory/Stock/ScanLookup?code=' + encodeURIComponent(code));
            const data = await res.json();
            if (!data.found) { scanBox.closest('form').submit(); return; }
            let row = tbody.querySelector(`tr[data-row-pid="${data.productId}"]`);
            // Variant product not on this page → reload so its read-only roll-up + variant rows render.
            if (!row && data.hasVariants) { scanBox.closest('form').submit(); return; }
            scanBox.value = '';
            if (!row) {
                const placeholder = tbody.querySelector('td[colspan]');
                if (placeholder) placeholder.closest('tr').remove();
                row = buildRow(data);
                tbody.prepend(row);
            }
            if (data.hasVariants) {
                row.querySelector('.variant-chevron')?.classList.add('rotate-90');
                document.querySelectorAll(`tr[data-row-pid="${data.productId}"][data-row-vid]`).forEach(vr => vr.classList.remove('hidden'));
            }
            row.scrollIntoView({ behavior: 'smooth', block: 'center' });
            row.classList.add('bg-emerald-50');
            setTimeout(() => row.classList.remove('bg-emerald-50'), 1500);
            const focusTarget = data.hasVariants
                ? document.querySelector(`tr[data-row-pid="${data.productId}"][data-row-vid] .stock-cell`)
                : row.querySelector('.stock-cell');
            focusTarget?.focus();
        });
    })();
    </script>
}
