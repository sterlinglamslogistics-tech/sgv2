@model SterlingLams.Web.Areas.Inventory.Controllers.SalesSummaryVm
@{
    ViewData["Title"] = "Sales summary";
    DateTime from = ViewBag.From; DateTime to = ViewBag.To;
    var inCls = "border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white focus:outline-none focus:border-emerald-400";
    var maxRev = Model.Daily.Any() ? Model.Daily.Max(d => d.Revenue) : 0m;
}

@await Html.PartialAsync("_ReportTabs", "Summary")

<form method="get" class="flex flex-wrap items-end gap-2 mb-4">
    <div><label class="block text-[10px] text-neutral-400 uppercase tracking-widest mb-1">From</label>
        <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="@inCls" /></div>
    <div><label class="block text-[10px] text-neutral-400 uppercase tracking-widest mb-1">To</label>
        <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="@inCls" /></div>
    <button type="submit" class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700">Filter</button>
</form>

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <div class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Revenue</div>
        <div class="text-2xl font-light text-emerald-600">₦@Model.Revenue.ToString("N0")</div>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <div class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Orders</div>
        <div class="text-2xl font-light text-neutral-800">@Model.Orders.ToString("N0")</div>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <div class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Units sold</div>
        <div class="text-2xl font-light text-neutral-800">@Model.Units.ToString("N0")</div>
    </div>
    <div class="bg-white border border-neutral-100 rounded-sm p-4">
        <div class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Avg order</div>
        <div class="text-2xl font-light text-neutral-800">₦@Model.Average.ToString("N0")</div>
    </div>
</div>

<div class="bg-white border border-neutral-100 rounded-sm overflow-x-auto">
    <table class="w-full text-sm min-w-[480px]">
        <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100 text-xs text-neutral-400">
                <th class="text-left px-4 py-3 font-medium">Day</th>
                <th class="text-right px-4 py-3 font-medium">Orders</th>
                <th class="text-right px-4 py-3 font-medium">Revenue</th>
                <th class="text-left px-4 py-3 font-medium w-1/3">&nbsp;</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (Model.Daily.Any())
            {
                @foreach (var d in Model.Daily)
                {
                    var pct = maxRev > 0 ? (double)(d.Revenue / maxRev) * 100 : 0;
                    <tr class="hover:bg-neutral-50">
                        <td class="px-4 py-2.5 text-neutral-600 text-xs">@d.Day.ToString("ddd, dd MMM yyyy")</td>
                        <td class="px-4 py-2.5 text-right text-neutral-500">@d.Orders</td>
                        <td class="px-4 py-2.5 text-right font-medium text-neutral-800">₦@d.Revenue.ToString("N0")</td>
                        <td class="px-4 py-2.5"><div class="h-2 bg-emerald-100 rounded-sm"><div class="h-2 bg-emerald-500 rounded-sm" style="width:@pct.ToString("F0")%"></div></div></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="px-4 py-10 text-center text-sm text-neutral-400">No sales in this period.</td></tr>
            }
        </tbody>
    </table>
</div>
