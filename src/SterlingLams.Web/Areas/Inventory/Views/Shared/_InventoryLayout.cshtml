@{
    var cc = ViewContext.RouteData.Values["controller"]?.ToString();
    var ca = ViewContext.RouteData.Values["action"]?.ToString();
    var isFullAdmin = User.IsInRole("Admin");
    var pendingTransfers = ViewData["PendingTransfersCount"] as int? ?? 0;

    // Icons (heroicons paths)
    const string icoOverview  = "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6";
    const string icoProducts  = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4";
    const string icoStock     = "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10";
    const string icoTransfers = "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4";
    const string icoPos       = "M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z";
    const string icoStocktake = "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z";
    const string icoReport    = "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z";

    const string icoBag   = "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z";
    const string icoUsers = "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-3a4 4 0 10-8 0 4 4 0 008 0z";
    const string icoTag   = "M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z";

    // item = (Label, Controller, Action, Icon, MatchByAction, IsPlaceholder, ShowTransferBadge)
    (string Label, string Ctrl, string Action, string Icon, bool ByAction, bool Soon, bool Badge) R(string l, string c, string a, string ico, bool ba = false, bool badge = false) => (l, c, a, ico, ba, false, badge);
    (string Label, string Ctrl, string Action, string Icon, bool ByAction, bool Soon, bool Badge) S(string l, string ico) => (l, "Soon", "Index", ico, false, true, false);

    // Full Moniebook-style tree. Real pages link through; not-yet-built items are placeholders (→ Soon).
    var nav = new (string Header, bool Collapsible, (string Label, string Ctrl, string Action, string Icon, bool ByAction, bool Soon, bool Badge)[] Items)[]
    {
        ("", false, new[] { R("Overview", "Overview", "Index", icoOverview) }),
        ("Point of sale", false, new[] { R("POS", "Till", "Index", icoPos) }),
        ("Sales", true, new[] {
            R("Completed Sales", "Sales", "Completed", icoBag, true),
            R("Outstanding Sales", "Sales", "Outstanding", icoBag, true),
            R("Saved Carts", "Sales", "Saved", icoBag, true) }),
        ("CRM", true, new[] {
            R("Customers", "Crm", "Customers", icoUsers, true),
            R("Discounts", "Crm", "Discounts", icoTag, true) }),
        ("Inventory", true, new[] {
            R("All items", "Products", "Index", icoProducts),
            R("Categories", "Categories", "Index", icoTag, true),
            S("Taxes", icoTag),
            R("Stock levels", "Stock", "Index", icoStock),
            R("Stock adjustment", "Adjustments", "Index", icoStock),
            R("Stock-take", "Stocktake", "Index", icoStocktake),
            R("Stock transfer", "Transfers", "Index", icoTransfers, false, true),
            R("Stock history", "Reports", "Movements", icoReport, true),
            S("Batch management", icoStock),
            S("Production & Recipes", icoStock),
            S("Purchasing orders", icoStock),
            S("Measurement Units", icoTag),
            S("Suppliers", icoUsers) }),
        ("Reports", true, new[] {
            R("Reorder", "Reports", "Reorder", icoReport, true),
            R("Stock value", "Reports", "Value", icoReport, true),
            R("Stock movement", "Reports", "Movements", icoReport, true),
            R("Shrinkage", "Reports", "Shrinkage", icoReport, true),
            R("Sales summary", "Reports", "Summary", icoReport, true),
            R("Sales by item", "Reports", "SalesByItem", icoReport, true),
            R("Sales by category", "Reports", "SalesByCategory", icoReport, true),
            R("Sales by customer", "Reports", "SalesByCustomer", icoReport, true),
            R("Sales by staff", "Reports", "Sales", icoReport, true),
            R("Payment method", "Reports", "Payments", icoReport, true),
            R("Discounts", "Reports", "Discounts", icoReport, true),
            R("Expiring inventory", "Reports", "Expiring", icoReport, true),
            R("Inventory valuation", "Reports", "Value", icoReport, true),
            S("Sales by pricing groups", icoReport),
            S("Taxes ", icoReport) }),
        ("Administration", true, new[] {
            R("Staff & Roles", "Org", "Staff", icoUsers, true),
            R("Branches", "Org", "Branches", icoStock, true),
            R("Registers", "Org", "Registers", icoPos, true),
            R("Activity Log", "Org", "ActivityLog", icoReport, true) }),
    };

    var curFeature = Context.Request.Query["feature"].ToString();
    bool ItemActive((string Label, string Ctrl, string Action, string Icon, bool ByAction, bool Soon, bool Badge) it)
        => it.Soon ? (cc == "Soon" && it.Label == curFeature) : (cc == it.Ctrl && (!it.ByAction || ca == it.Action));
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Inventory — @ViewData["Title"] — Sterlin Glams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="bg-neutral-50 text-neutral-900 font-inter antialiased">

<div class="flex h-screen overflow-hidden">

    <!-- ─── Sidebar ──────────────────────────────────────────────────────── -->
    <aside class="w-60 bg-neutral-900 text-white flex flex-col flex-shrink-0 overflow-y-auto">
        <div class="px-6 py-6 border-b border-neutral-800">
            <span class="font-cormorant text-lg font-light tracking-[0.2em] uppercase">Sterlin Glams</span>
            <p class="text-[10px] text-emerald-400 tracking-widest uppercase mt-1 font-medium">Inventory System</p>
        </div>

        <nav class="flex-1 px-3 py-3 space-y-0.5 overflow-y-auto">
            @foreach (var grp in nav)
            {
                if (grp.Collapsible)
                {
                    <details class="group/nav" open>
                        <summary class="cursor-pointer list-none flex items-center justify-between px-3 pt-3 pb-1 text-[10px] tracking-widest uppercase text-neutral-500 hover:text-neutral-300">
                            <span>@grp.Header</span>
                            <svg class="w-3 h-3 transition-transform group-open/nav:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="space-y-0.5 mb-1">
                            @foreach (var it in grp.Items)
                            {
                                var active = ItemActive(it);
                                var routeData = it.Soon ? new Dictionary<string, string> { ["feature"] = it.Label } : new Dictionary<string, string>();
                                <a asp-area="Inventory" asp-controller="@it.Ctrl" asp-action="@it.Action" asp-all-route-data="routeData"
                                   class="flex items-center gap-3 px-3 py-2 rounded-sm text-sm transition-colors @(active ? "bg-emerald-600 text-white" : it.Soon ? "text-neutral-500 hover:text-neutral-300 hover:bg-neutral-800/50" : "text-neutral-400 hover:text-white hover:bg-neutral-800")">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@it.Icon"/></svg>
                                    <span class="flex-1">@it.Label</span>
                                    @if (it.Badge && pendingTransfers > 0)
                                    {
                                        <span class="text-[10px] font-medium bg-emerald-500 text-white rounded-full px-1.5 py-0.5 leading-none">@pendingTransfers</span>
                                    }
                                    @if (it.Soon)
                                    {
                                        <span class="text-[8px] uppercase tracking-wide text-neutral-600">soon</span>
                                    }
                                </a>
                            }
                        </div>
                    </details>
                }
                else
                {
                    foreach (var it in grp.Items)
                    {
                        var active = ItemActive(it);
                        <a asp-area="Inventory" asp-controller="@it.Ctrl" asp-action="@it.Action"
                           class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm transition-colors @(active ? "bg-emerald-600 text-white" : "text-neutral-400 hover:text-white hover:bg-neutral-800")">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@it.Icon"/></svg>
                            <span class="flex-1">@it.Label</span>
                        </a>
                    }
                }
            }
        </nav>

        <div class="px-3 py-4 border-t border-neutral-800 space-y-1">
            @if (isFullAdmin)
            {
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 text-xs text-neutral-500 hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/></svg>
                    Website Admin
                </a>
            }
            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex items-center gap-3 px-3 py-2.5 w-full text-xs text-neutral-500 hover:text-white transition-colors text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- ─── Main ─────────────────────────────────────────────────────────── -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="bg-white border-b border-neutral-100 px-8 py-4 flex items-center justify-between flex-shrink-0">
            <h1 class="text-sm font-medium text-neutral-800">@ViewData["Title"]</h1>
            <div class="flex items-center gap-3">
                @if (TempData["Success"] != null) { <span class="text-xs text-emerald-700 bg-emerald-50 px-3 py-1.5 rounded-full">✓ @TempData["Success"]</span> }
                @if (TempData["Error"] != null) { <span class="text-xs text-red-700 bg-red-50 px-3 py-1.5 rounded-full">@TempData["Error"]</span> }
                <span class="text-xs text-neutral-400">@User.Identity?.Name</span>
            </div>
            
        </header>
        <main class="flex-1 overflow-y-auto p-8">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
