@model List<SterlingLams.Web.Models.Domain.PosDiscountReason>
@{
    ViewData["Title"] = "POS Discount Reasons";
}

<div class="mb-5">
    <h1 class="text-lg font-medium text-neutral-800">Discount reasons</h1>
    <p class="text-xs text-neutral-400">Configure the discount reasons and presets shown on the POS.</p>
</div>

<!-- Add Reason -->
<div class="bg-white rounded-xl border border-neutral-200 p-5 mb-6">
    <h2 class="text-sm font-semibold text-neutral-700 mb-3">Add New Reason</h2>
    <form asp-action="CreateReason" method="post" class="flex gap-3">
        @Html.AntiForgeryToken()
        <input type="text" name="name" placeholder="Reason name (e.g. Damaged Product)" required
               class="flex-1 border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
        <button type="submit" class="px-4 py-2 bg-emerald-600 text-white text-sm rounded-lg hover:bg-emerald-700 transition-colors">Add Reason</button>
    </form>
</div>

<!-- Reasons list -->
@if (!Model.Any())
{
    <div class="bg-white rounded-xl border border-neutral-200 p-10 text-center">
        <p class="text-sm text-neutral-400">No discount reasons yet. Add one above.</p>
    </div>
}

@foreach (var reason in Model)
{
    <div class="bg-white rounded-xl border border-neutral-200 mb-4 overflow-hidden">
        <!-- Reason header -->
        <div class="flex items-center gap-3 px-5 py-3 border-b border-neutral-100 bg-neutral-50">
            <div class="flex-1">
                <span class="text-sm font-semibold text-neutral-800">@reason.Name</span>
                @if (!reason.IsActive)
                {
                    <span class="ml-2 text-[10px] bg-neutral-200 text-neutral-500 px-1.5 py-0.5 rounded uppercase tracking-wide">Inactive</span>
                }
            </div>
            <button type="button" onclick="toggleEdit(@reason.Id)"
                    class="text-xs text-neutral-500 hover:text-neutral-700 px-2 py-1 border border-neutral-200 rounded transition-colors">Edit</button>
            <form asp-action="DeleteReason" method="post" class="inline" onsubmit="return confirm('Delete this reason and all its presets?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@reason.Id" />
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 px-2 py-1 border border-red-200 rounded transition-colors">Delete</button>
            </form>
        </div>

        <!-- Inline edit form (hidden by default) -->
        <div id="edit-@reason.Id" class="hidden px-5 py-3 border-b border-neutral-100 bg-amber-50">
            <form asp-action="EditReason" method="post" class="flex gap-3 items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@reason.Id" />
                <input type="text" name="name" value="@reason.Name" required
                       class="flex-1 border border-neutral-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" />
                <label class="flex items-center gap-1.5 text-sm text-neutral-600">
                    <input type="checkbox" name="isActive" value="true" @(reason.IsActive ? "checked" : "") />
                    Active
                </label>
                <button type="submit" class="px-4 py-2 bg-emerald-600 text-white text-sm rounded-lg hover:bg-emerald-700 transition-colors">Save</button>
                <button type="button" onclick="toggleEdit(@reason.Id)" class="px-3 py-2 text-sm text-neutral-500 hover:text-neutral-700">Cancel</button>
            </form>
        </div>

        <!-- Presets -->
        <div class="divide-y divide-neutral-50">
            @if (!reason.Presets.Any())
            {
                <p class="px-5 py-3 text-xs text-neutral-400 italic">No presets yet — cashiers will enter custom values.</p>
            }
            @foreach (var preset in reason.Presets)
            {
                <div class="flex items-center gap-3 px-5 py-2.5">
                    <div class="flex-1">
                        <span class="text-sm text-neutral-700">@preset.Label</span>
                        <span class="ml-2 text-xs text-neutral-400">@preset.Type · @preset.Value@(preset.Type == "Percentage" ? "%" : "₦")</span>
                    </div>
                    <form asp-action="DeletePreset" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@preset.Id" />
                        <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition-colors">Remove</button>
                    </form>
                </div>
            }
        </div>

        <!-- Add preset -->
        <div class="px-5 py-3 bg-neutral-50 border-t border-neutral-100">
            <p class="text-xs font-medium text-neutral-500 mb-2">Add Preset</p>
            <form asp-action="CreatePreset" method="post" class="flex gap-2 flex-wrap">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reasonId" value="@reason.Id" />
                <input type="text" name="label" placeholder="Label (e.g. Discount by 40%)" required
                       class="flex-1 min-w-[160px] border border-neutral-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-emerald-500" />
                <select name="type" class="border border-neutral-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-emerald-500">
                    <option value="Percentage">% Percentage</option>
                    <option value="Amount">₦ Amount</option>
                    <option value="NewPrice">₦ New Price</option>
                </select>
                <input type="number" name="value" min="0.01" step="0.01" placeholder="Value" required
                       class="w-24 border border-neutral-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-emerald-500" />
                <button type="submit" class="px-3 py-1.5 bg-neutral-800 text-white text-sm rounded-lg hover:bg-neutral-700 transition-colors">Add Preset</button>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
function toggleEdit(id) {
    document.getElementById('edit-' + id).classList.toggle('hidden');
}
</script>
}
