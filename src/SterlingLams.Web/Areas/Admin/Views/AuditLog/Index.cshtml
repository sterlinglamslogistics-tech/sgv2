@model SterlingLams.Web.Areas.Admin.ViewModels.AdminAuditLogViewModel
@{
    ViewData["Title"] = "Audit Log";
    bool isFullAdmin = (bool)(ViewData["IsFullAdmin"] ?? false);
    bool hasFilters = !string.IsNullOrEmpty(Model.ActionFilter) || !string.IsNullOrEmpty(Model.EntityFilter)
                   || !string.IsNullOrEmpty(Model.DateFrom)     || !string.IsNullOrEmpty(Model.DateTo)
                   || !string.IsNullOrEmpty(Model.SearchQuery);
    int cols = isFullAdmin ? 7 : 6;
    Dictionary<string, string> rd(int p) => new()
    {
        ["page"] = p.ToString(), ["act"] = Model.ActionFilter, ["entity"] = Model.EntityFilter,
        ["dateFrom"] = Model.DateFrom, ["dateTo"] = Model.DateTo, ["q"] = Model.SearchQuery
    };
}
@Html.AntiForgeryToken()

@if (TempData["Success"] != null) { <div class="mb-4 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm px-4 py-3 rounded-sm">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-sm">@TempData["Error"]</div> }

<!-- Filters + Export -->
<form method="get" class="bg-white rounded-sm border border-neutral-100 p-4 mb-4">
    <div class="flex flex-wrap gap-2 items-center">
        <input type="text" name="q" value="@Model.SearchQuery" placeholder="Search description or user…"
               class="border border-neutral-200 rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-neutral-400 min-w-[200px]" />
        <select name="act" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-neutral-400 bg-white">
            <option value="">All Actions</option>
            @foreach (var a in Model.AvailableActions) { <option value="@a" selected="@(Model.ActionFilter == a)">@a</option> }
        </select>
        <select name="entity" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-neutral-400 bg-white">
            <option value="">All Entities</option>
            @foreach (var e in Model.AvailableEntities) { <option value="@e" selected="@(Model.EntityFilter == e)">@e</option> }
        </select>
        <input type="date" name="dateFrom" value="@Model.DateFrom" title="From date" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-neutral-400" />
        <input type="date" name="dateTo" value="@Model.DateTo" title="To date" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-neutral-400" />
        <button type="submit" class="px-4 py-1.5 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">Filter</button>
        @if (hasFilters)
        {
            <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" class="px-4 py-1.5 border border-neutral-200 text-neutral-500 text-xs rounded-sm hover:border-neutral-400 transition-colors">Clear</a>
        }
        <a asp-area="Admin" asp-controller="AuditLog" asp-action="ExportCsv"
           asp-route-act="@Model.ActionFilter" asp-route-entity="@Model.EntityFilter"
           asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo" asp-route-q="@Model.SearchQuery"
           class="ml-auto px-4 py-1.5 border border-neutral-300 text-neutral-700 text-xs rounded-sm hover:border-neutral-500 transition-colors">↓ Export CSV</a>
    </div>
</form>

@if (isFullAdmin)
{
    <div class="flex items-center gap-2 mb-3">
        <button type="submit" form="audit-delete-form" id="del-selected-btn"
                class="px-3 py-1.5 text-xs border border-red-200 text-red-600 rounded-sm hover:bg-red-50 transition-colors">Delete selected</button>
        <span class="flex-1"></span>
        <form asp-area="Admin" asp-controller="AuditLog" asp-action="ClearAll" method="post"
              onsubmit="return confirm('Delete ALL audit log entries permanently? This cannot be undone.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="px-3 py-1.5 text-xs bg-red-600 text-white rounded-sm hover:bg-red-700 transition-colors">Clear all logs</button>
        </form>
    </div>
}

<form id="audit-delete-form" asp-area="Admin" asp-controller="AuditLog" asp-action="DeleteSelected" method="post"
      onsubmit="return confirm('Delete the selected log entries permanently?');">
    @Html.AntiForgeryToken()
    <input type="hidden" name="act" value="@Model.ActionFilter" />
    <input type="hidden" name="entity" value="@Model.EntityFilter" />
    <input type="hidden" name="dateFrom" value="@Model.DateFrom" />
    <input type="hidden" name="dateTo" value="@Model.DateTo" />
    <input type="hidden" name="q" value="@Model.SearchQuery" />
    <input type="hidden" name="page" value="@Model.CurrentPage" />

    <div class="bg-white rounded-sm border border-neutral-100 overflow-x-auto">
        <table class="w-full text-sm min-w-[800px]">
            <thead>
                <tr class="border-b border-neutral-100 bg-neutral-50">
                    @if (isFullAdmin) { <th class="px-4 py-3 w-8"><input type="checkbox" id="check-all" class="align-middle cursor-pointer" /></th> }
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Time</th>
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Action</th>
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Entity</th>
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Description</th>
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">Performed By</th>
                    <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">IP</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-50">
                @if (!Model.Logs.Any())
                {
                    <tr><td colspan="@cols" class="px-6 py-12 text-center text-xs text-neutral-400">No audit events match your filters.</td></tr>
                }
                @foreach (var log in Model.Logs)
                {
                    var badge = log.Action switch
                    {
                        "Delete" => "bg-red-50 text-red-700",
                        "Create" => "bg-emerald-50 text-emerald-700",
                        "Export" => "bg-violet-50 text-violet-700",
                        "Import" => "bg-amber-50 text-amber-700",
                        "Login"  => "bg-neutral-100 text-neutral-600",
                        _        => "bg-blue-50 text-blue-700"
                    };
                    <tr class="hover:bg-neutral-50 transition-colors">
                        @if (isFullAdmin) { <td class="px-4 py-3"><input type="checkbox" name="ids" value="@log.Id" class="row-check align-middle cursor-pointer" /></td> }
                        <td class="px-6 py-3 text-xs text-neutral-400 whitespace-nowrap">@log.CreatedAt.ToLocalTime().ToString("dd MMM yy HH:mm")</td>
                        <td class="px-6 py-3"><span class="text-[10px] px-2 py-0.5 rounded-full @badge">@log.Action</span></td>
                        <td class="px-6 py-3 text-xs text-neutral-500 whitespace-nowrap">
                            <span>@log.EntityType</span>
                            @if (!string.IsNullOrEmpty(log.EntityId)) { <span class="text-neutral-400"> #@log.EntityId</span> }
                        </td>
                        <td class="px-6 py-3 text-xs text-neutral-600">@log.Description</td>
                        <td class="px-6 py-3 text-xs text-neutral-500 whitespace-nowrap">@log.PerformedBy</td>
                        <td class="px-6 py-3 text-xs text-neutral-400 font-mono whitespace-nowrap">@(string.IsNullOrEmpty(log.IpAddress) ? "—" : log.IpAddress)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@if (Model.TotalPages > 1)
{
    int cur = Model.CurrentPage, tp = Model.TotalPages;
    int start = Math.Max(1, cur - 2), end = Math.Min(tp, cur + 2);
    <div class="flex items-center justify-between gap-2 mt-4">
        <span class="text-xs text-neutral-400">Page @cur of @tp</span>
        <div class="flex items-center gap-1">
            <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" asp-all-route-data="rd(1)"
               class="px-2.5 py-1.5 text-xs rounded-sm border @(cur <= 1 ? "text-neutral-300 border-neutral-100 pointer-events-none" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">« First</a>
            <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" asp-all-route-data="rd(cur - 1)"
               class="px-2.5 py-1.5 text-xs rounded-sm border @(cur <= 1 ? "text-neutral-300 border-neutral-100 pointer-events-none" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">‹</a>
            @for (int p = start; p <= end; p++)
            {
                <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" asp-all-route-data="rd(p)"
                   class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(p == cur ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">@p</a>
            }
            <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" asp-all-route-data="rd(cur + 1)"
               class="px-2.5 py-1.5 text-xs rounded-sm border @(cur >= tp ? "text-neutral-300 border-neutral-100 pointer-events-none" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">›</a>
            <a asp-area="Admin" asp-controller="AuditLog" asp-action="Index" asp-all-route-data="rd(tp)"
               class="px-2.5 py-1.5 text-xs rounded-sm border @(cur >= tp ? "text-neutral-300 border-neutral-100 pointer-events-none" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">Last »</a>
        </div>
    </div>
}

@if (isFullAdmin)
{
    <script>
        (function () {
            var all = document.getElementById('check-all');
            var rows = function () { return Array.prototype.slice.call(document.querySelectorAll('.row-check')); };
            if (all) all.addEventListener('change', function () { rows().forEach(function (r) { r.checked = all.checked; }); });
        })();
    </script>
}
