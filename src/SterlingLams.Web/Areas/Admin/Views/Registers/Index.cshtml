@model List<SterlingLams.Web.Models.Domain.Register>
@{
    ViewData["Title"] = "Tills";
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    var byStore = Model.GroupBy(r => r.Store?.Name ?? "—").OrderBy(g => g.Key);
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-lg font-medium text-neutral-800">Tills / Registers</h1>
        <p class="text-xs text-neutral-400">Each physical till is bound to one of these. Open the till app at <span class="font-mono">/till</span>.</p>
    </div>
    <a asp-area="Admin" asp-controller="Stores" asp-action="Index" class="text-xs text-neutral-400 hover:text-neutral-700">← Branches</a>
</div>

@if (TempData["Success"] != null) { <div class="mb-4 text-sm text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-sm px-4 py-2">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="mb-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-sm px-4 py-2">@TempData["Error"]</div> }

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Add a till -->
    <div class="bg-white border border-neutral-100 rounded-sm p-5 h-fit">
        <h2 class="text-sm font-medium text-neutral-800 mb-3">Add a till</h2>
        <form asp-area="Admin" asp-controller="Registers" asp-action="Create" method="post" class="space-y-3">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Till name</label>
                <input name="name" required placeholder="e.g. Counter 2"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>
            <div>
                <label class="block text-xs text-neutral-500 mb-1">Branch</label>
                <select name="storeId" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                    <option value="">— Select branch —</option>
                    @foreach (var s in stores) { <option value="@s.Id">@s.Name</option> }
                </select>
            </div>
            <button type="submit" class="w-full bg-neutral-900 text-white text-sm rounded-sm py-2.5 hover:bg-neutral-700 transition-colors">Add Till</button>
        </form>
    </div>

    <!-- List -->
    <div class="lg:col-span-2 space-y-5">
        @foreach (var grp in byStore)
        {
            <div class="bg-white border border-neutral-100 rounded-sm overflow-hidden">
                <div class="px-4 py-2.5 bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">@grp.Key</div>
                <div class="divide-y divide-neutral-100">
                    @foreach (var r in grp)
                    {
                        <div class="flex items-center justify-between px-4 py-3">
                            <div>
                                <p class="text-sm text-neutral-800">@r.Name</p>
                                <span class="text-[10px] @(r.IsActive ? "text-emerald-600" : "text-neutral-400")">@(r.IsActive ? "Active" : "Disabled")</span>
                            </div>
                            <form asp-area="Admin" asp-controller="Registers" asp-action="ToggleActive" asp-route-id="@r.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">@(r.IsActive ? "Disable" : "Enable")</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <p class="text-sm text-neutral-400">No tills yet. Add one on the left.</p>
        }
    </div>
</div>
