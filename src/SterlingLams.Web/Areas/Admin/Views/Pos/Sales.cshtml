@model List<SterlingLams.Web.Models.Domain.Order>
@{
    ViewData["Title"] = "POS Sales";
    var total = Model.Sum(o => o.Total);
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-lg font-medium text-neutral-800">POS Sales</h1>
        <p class="text-xs text-neutral-400">@Model.Count sale(s) · ₦@total.ToString("N0") total</p>
    </div>
    <a asp-area="Admin" asp-controller="Pos" asp-action="Index"
       class="px-4 py-2 bg-brand-500 text-white text-sm rounded-sm hover:bg-brand-600 transition-colors">+ New Sale</a>
</div>

<div class="bg-white border border-neutral-100 rounded-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-neutral-50 text-neutral-500 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left font-medium px-4 py-3">Receipt</th>
                <th class="text-left font-medium px-4 py-3">Date</th>
                <th class="text-left font-medium px-4 py-3">Branch</th>
                <th class="text-left font-medium px-4 py-3">Items</th>
                <th class="text-left font-medium px-4 py-3">Payment</th>
                <th class="text-right font-medium px-4 py-3">Total</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="px-4 py-10 text-center text-neutral-400 text-sm">No POS sales yet.</td></tr>
            }
            @foreach (var o in Model)
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-3 font-mono text-xs text-neutral-700">@o.OrderNumber</td>
                    <td class="px-4 py-3 text-neutral-600">@o.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")</td>
                    <td class="px-4 py-3 text-neutral-600">@(o.PickupStore?.Name ?? "—")</td>
                    <td class="px-4 py-3 text-neutral-600">@o.Items.Sum(i => i.Quantity)</td>
                    <td class="px-4 py-3 text-neutral-600">@o.PaymentProvider</td>
                    <td class="px-4 py-3 text-right text-neutral-800">₦@o.Total.ToString("N0")</td>
                    <td class="px-4 py-3 text-right">
                        <a asp-area="Admin" asp-controller="Pos" asp-action="Receipt" asp-route-id="@o.Id" target="_blank"
                           class="text-xs text-neutral-500 hover:text-brand-500 transition-colors">Receipt</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
