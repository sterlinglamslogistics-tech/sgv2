@model IEnumerable<SterlingLams.Web.Models.Domain.Store>
@{
    ViewData["Title"] = "Stores";
}

<!-- Toolbar -->
<div class="flex items-center justify-between mb-6">
    <p class="text-xs text-neutral-400">
        @Model.Count() store@(Model.Count() == 1 ? "" : "s") · @Model.Count(s => s.IsActive) active
    </p>
    <a asp-area="Admin" asp-controller="Stores" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        + New Store
    </a>
</div>

@if (!Model.Any())
{
    <div class="bg-white rounded-sm border border-neutral-100 p-16 text-center">
        <p class="text-neutral-400 text-sm mb-4">No stores yet.</p>
        <a asp-area="Admin" asp-controller="Stores" asp-action="Create"
           class="inline-block px-6 py-2.5 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
            Create your first store
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var store in Model)
        {
            var stockCount = store.Inventories?.Sum(i => i.QuantityOnHand) ?? 0;

            <div class="bg-white rounded-sm border border-neutral-100 p-6 flex flex-col">
                <!-- Header -->
                <div class="flex items-start justify-between mb-4">
                    <div class="min-w-0 flex-1">
                        <h2 class="text-sm font-medium text-neutral-800 truncate">@store.Name</h2>
                        <p class="text-xs text-neutral-400 mt-0.5">@store.City, @store.State</p>
                    </div>
                    @if (store.IsActive)
                    {
                        <span class="ml-2 text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full flex-shrink-0">Active</span>
                    }
                    else
                    {
                        <span class="ml-2 text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full flex-shrink-0">Inactive</span>
                    }
                </div>

                <!-- Details -->
                <div class="text-xs text-neutral-500 space-y-1.5 flex-1 mb-4">
                    <p class="flex items-start gap-1.5">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        </svg>
                        @store.Address
                    </p>
                    @if (!string.IsNullOrEmpty(store.Phone))
                    {
                        <p class="flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                            @store.Phone
                        </p>
                    }
                    @if (!string.IsNullOrEmpty(store.OpeningHours))
                    {
                        <p class="flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            @store.OpeningHours
                        </p>
                    }
                    @if (store.Latitude.HasValue)
                    {
                        <p class="text-neutral-300 text-[10px]">
                            GPS: @store.Latitude?.ToString("F4"), @store.Longitude?.ToString("F4")
                        </p>
                    }
                </div>

                <!-- Action buttons -->
                <div class="flex items-center gap-2 border-t border-neutral-50 pt-4 mt-auto">
                    <a asp-area="Admin" asp-controller="Stores" asp-action="Edit" asp-route-id="@store.Id"
                       class="px-3 py-1.5 text-xs border border-neutral-200 text-neutral-600 rounded-sm hover:bg-neutral-50 transition-colors">
                        Edit
                    </a>
                    <form asp-area="Admin" asp-controller="Stores" asp-action="ToggleActive"
                          asp-route-id="@store.Id" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" data-no-loading="1"
                                class="px-3 py-1.5 text-xs border border-neutral-200 text-neutral-500 rounded-sm hover:bg-neutral-50 transition-colors">
                            @(store.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                    @if (store.Latitude.HasValue && store.Longitude.HasValue)
                    {
                        <a href="https://maps.google.com/?q=@store.Latitude,@store.Longitude"
                           target="_blank" rel="noopener"
                           class="px-3 py-1.5 text-xs border border-neutral-200 text-neutral-500 rounded-sm hover:bg-neutral-50 transition-colors">
                            Map
                        </a>
                    }
                    <form asp-area="Admin" asp-controller="Stores" asp-action="Delete"
                          asp-route-id="@store.Id" method="post" class="inline ml-auto"
                          data-itemname="@store.Name"
                          onsubmit="return confirm('Delete ' + this.dataset.itemname + '? This cannot be undone.')">
                        @Html.AntiForgeryToken()
                        <button type="submit" data-no-loading="1"
                                class="px-3 py-1.5 text-xs text-rose-400 hover:text-rose-700 transition-colors">
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
