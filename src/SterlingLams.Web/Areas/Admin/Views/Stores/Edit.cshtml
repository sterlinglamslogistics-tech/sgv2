@model SterlingLams.Web.Areas.Admin.ViewModels.AdminStoreEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "New Store" : "Edit Store";
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="Stores" asp-action="Index"
           class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Stores</a>
        <span class="text-neutral-200">/</span>
        <span class="text-xs text-neutral-600">@(isNew ? "New Store" : Model.Name)</span>
    </div>
    @if (!isNew)
    {
        <form asp-area="Admin" asp-controller="Stores" asp-action="Delete"
              asp-route-id="@Model.Id" method="post"
              data-itemname="@Model.Name"
              onsubmit="return confirm('Delete ' + this.dataset.itemname + ', are you sure? This cannot be undone.')">
            @Html.AntiForgeryToken()
            <button type="submit" data-no-loading="1"
                    class="text-xs text-rose-400 hover:text-rose-700 transition-colors">
                Delete Store
            </button>
        </form>
    }
</div>

<div class="max-w-2xl">
    <form asp-area="Admin" asp-controller="Stores" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">

            <!-- Name + Slug -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Store Name <span class="text-red-400">*</span></label>
                    <input asp-for="Name" required placeholder="e.g. Sterlin Glams Lekki"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    <span asp-validation-for="Name" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="Slug" class="block text-xs text-neutral-500 mb-1">Slug <span class="text-neutral-300">(auto if blank)</span></label>
                    <input asp-for="Slug" placeholder="sterlin-glams-lekki"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <!-- Address -->
            <div>
                <label asp-for="Address" class="block text-xs text-neutral-500 mb-1">Street Address <span class="text-red-400">*</span></label>
                <input asp-for="Address" required placeholder="e.g. 12 Admiralty Way, Lekki Phase 1"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                <span asp-validation-for="Address" class="text-xs text-red-500"></span>
            </div>

            <!-- City + State -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="City" class="block text-xs text-neutral-500 mb-1">City <span class="text-red-400">*</span></label>
                    <input asp-for="City" required placeholder="e.g. Lekki"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    <span asp-validation-for="City" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="State" class="block text-xs text-neutral-500 mb-1">State <span class="text-red-400">*</span></label>
                    <input asp-for="State" required placeholder="e.g. Lagos"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    <span asp-validation-for="State" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- Phone + Email -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Phone" class="block text-xs text-neutral-500 mb-1">Phone</label>
                    <input asp-for="Phone" type="tel" placeholder="+234 800 000 0000"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="Email" class="block text-xs text-neutral-500 mb-1">Email</label>
                    <input asp-for="Email" type="email" placeholder="lekki@sterlinglams.com"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <!-- Opening Hours -->
            <div>
                <label asp-for="OpeningHours" class="block text-xs text-neutral-500 mb-1">Opening Hours</label>
                <input asp-for="OpeningHours" placeholder="e.g. Mon–Sat: 9am–7pm, Sun: 12pm–6pm"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- GPS Coordinates -->
            <div>
                <label class="block text-xs text-neutral-500 mb-1">
                    GPS Coordinates
                    <span class="text-neutral-300">(enables "Get Directions" button on the storefront)</span>
                </label>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <input asp-for="Latitude" type="number" step="0.0001" placeholder="Latitude e.g. 6.4281"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                        <label class="text-[10px] text-neutral-400 mt-0.5 block">Latitude</label>
                    </div>
                    <div>
                        <input asp-for="Longitude" type="number" step="0.0001" placeholder="Longitude e.g. 3.4219"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                        <label class="text-[10px] text-neutral-400 mt-0.5 block">Longitude</label>
                    </div>
                </div>
                <p class="text-[11px] text-neutral-400 mt-1">
                    Find coordinates at
                    <a href="https://maps.google.com" target="_blank" class="underline hover:text-neutral-700">maps.google.com</a>
                    — right-click any location and copy the coordinates shown.
                </p>
            </div>

            <!-- Active -->
            <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                <input asp-for="IsActive" type="checkbox" class="rounded accent-neutral-900" />
                Store is active <span class="text-neutral-400 text-xs font-light">(inactive stores are hidden from customers and checkout)</span>
            </label>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Store" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Stores" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>
