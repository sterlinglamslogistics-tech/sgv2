@model SterlingLams.Web.Areas.Admin.ViewModels.AdminProductEditViewModel
@{
    var isNew = Model.Id == 0;
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="Products" asp-action="Index"
           class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Products</a>
        <span class="text-neutral-200">/</span>
        <span class="text-xs text-neutral-600">@(isNew ? "New Product" : Model.Name)</span>
    </div>
    @if (!isNew && !string.IsNullOrEmpty(Model.Slug))
    {
        <a href="/Products/@Model.Slug" target="_blank"
           class="flex items-center gap-1.5 text-xs text-neutral-400 hover:text-neutral-900 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View on site
        </a>
    }
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 max-w-6xl">
    <div class="xl:col-span-2 min-w-0">
    <form asp-area="Admin" asp-controller="Products" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">

            <div asp-validation-summary="ModelOnly" class="text-xs text-red-500"></div>

            <!-- Product Type -->
            <div>
                <label class="block text-xs text-neutral-500 mb-1.5">Product Type</label>
                <div class="flex gap-3">
                    <label class="flex-1 cursor-pointer">
                        <input type="radio" asp-for="ProductType" value="simple" class="peer sr-only" />
                        <div class="border border-neutral-200 rounded-sm px-4 py-3 peer-checked:border-brand-500 peer-checked:bg-brand-50 transition-colors">
                            <span class="text-sm font-medium text-neutral-800">Simple product</span>
                            <span class="block text-xs text-neutral-400 mt-0.5">One item, single price &amp; SKU.</span>
                        </div>
                    </label>
                    <label class="flex-1 cursor-pointer">
                        <input type="radio" asp-for="ProductType" value="variable" class="peer sr-only" />
                        <div class="border border-neutral-200 rounded-sm px-4 py-3 peer-checked:border-brand-500 peer-checked:bg-brand-50 transition-colors">
                            <span class="text-sm font-medium text-neutral-800">Variable product</span>
                            <span class="block text-xs text-neutral-400 mt-0.5">Has options/variants (e.g. colour).</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Name -->
            <div>
                <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Name <span class="text-red-400">*</span></label>
                <input asp-for="Name" required class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                <span asp-validation-for="Name" class="text-xs text-red-500"></span>
            </div>

            <!-- Slug -->
            <div>
                <label asp-for="Slug" class="block text-xs text-neutral-500 mb-1">Slug (auto-generated if blank)</label>
                <input asp-for="Slug" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- Price + Category -->
            <div class="grid grid-cols-2 gap-4">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label asp-for="Price" class="block text-xs text-neutral-500 mb-1">Price (₦) <span class="text-red-400">*</span></label>
                        <input asp-for="Price" type="number" step="0.01" min="0"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                        <span asp-validation-for="Price" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="SalePrice" class="block text-xs text-neutral-500 mb-1">Sale price (₦)</label>
                        <input asp-for="SalePrice" type="number" step="0.01" min="0" placeholder="optional"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                        <span class="text-[10px] text-neutral-400">Below Price → shows the old price struck through.</span>
                    </div>
                    <div>
                        <label asp-for="CostPrice" class="block text-xs text-neutral-500 mb-1">Cost price (₦)</label>
                        <input asp-for="CostPrice" type="number" step="0.01" min="0" placeholder="optional"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                        <span class="text-[10px] text-neutral-400">What the item costs you — powers profit &amp; margin reports.</span>
                    </div>
                    <div>
                        <label asp-for="SaleStartsAt" class="block text-xs text-neutral-500 mb-1">Sale starts (optional)</label>
                        <input asp-for="SaleStartsAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                        <span class="text-[10px] text-neutral-400">Blank = live now. Times are UTC.</span>
                    </div>
                    <div>
                        <label asp-for="SaleEndsAt" class="block text-xs text-neutral-500 mb-1">Sale ends (optional)</label>
                        <input asp-for="SaleEndsAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                        <span class="text-[10px] text-neutral-400">Blank = until cleared. Times are UTC.</span>
                    </div>
                </div>
                <div>
                    <label asp-for="CategoryId" class="block text-xs text-neutral-500 mb-1">Category <span class="text-red-400">*</span></label>
                    <select asp-for="CategoryId" required
                            asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                            class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                        <option value="">— Select —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-xs text-red-500"></span>
                </div>
            </div>

            <!-- Short Description -->
            <div>
                <label asp-for="ShortDescription" class="block text-xs text-neutral-500 mb-1">Short Description <span class="text-neutral-300">(shown on product page)</span></label>
                <input asp-for="ShortDescription" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- Description -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="Description" class="block text-xs text-neutral-500">Full Description</label>
                    <button type="button" id="gen-seo-desc"
                            data-url="@Url.Action("GenerateDescription")"
                            class="text-xs px-2.5 py-1 rounded-sm border border-neutral-300 text-neutral-600 hover:bg-neutral-900 hover:text-white hover:border-neutral-900 transition-colors">
                        ✨ Generate SEO description
                    </button>
                </div>
                <partial name="_RichTextEditor" model='new SterlingLams.Web.Models.ViewModels.RichTextEditorVm(nameof(Model.Description), "product-description-editor", Model.Description)' />
                <p id="gen-seo-msg" class="text-xs text-neutral-400 mt-1 hidden"></p>
            </div>
            <script>
                (function () {
                    var btn = document.getElementById('gen-seo-desc');
                    if (!btn) return;
                    var msg = document.getElementById('gen-seo-msg');
                    function show(text, isErr) {
                        if (!msg) return;
                        msg.textContent = text;
                        msg.classList.remove('hidden');
                        msg.classList.toggle('text-red-500', !!isErr);
                        msg.classList.toggle('text-neutral-400', !isErr);
                    }
                    btn.addEventListener('click', async function () {
                        var name = (document.getElementById('Name') || {}).value || '';
                        var categoryId = (document.getElementById('CategoryId') || {}).value || '';
                        name = name.trim();
                        if (!name) { show('Enter a product name first.', true); return; }
                        if (!categoryId) { show('Choose a category first.', true); return; }

                        var wrap = document.querySelector('[data-editor="product-description-editor"]');
                        var editor = wrap && wrap.querySelector('.rte-editor');
                        var ta = wrap && wrap.querySelector('textarea');
                        if (editor && editor.textContent.trim() &&
                            !confirm('Replace the current description with a freshly generated one? You can still edit it afterwards.')) return;

                        btn.disabled = true;
                        var original = btn.textContent;
                        btn.textContent = 'Generating…';
                        try {
                            var url = btn.dataset.url + '?id=@Model.Id&categoryId=' + encodeURIComponent(categoryId) +
                                      '&name=' + encodeURIComponent(name);
                            var res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                            var data = await res.json();
                            if (!data.ok) { show(data.error || 'Could not generate a description.', true); return; }
                            if (editor) editor.innerHTML = data.html;
                            if (ta) ta.value = data.html;
                            var shortInput = document.getElementById('ShortDescription');
                            if (shortInput && !shortInput.value.trim()) shortInput.value = data.shortText;
                            show('Generated for “' + data.kind + '”. Edit as needed, then Save.', false);
                        } catch (e) {
                            show('Could not generate a description. Please try again.', true);
                        } finally {
                            btn.disabled = false;
                            btn.textContent = original;
                        }
                    });
                })();
            </script>

            <!-- SKU + External Code -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Sku" class="block text-xs text-neutral-500 mb-1">SKU</label>
                    <input asp-for="Sku" type="text"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="ExternalCode" class="block text-xs text-neutral-500 mb-1">External / Import Code <span class="text-neutral-300">(optional)</span></label>
                    <input asp-for="ExternalCode" type="text"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <!-- Flags -->
            <div class="flex gap-6">
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="rounded" />
                    Active
                </label>
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsFeatured" type="checkbox" class="rounded" />
                    Featured
                </label>
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsNewArrival" type="checkbox" class="rounded" />
                    New Arrival
                </label>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Product" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>

    @if (!isNew)
    {
        <!-- ── Variants Tab (only for variable products) ──────────────────────── -->
        <div id="variants-section" class="mt-6 bg-white rounded-sm border border-neutral-100 p-6 @(Model.ProductType == "variable" ? "" : "hidden")">
            <h2 class="text-sm font-medium mb-1">Variants</h2>
            <p class="text-xs text-neutral-400 mb-5">Select attribute values that apply to this product, then click Generate to create all combinations.</p>

            @if (!Model.AllAttributes.Any())
            {
                <p class="text-xs text-neutral-400">
                    No attributes defined yet.
                    <a asp-area="Admin" asp-controller="Attributes" asp-action="Index"
                       class="underline hover:text-neutral-700">Go to Attributes</a> to create Colour, Alphabet, Length, etc.
                </p>
            }
            else
            {
                <!-- Attribute selector — accordion with search per attribute -->
                <form asp-area="Admin" asp-controller="Products" asp-action="GenerateVariants"
                      asp-route-id="@Model.Id" method="post" class="mb-6">
                    @Html.AntiForgeryToken()

                    <div class="space-y-2 mb-5">
                        @foreach (var attr in Model.AllAttributes)
                        {
                            // AttributeLabels is List<string> of plain value names — find which of this
                            // attribute's values appear in any existing variant's labels
                            var attrValueNames = attr.Values.Select(av => av.Value).ToHashSet();
                            var allLabels      = Model.Variants.SelectMany(v => v.AttributeLabels).ToHashSet();
                            var selectedVals   = attrValueNames.Intersect(allLabels).ToHashSet();
                            var selectedCount  = selectedVals.Count;
                            var slug = attr.Slug;

                            <div class="border border-neutral-200 rounded-sm overflow-hidden">
                                <!-- Accordion header -->
                                <button type="button"
                                        onclick="toggleAttrPanel('@slug')"
                                        class="w-full flex items-center justify-between px-4 py-3 hover:bg-neutral-50 transition-colors text-left">
                                    <span class="text-sm font-medium text-neutral-800">@attr.Name</span>
                                    <div class="flex items-center gap-3">
                                        <span id="count-@slug"
                                              class="text-xs @(selectedCount > 0 ? "bg-neutral-900 text-white px-2 py-0.5 rounded-full" : "text-neutral-400")">
                                            @(selectedCount > 0 ? $"{selectedCount} selected" : "None selected")
                                        </span>
                                        <svg id="arrow-@slug" class="w-4 h-4 text-neutral-400 transition-transform duration-200"
                                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </div>
                                </button>

                                <!-- Accordion panel -->
                                <div id="panel-@slug" class="hidden border-t border-neutral-100 p-4">
                                    <!-- Search box -->
                                    <input type="text"
                                           placeholder="Search @attr.Name…"
                                           oninput="filterAttr('@slug', this.value)"
                                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-xs mb-3 focus:outline-none focus:border-neutral-400" />

                                    <!-- Quick actions -->
                                    <div class="flex gap-3 mb-3">
                                        <button type="button" onclick="selectAllAttr('@slug', true)"
                                                class="text-[10px] text-neutral-500 hover:text-neutral-900 underline underline-offset-2">Select all</button>
                                        <button type="button" onclick="selectAllAttr('@slug', false)"
                                                class="text-[10px] text-neutral-500 hover:text-neutral-900 underline underline-offset-2">Clear</button>
                                    </div>

                                    <!-- Scrollable checkbox list -->
                                    <div class="max-h-52 overflow-y-auto space-y-0.5" id="list-@slug">
                                        @foreach (var val in attr.Values.OrderBy(v => v.SortOrder))
                                        {
                                            var chk = selectedVals.Contains(val.Value);
                                            <label class="attr-item-@slug flex items-center gap-2.5 px-2 py-1.5 rounded hover:bg-neutral-50 cursor-pointer"
                                                   data-label="@val.Value.ToLower()">
                                                <input type="checkbox"
                                                       name="selectedValueIds"
                                                       value="@val.Id"
                                                       @(chk ? "checked" : "")
                                                       onchange="updateAttrCount('@slug')"
                                                       class="rounded border-neutral-300 accent-neutral-900 flex-shrink-0" />
                                                @if (!string.IsNullOrEmpty(val.ColorHex))
                                                {
                                                    <span class="w-4 h-4 rounded-full border border-neutral-200 flex-shrink-0 inline-block"
                                                          style="background-color:@val.ColorHex"></span>
                                                }
                                                <span class="text-sm text-neutral-700">@val.Value</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="submit"
                            class="px-6 py-2.5 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                        ↺ Generate Variants from Selected Options
                    </button>
                </form>

                @section Scripts {
                <script>
                function toggleAttrPanel(slug) {
                    const panel = document.getElementById('panel-' + slug);
                    const arrow = document.getElementById('arrow-' + slug);
                    const isOpen = !panel.classList.contains('hidden');
                    panel.classList.toggle('hidden', isOpen);
                    arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
                }

                function filterAttr(slug, query) {
                    const q = query.toLowerCase();
                    document.querySelectorAll('.attr-item-' + slug).forEach(item => {
                        item.style.display = item.dataset.label.includes(q) ? '' : 'none';
                    });
                }

                function selectAllAttr(slug, check) {
                    document.querySelectorAll('.attr-item-' + slug + ' input[type=checkbox]').forEach(cb => {
                        cb.checked = check;
                    });
                    updateAttrCount(slug);
                }

                function updateAttrCount(slug) {
                    const total = document.querySelectorAll('.attr-item-' + slug + ' input[type=checkbox]:checked').length;
                    const el = document.getElementById('count-' + slug);
                    el.textContent = total > 0 ? total + ' selected' : 'None selected';
                    el.className = total > 0
                        ? 'text-xs bg-neutral-900 text-white px-2 py-0.5 rounded-full'
                        : 'text-xs text-neutral-400';
                }

                // Panels start closed — user opens what they need
                </script>
                <script>
                // Keep your place: the variant/image section buttons save via a server redirect that
                // reloads this page at the top. Remember the scroll position on submit and restore it
                // on the reload so you don't have to scroll back down. (Validation-error reloads of the
                // main form keep your place too. Fresh-only, so a stale position is never reapplied.)
                (function () {
                    var KEY = 'pedit-scroll-@Model.Id';
                    document.addEventListener('submit', function () {
                        try { sessionStorage.setItem(KEY, JSON.stringify({ y: window.scrollY, t: Date.now() })); } catch (e) {}
                    }, true);
                    try {
                        var raw = sessionStorage.getItem(KEY);
                        if (raw) {
                            sessionStorage.removeItem(KEY);
                            var s = JSON.parse(raw);
                            if (s && s.y > 0 && (Date.now() - s.t) < 10000) {
                                var restore = function () { window.scrollTo(0, s.y); };
                                restore();                                // best-effort before paint
                                window.addEventListener('load', restore); // again once images/layout settle
                            }
                        }
                    } catch (e) {}
                }());
                </script>
                }

                <!-- Existing variants table -->
                @if (Model.Variants.Any())
                {
                    <div class="flex items-center gap-4 mb-4 p-3 bg-neutral-50 rounded-sm text-xs text-neutral-600">
                        <span><strong class="text-neutral-800">@Model.Variants.Count</strong> variant@(Model.Variants.Count == 1 ? "" : "s")</span>
                        <span class="text-neutral-400">@Model.Variants.Count(v => v.IsActive) active · @Model.Variants.Count(v => !v.IsActive) inactive</span>
                        <span class="text-neutral-300 text-[10px]">Stock is managed per-store from the Inventory page →</span>
                    </div>

                    @* Single form — saves ALL variants at once *@
                    <form asp-area="Admin" asp-controller="Products" asp-action="SaveAllVariants"
                          asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <table class="w-full text-sm border-t border-neutral-100 mb-4">
                            <thead>
                                <tr class="text-left text-xs text-neutral-400 border-b border-neutral-100">
                                    <th class="py-2 pr-4">Option</th>
                                    <th class="py-2 pr-4">SKU</th>
                                    <th class="py-2 pr-4">Image <span class="font-normal text-[10px] text-neutral-300">shown when selected</span></th>
                                    <th class="py-2 pr-4">Price Adj (₦) <span class="font-normal text-[10px] text-neutral-300">e.g. +500 or -200</span></th>
                                    <th class="py-2 pr-4 text-center">Active</th>
                                    <th class="py-2 text-right">Delete</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-neutral-50">
                                @foreach (var v in Model.Variants)
                                {
                                    <tr>
                                        <td class="py-2.5 pr-4 text-sm text-neutral-800 font-medium">@v.Name</td>
                                        <td class="py-2.5 pr-4">
                                            <input name="sku_@v.Id" value="@v.Sku" placeholder="SKU"
                                                   class="w-28 border border-neutral-200 rounded-sm px-2 py-1.5 text-xs focus:outline-none focus:border-neutral-400" />
                                        </td>
                                        <td class="py-2.5 pr-4">
                                            <div class="flex items-center gap-2">
                                                <img src="@v.ImageUrl" alt="" id="vimg-prev-@v.Id"
                                                     class="w-9 h-9 object-cover rounded border border-neutral-200 @(string.IsNullOrEmpty(v.ImageUrl) ? "hidden" : "")" />
                                                <input name="img_@v.Id" id="vimg-@v.Id" value="@v.ImageUrl" placeholder="/uploads/… or https://…"
                                                       class="w-40 border border-neutral-200 rounded-sm px-2 py-1.5 text-xs focus:outline-none focus:border-neutral-400" />
                                                <label class="cursor-pointer text-xs text-neutral-500 hover:text-neutral-800 underline whitespace-nowrap">
                                                    Upload
                                                    <input type="file" accept="image/*" class="hidden vimg-file" data-vid="@v.Id" />
                                                </label>
                                            </div>
                                        </td>
                                        <td class="py-2.5 pr-4">
                                            <input name="adj_@v.Id" type="number" step="0.01"
                                                   value="@v.PriceAdjustment" placeholder="0"
                                                   class="w-28 border border-neutral-200 rounded-sm px-2 py-1.5 text-xs focus:outline-none focus:border-neutral-400" />
                                        </td>
                                        <td class="py-2.5 pr-4 text-center">
                                            @* Checkbox trick: hidden=false sends 'false' when unchecked *@
                                            <input type="hidden" name="active_@v.Id" value="false" />
                                            <input type="checkbox" name="active_@v.Id" value="true"
                                                   @(v.IsActive ? "checked" : "")
                                                   class="w-4 h-4 rounded accent-neutral-900" />
                                        </td>
                                        <td class="py-2.5 text-right">
                                            @* Delete form separate — outside the save form *@
                                            <button type="button"
                                                    onclick="if(confirm('Delete @v.Name?')) document.getElementById('del-@v.Id').submit()"
                                                    class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <button type="submit"
                                class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                            Save All Variants
                        </button>
                    </form>

                    @* Delete forms live outside the save form *@
                    @foreach (var v in Model.Variants)
                    {
                        <form id="del-@v.Id"
                              asp-area="Admin" asp-controller="Products" asp-action="DeleteVariant"
                              method="post" style="display:none">
                            @Html.AntiForgeryToken()
                            <input name="productId" value="@Model.Id" />
                            <input name="variantId" value="@v.Id" />
                        </form>
                    }
                }
                else
                {
                    <p class="text-xs text-neutral-400 mt-2">No variants yet. Open an attribute above, select the options that apply, then click Generate.</p>
                }
            }
        </div>

        <!-- Images -->
        <div class="mt-6 bg-white rounded-sm border border-neutral-100 p-6">
            <h2 class="text-sm font-medium mb-4">Product Images</h2>

            @if (Model.Images.Any())
            {
                <p class="text-xs text-neutral-400 mb-3">The <span class="text-neutral-600 font-medium">primary</span> image shows on cards &amp; the product page. The <span class="text-emerald-600 font-medium">hover</span> image is revealed when a shopper hovers a card (Tiffany-style swap).</p>
                <div class="flex flex-wrap gap-3 mb-5">
                    @foreach (var img in Model.Images)
                    {
                        <div class="relative group w-24">
                            <img src="@img.Url" alt="@img.AltText"
                                 class="w-24 h-24 object-cover rounded border @(img.IsPrimary ? "border-neutral-900 ring-1 ring-neutral-900" : img.IsHover ? "border-emerald-500 ring-1 ring-emerald-500" : "border-neutral-200")" />
                            @if (img.IsPrimary)
                            {
                                <span class="absolute bottom-1 left-1 text-[9px] bg-neutral-900 text-white px-1 rounded">Primary</span>
                            }
                            else if (img.IsHover)
                            {
                                <span class="absolute bottom-1 left-1 text-[9px] bg-emerald-600 text-white px-1 rounded">Hover</span>
                            }
                            <form asp-area="Admin" asp-controller="Products" asp-action="DeleteImage"
                                  asp-route-productId="@Model.Id" asp-route-imageId="@img.Id"
                                  method="post" class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="bg-red-500 text-white text-[10px] rounded w-5 h-5 flex items-center justify-center">×</button>
                            </form>
                            <div class="mt-1.5 flex flex-col gap-1">
                                @if (!img.IsPrimary)
                                {
                                    <form asp-area="Admin" asp-controller="Products" asp-action="SetPrimaryImage"
                                          asp-route-productId="@Model.Id" asp-route-imageId="@img.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-full text-[10px] py-1 rounded border border-neutral-200 text-neutral-600 hover:border-neutral-900 hover:text-neutral-900 transition-colors">Make primary</button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="Products" asp-action="SetHoverImage"
                                          asp-route-productId="@Model.Id" asp-route-imageId="@img.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-full text-[10px] py-1 rounded border @(img.IsHover ? "border-emerald-500 text-emerald-600 hover:border-emerald-600" : "border-neutral-200 text-neutral-600 hover:border-emerald-500 hover:text-emerald-600") transition-colors">@(img.IsHover ? "Hover ✓ (clear)" : "Set hover")</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <form asp-area="Admin" asp-controller="Products" asp-action="AddImage"
                  asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="space-y-3">
                @Html.AntiForgeryToken()
                <div class="flex gap-4 items-start">
                    <!-- Upload from computer -->
                    <div class="flex-1">
                        <label class="block text-xs text-neutral-500 mb-1">Upload from computer</label>
                        <label class="flex items-center gap-2 cursor-pointer border border-neutral-200 rounded-sm px-3 py-2 text-sm text-neutral-500 hover:border-neutral-400 transition-colors w-full">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span id="prod-file-label">Choose image…</span>
                            <input id="prod-file-input" type="file" name="imageFile" accept="image/*" class="hidden"
                                   onchange="document.getElementById('prod-file-label').textContent = this.files[0]?.name ?? 'Choose image…'" />
                        </label>
                    </div>
                    <div class="flex items-center text-xs text-neutral-400 mt-6">or</div>
                    <!-- URL fallback -->
                    <div class="flex-1">
                        <label class="block text-xs text-neutral-500 mb-1">Image URL</label>
                        <input name="imageUrl" type="url" placeholder="https://…"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    </div>
                </div>
                <div class="flex gap-4 items-end">
                    <div class="flex-1">
                        <label class="block text-xs text-neutral-500 mb-1">Alt Text</label>
                        <input name="altText" type="text"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    </div>
                    <label class="flex items-center gap-2 text-xs text-neutral-600 pb-2 cursor-pointer">
                        <input name="isPrimary" type="checkbox" class="accent-neutral-900" />
                        Set as primary
                    </label>
                    <button type="submit"
                            class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors pb-2">
                        Add Image
                    </button>
                </div>
            </form>
        </div>
    }
    else
    {
        <!-- New product: images & variants become available after the first save -->
        <div class="mt-6 bg-white rounded-sm border border-dashed border-neutral-200 p-6 text-center">
            <svg class="w-8 h-8 mx-auto text-neutral-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-sm text-neutral-600">Save the product first to upload images from your computer and add variants.</p>
            <p class="text-xs text-neutral-400 mt-1">Click “Save Product” above — you'll return here with image upload enabled.</p>
        </div>
    }

    <script>
        (function () {
            var section = document.getElementById('variants-section');
            document.querySelectorAll('input[name="ProductType"]').forEach(function (r) {
                r.addEventListener('change', function () {
                    if (section) section.classList.toggle('hidden', this.value !== 'variable');
                });
            });

            // Per-variant image upload → fills the URL input + preview (saved with "Save All Variants")
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            document.querySelectorAll('.vimg-file').forEach(function (input) {
                input.addEventListener('change', async function () {
                    var file = input.files[0];
                    if (!file) return;
                    var vid = input.dataset.vid;
                    var label = input.closest('label');
                    var prev = label ? label.textContent : '';
                    if (label) label.firstChild && (label.childNodes[0].nodeValue = 'Uploading…');
                    var fd = new FormData();
                    fd.append('file', file);
                    fd.append('subfolder', 'products');
                    fd.append('__RequestVerificationToken', token);
                    try {
                        var res = await fetch(__adminBase + '/Upload/Image', { method: 'POST', body: fd });
                        var data = await res.json();
                        if (res.ok && data.url) {
                            var urlInput = document.getElementById('vimg-' + vid);
                            var img = document.getElementById('vimg-prev-' + vid);
                            if (urlInput) urlInput.value = data.url;
                            if (img) { img.src = data.url; img.classList.remove('hidden'); }
                        } else {
                            alert(data.error ?? 'Upload failed.');
                        }
                    } catch (e) { alert('Upload failed.'); }
                    if (label && label.childNodes[0]) label.childNodes[0].nodeValue = 'Upload';
                });
            });
        }());
    </script>
    </div><!-- /left column -->

    @if (Model.Sidebar != null)
    {
        var sb = Model.Sidebar;
        <aside class="space-y-4 xl:sticky xl:top-6 self-start">
            <!-- Stock summary -->
            <div class="bg-white rounded-sm border border-neutral-100 p-5">
                <h3 class="text-sm font-medium mb-3">Stock</h3>
                <div class="flex items-baseline justify-between">
                    <span class="text-xs text-neutral-400">On hand · all branches</span>
                    <span class="text-2xl font-light @(sb.TotalOnHand == 0 ? "text-red-600" : "text-neutral-900")">@sb.TotalOnHand</span>
                </div>
                @if (sb.TotalReserved > 0)
                {
                    <p class="text-[11px] text-neutral-400 mt-0.5">@sb.TotalReserved reserved (held for online orders)</p>
                }
                <div class="border-t border-neutral-100 mt-3 pt-3 space-y-1.5">
                    @if (!sb.Branches.Any())
                    {
                        <p class="text-xs text-neutral-400">No stock records yet.</p>
                    }
                    @foreach (var b in sb.Branches)
                    {
                        var thr = sb.LowStockThreshold < 1 ? 1 : sb.LowStockThreshold;
                        var low = b.OnHand > 0 && b.OnHand < thr;
                        <div class="flex items-center justify-between text-xs">
                            <span class="text-neutral-500">@b.Store.Replace("Sterlin Glams ", "")</span>
                            <span class="font-medium @(b.OnHand == 0 ? "text-red-500" : low ? "text-amber-600" : "text-neutral-800")">
                                @b.OnHand@(b.OnHand == 0 ? " · out" : low ? " · low" : "")
                            </span>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Sku))
                {
                    <a asp-area="Inventory" asp-controller="Stock" asp-action="Index" asp-route-q="@Model.Sku"
                       class="mt-3 inline-block text-[11px] text-neutral-400 hover:text-neutral-700 hover:underline">Manage stock →</a>
                }
            </div>

            <!-- Sales snapshot -->
            <div class="bg-white rounded-sm border border-neutral-100 p-5">
                <h3 class="text-sm font-medium mb-3">Sales <span class="text-xs text-neutral-400 font-normal">· last 90 days</span></h3>
                <div class="space-y-2">
                    <div class="flex justify-between text-xs"><span class="text-neutral-400">Units sold</span><span class="font-medium">@sb.UnitsSold90</span></div>
                    <div class="flex justify-between text-xs"><span class="text-neutral-400">Revenue</span><span class="font-medium text-emerald-700">₦@sb.Revenue90.ToString("N0")</span></div>
                    <div class="flex justify-between text-xs">
                        <span class="text-neutral-400">Last sold</span>
                        @if (sb.LastSold != null && sb.LastSoldOrderId != null)
                        {
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Detail" asp-route-id="@sb.LastSoldOrderId"
                               class="text-neutral-700 hover:text-neutral-900 underline decoration-dotted underline-offset-2"
                               title="Open order @sb.LastSoldOrderNumber">
                                @sb.LastSold?.ToLocalTime().ToString("dd MMM yyyy") · @sb.LastSoldOrderNumber
                            </a>
                        }
                        else
                        {
                            <span class="text-neutral-600">never</span>
                        }
                    </div>
                </div>
            </div>
        </aside>
    }
</div>
