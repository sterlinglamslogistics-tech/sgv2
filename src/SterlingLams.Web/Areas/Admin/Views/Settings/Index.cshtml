@model List<SterlingLams.Web.Models.Domain.SiteSetting>
@{
    ViewData["Title"] = "Settings";
    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "General";
    var groups = Model.GroupBy(s => s.Group).OrderBy(g => g.Key).ToList();

    // group slug used as HTML id
    string Slug(string g) => g.ToLower().Replace(" ", "_");
}

<!-- Tab nav -->
<div class="flex gap-1 border-b border-neutral-200 mb-6 overflow-x-auto">
    @foreach (var g in groups)
    {
        var isActive = g.Key == activeTab;
        <button type="button" onclick="switchTab('@g.Key')"
                id="tab-btn-@Slug(g.Key)"
                class="tab-btn px-4 py-2.5 text-xs font-medium whitespace-nowrap border-b-2 transition-colors
                       @(isActive ? "border-neutral-900 text-neutral-900" : "border-transparent text-neutral-400 hover:text-neutral-700")">
            @g.Key
        </button>
    }
</div>

@foreach (var group in groups)
{
    var slug = Slug(group.Key);
    <div id="panel-@slug" class="tab-panel @(group.Key == activeTab ? "" : "hidden") max-w-2xl">
        @if (group.Key == "Shipping")
        {
            <a asp-area="Admin" asp-controller="DeliveryZones" asp-action="Index"
               class="flex items-center justify-between gap-3 mb-4 p-4 bg-neutral-900 text-white rounded-sm hover:bg-black transition-colors">
                <span>
                    <span class="block text-sm font-medium">Delivery Zones (Lagos &amp; Abuja)</span>
                    <span class="block text-xs text-neutral-300 mt-0.5">Set Standard &amp; Express prices per distance band. Manages the area-based checkout fees.</span>
                </span>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
        }
        <form asp-area="Admin" asp-controller="Settings" asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="group" value="@group.Key" />

            <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-5">

                @foreach (var s in group.OrderBy(x => x.SortOrder))
                {
                    if (s.Type == "hidden") { <input type="hidden" name="@s.Key" value="@s.Value" /> continue; }
                    <div>
                        @if (s.Type == "boolean")
                        {
                            <label class="flex items-start gap-3 cursor-pointer">
                                <div class="mt-0.5">
                                    <input type="checkbox" name="@s.Key" value="true"
                                           @(s.Value == "true" ? "checked" : "")
                                           class="rounded border-neutral-300 accent-neutral-900 w-4 h-4" />
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-neutral-800">@s.Label</p>
                                    @if (!string.IsNullOrEmpty(s.Description))
                                    {
                                        <p class="text-xs text-neutral-400 mt-0.5">@s.Description</p>
                                    }
                                </div>
                            </label>
                        }
                        else
                        {
                            <label class="block text-xs font-medium text-neutral-700 mb-1">
                                @s.Label
                            </label>
                            @if (!string.IsNullOrEmpty(s.Description))
                            {
                                <p class="text-[11px] text-neutral-400 mb-1.5">@s.Description</p>
                            }
                            @if (s.Type == "textarea")
                            {
                                <textarea name="@s.Key" rows="3"
                                          class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 resize-none">@s.Value</textarea>
                            }
                            else if (s.Type == "html")
                            {
                                <partial name="_RichTextEditor" model='new SterlingLams.Web.Models.ViewModels.RichTextEditorVm(s.Key, "rte-" + s.Key.Replace(".", "-"), s.Value, "min-h-[12rem]")' />
                            }
                            else if (s.Type == "number")
                            {
                                <input type="number" name="@s.Key" value="@s.Value" min="0" step="0.01"
                                       class="w-48 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                            }
                            else if (s.Type == "image")
                            {
                                var inputId = "img-" + s.Key.Replace(".", "-");
                                var previewId = "prev-" + s.Key.Replace(".", "-");
                                <div class="space-y-3">
                                    @if (!string.IsNullOrEmpty(s.Value))
                                    {
                                        <div id="@previewId" class="relative inline-block">
                                            <img src="@s.Value" alt="Preview"
                                                 class="h-32 w-auto object-cover rounded border border-neutral-200" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div id="@previewId" class="hidden relative inline-block">
                                            <img src="" alt="Preview"
                                                 class="h-32 w-auto object-cover rounded border border-neutral-200" />
                                        </div>
                                    }
                                    <div class="flex gap-2 items-center">
                                        <label class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 border border-neutral-200 rounded-sm text-xs text-neutral-600 hover:border-neutral-400 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                            </svg>
                                            Upload Image
                                            <input id="@inputId" type="file" accept="image/*" class="hidden"
                                                   data-setting-key="@s.Key" data-preview-id="@previewId" />
                                        </label>
                                        <span class="text-neutral-400 text-xs">or</span>
                                        @* type=text (not url): uploads fill this with a relative path like
                                           /uploads/settings/x.jpg, which HTML5 url-validation rejects. *@
                                        <input type="text" name="@s.Key" value="@s.Value" placeholder="/uploads/… or https://…"
                                               id="url-@inputId"
                                               class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                                    </div>
                                    <p class="text-[11px] text-neutral-400">Uploading a file will fill the URL field automatically.</p>
                                </div>
                            }
                            else if (s.Type == "imagelist")
                            {
                                var listId = "il-" + s.Key.Replace(".", "-");
                                var urls = (s.Value ?? "").Split('\n', StringSplitOptions.RemoveEmptyEntries).Select(u => u.Trim()).Where(u => u.Length > 0).ToList();
                                <div class="imagelist space-y-3" data-key="@s.Key">
                                    <input type="hidden" name="@s.Key" id="val-@listId" value="@s.Value" />
                                    <div id="@listId" class="flex flex-wrap gap-3">
                                        @foreach (var u in urls)
                                        {
                                            <div class="il-item relative" data-url="@u">
                                                <img src="@u" alt="Slide" class="h-24 w-24 object-cover rounded border border-neutral-200" />
                                                <button type="button" class="il-remove absolute -top-2 -right-2 bg-white border border-neutral-300 rounded-full w-6 h-6 text-neutral-500 hover:text-red-600 shadow flex items-center justify-center text-xs">&times;</button>
                                            </div>
                                        }
                                    </div>
                                    <label class="cursor-pointer inline-flex items-center gap-2 px-3 py-2 border border-neutral-200 rounded-sm text-xs text-neutral-600 hover:border-neutral-400 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
                                        Add image
                                        <input type="file" accept="image/*" class="il-add hidden" data-list="@listId" />
                                    </label>
                                    <p class="text-[11px] text-neutral-400">Add several photos to make the hero a rotating slider. They appear in the order added.</p>
                                </div>
                            }
                            else if (s.Type == "category")
                            {
                                var cats = ViewBag.Categories as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                                <select name="@s.Key"
                                        class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 bg-white">
                                    <option value="">— Select a category —</option>
                                    @foreach (var c in cats)
                                    {
                                        <option value="@c.Slug" selected="@(s.Value == (string)c.Slug)">@c.Name</option>
                                    }
                                </select>
                            }
                            else if (s.Type == "select")
                            {
                                <select name="@s.Key"
                                        class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400 bg-white">
                                    @foreach (var o in SterlingLams.Web.Infrastructure.SettingsSelectOptions.For(s.Key))
                                    {
                                        <option value="@o.Value" selected="@(s.Value == o.Value)">@o.Label</option>
                                    }
                                </select>
                            }
                            else if (s.Type == "color")
                            {
                                <div class="flex items-center gap-3">
                                    <input type="color" name="@s.Key" value="@(string.IsNullOrWhiteSpace(s.Value) ? "#ed028b" : s.Value)"
                                           class="h-10 w-16 border border-neutral-200 rounded-sm p-1 cursor-pointer bg-white"
                                           oninput="this.nextElementSibling.textContent=this.value" />
                                    <span class="text-xs text-neutral-500 font-mono">@s.Value</span>
                                </div>
                            }
                            else
                            {
                                <input type="@s.Type" name="@s.Key" value="@s.Value"
                                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                            }
                        }
                    </div>
                }

            </div>

            <div class="mt-4 flex items-center gap-3">
                <button type="submit"
                        class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                    Save @group.Key Settings
                </button>
                <p class="text-xs text-neutral-400">Changes take effect immediately.</p>
            </div>
        </form>
    </div>
}

@section Scripts {
<script>
    function switchTab(name) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('border-neutral-900', 'text-neutral-900');
            b.classList.add('border-transparent', 'text-neutral-400');
        });
        const slug = name.toLowerCase().replace(/ /g, '_');
        document.getElementById('panel-' + slug)?.classList.remove('hidden');
        const btn = document.getElementById('tab-btn-' + slug);
        if (btn) {
            btn.classList.remove('border-transparent', 'text-neutral-400');
            btn.classList.add('border-neutral-900', 'text-neutral-900');
        }
    }

    // Image upload via file picker
    document.querySelectorAll('input[type="file"][data-setting-key]').forEach(input => {
        input.addEventListener('change', async () => {
            const file = input.files[0];
            if (!file) return;
            const key = input.dataset.settingKey;
            const previewId = input.dataset.previewId;
            const urlInput = document.getElementById('url-img-' + key.replace(/\./g, '-'));
            const previewWrap = document.getElementById(previewId);

            const form = new FormData();
            form.append('file', file);
            form.append('subfolder', 'settings');
            form.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');

            const label = input.closest('label');
            if (label) label.textContent = 'Uploading…';

            const res = await fetch(__adminBase + '/Upload/Image', { method: 'POST', body: form });
            const data = await res.json();

            if (label) { label.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/> </svg> Upload Image <input id="' + input.id + '" type="file" accept="image/*" class="hidden" data-setting-key="' + key + '" data-preview-id="' + previewId + '" />'; }

            if (res.ok && data.url) {
                if (urlInput) urlInput.value = data.url;
                if (previewWrap) {
                    const img = previewWrap.querySelector('img');
                    if (img) { img.src = data.url; previewWrap.classList.remove('hidden'); }
                }

                // Persist the value immediately so it takes effect without a
                // separate "Save" click (and survives any form quirks).
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                try {
                    await fetch(__adminBase + '/Settings/SaveOne', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'key=' + encodeURIComponent(key) + '&value=' + encodeURIComponent(data.url) + '&__RequestVerificationToken=' + encodeURIComponent(token)
                    });
                } catch (e) { /* falls back to the form's Save button */ }
            } else {
                alert(data.error ?? 'Upload failed. Please try again.');
            }
        });
    });

    // Multi-image (imagelist) manager — e.g. hero slider images
    document.querySelectorAll('.imagelist').forEach(function (wrap) {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        var hidden = wrap.querySelector('input[type="hidden"]');
        var container = document.getElementById(wrap.querySelector('.il-add').dataset.list);

        function resync() {
            var urls = Array.prototype.map.call(wrap.querySelectorAll('.il-item'), function (i) { return i.getAttribute('data-url'); });
            hidden.value = urls.join('\n');
            // Persist immediately (like the single-image picker) so it takes effect without Save.
            fetch(__adminBase + '/Settings/SaveOne', {
                method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'key=' + encodeURIComponent(wrap.dataset.key) + '&value=' + encodeURIComponent(hidden.value) + '&__RequestVerificationToken=' + encodeURIComponent(token)
            }).catch(function () {});
        }

        wrap.addEventListener('click', function (e) {
            var rm = e.target.closest('.il-remove');
            if (rm) { var item = rm.closest('.il-item'); if (item) { item.remove(); resync(); } }
        });

        var add = wrap.querySelector('.il-add');
        add.addEventListener('change', async function () {
            var file = add.files[0]; if (!file) return;
            var label = add.closest('label'); if (label) label.style.opacity = '0.5';
            var form = new FormData();
            form.append('file', file); form.append('subfolder', 'settings'); form.append('__RequestVerificationToken', token);
            try {
                var res = await fetch(__adminBase + '/Upload/Image', { method: 'POST', body: form });
                var data = await res.json();
                add.value = '';
                if (res.ok && data.url) {
                    var div = document.createElement('div');
                    div.className = 'il-item relative'; div.setAttribute('data-url', data.url);
                    div.innerHTML = '<img src="' + data.url + '" alt="Slide" class="h-24 w-24 object-cover rounded border border-neutral-200" />'
                        + '<button type="button" class="il-remove absolute -top-2 -right-2 bg-white border border-neutral-300 rounded-full w-6 h-6 text-neutral-500 hover:text-red-600 shadow flex items-center justify-center text-xs">&times;</button>';
                    container.appendChild(div);
                    resync();
                } else { alert(data.error ?? 'Upload failed. Please try again.'); }
            } catch (e) { alert('Upload failed. Please try again.'); }
            if (label) label.style.opacity = '';
        });
    });
</script>
}
