@model SterlingLams.Web.Areas.Admin.ViewModels.AdminUserListViewModel
@{
    ViewData["Title"] = "User Management";
    bool hasFilters = !string.IsNullOrEmpty(Model.SearchQuery) ||
                      !string.IsNullOrEmpty(Model.RoleFilter) ||
                      !string.IsNullOrEmpty(Model.StatusFilter);
}

<!-- Stat cards -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-3 mb-6">
    @{
        var stats = new[]
        {
            new { Label = "Total Staff",   Value = Model.TotalUsers.ToString(),    Color = "text-neutral-800" },
            new { Label = "Admins",        Value = Model.AdminCount.ToString(),    Color = "text-violet-600" },
            new { Label = "Staff",         Value = Model.CustomerCount.ToString(), Color = "text-blue-600" },
            new { Label = "Locked",        Value = Model.LockedCount.ToString(),   Color = "text-red-600" },
            new { Label = "New This Month",Value = Model.NewThisMonth.ToString(),  Color = "text-emerald-600" },
        };
    }
    @foreach (var s in stats)
    {
        <div class="bg-white rounded-sm border border-neutral-100 p-4">
            <p class="text-[10px] text-neutral-400 uppercase tracking-widest mb-1">@s.Label</p>
            <p class="text-2xl font-light @s.Color">@s.Value</p>
        </div>
    }
</div>

<!-- Toolbar: action buttons -->
<div class="flex justify-end gap-2 mb-4">
    <a asp-area="Admin" asp-controller="Users" asp-action="ExportCsv"
       class="px-4 py-2 border border-neutral-300 text-neutral-700 text-xs rounded-sm hover:border-neutral-500 transition-colors">
        ↓ Export CSV
    </a>
    <a asp-area="Admin" asp-controller="Users" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        + New User
    </a>
</div>

<!-- Filters -->
<form method="get" class="bg-white rounded-sm border border-neutral-100 p-4 mb-4">
    <div class="flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Search</label>
            <input type="text" name="q" value="@Model.SearchQuery"
                   placeholder="Name, email or phone…"
                   class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        </div>
        <div>
            <label class="block text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Role</label>
            <select name="role" class="border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400 bg-white min-w-[120px]">
                <option value="">All Roles</option>
                @foreach (var r in Model.AvailableRoles)
                {
                    <option value="@r" selected="@(Model.RoleFilter == r)">@r</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-[10px] text-neutral-400 uppercase tracking-widest mb-1">Status</label>
            <select name="status" class="border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400 bg-white min-w-[120px]">
                <option value="">All Status</option>
                <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
                <option value="locked" selected="@(Model.StatusFilter == "locked")">Locked</option>
            </select>
        </div>
        <button type="submit" class="px-6 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
            Apply Filters
        </button>
        @if (hasFilters)
        {
            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               class="px-4 py-2 border border-neutral-300 text-neutral-500 text-xs rounded-sm hover:border-neutral-500 transition-colors">
                ✕ Clear
            </a>
        }
        <p class="text-xs text-neutral-400 ml-auto self-center">
            <strong class="text-neutral-700">@Model.TotalCount</strong> result@(Model.TotalCount == 1 ? "" : "s")
        </p>
    </div>
</form>

<!-- Hidden reset-password forms (outside table) -->
@foreach (var u in Model.Users.Where(u => u.Email != User.Identity?.Name))
{
    <form id="reset-@u.Id" asp-area="Admin" asp-controller="Users" asp-action="ResetPassword"
          method="post" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@u.Id" />
        <input type="hidden" name="newPassword" id="reset-pwd-@u.Id" />
    </form>
    <form id="setpin-@u.Id" asp-area="Admin" asp-controller="Users" asp-action="SetPin"
          method="post" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@u.Id" />
        <input type="hidden" name="pin" id="setpin-val-@u.Id" />
    </form>
}

<div class="bg-white rounded-sm border border-neutral-100 overflow-x-auto">
    <table class="w-full text-sm min-w-[800px]">
        <thead>
            <tr class="border-b border-neutral-100 bg-neutral-50">
                <th class="text-left px-6 py-3 text-xs text-neutral-400 font-medium">User</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Phone</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Role</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Status</th>
                <th class="text-center px-4 py-3 text-xs text-neutral-400 font-medium">Orders</th>
                <th class="text-right px-4 py-3 text-xs text-neutral-400 font-medium">Spend</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Last Login</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.Users.Any())
            {
                <tr><td colspan="8" class="px-6 py-10 text-center text-xs text-neutral-400">No users match your filters.</td></tr>
            }
            @foreach (var u in Model.Users)
            {
                var isSelf = u.Email == User.Identity?.Name;
                <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-6 py-3">
                        <p class="text-xs font-medium text-neutral-800">@u.FullName @if (isSelf) { <span class="text-[9px] text-neutral-300">(You)</span> }</p>
                        <p class="text-[10px] text-neutral-400">@u.Email
                            @if (!u.EmailConfirmed) { <span class="text-amber-500" title="Email not confirmed">●</span> }
                        </p>
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-500">@(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)</td>
                    <td class="px-4 py-3">
                        @if (isSelf || u.IsAdmin)
                        {
                            @* Own account and full administrators aren't editable from this list. *@
                            <span class="text-[10px] bg-violet-50 text-violet-700 px-2 py-0.5 rounded-full">@u.RoleName</span>
                        }
                        else
                        {
                            <form asp-area="Admin" asp-controller="Users" asp-action="SetRole" asp-route-id="@u.Id"
                                  method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <select name="role" onchange="this.form.submit()"
                                        class="text-[11px] border border-neutral-200 rounded-sm px-2 py-1 bg-white focus:outline-none focus:border-neutral-400 cursor-pointer
                                               @(u.RoleName == "Customer" ? "text-neutral-500" : "text-neutral-700")">
                                    @foreach (var r in Model.AssignableRoles)
                                    {
                                        <option value="@r" selected="@(u.RoleName == r)">@r</option>
                                    }
                                </select>
                            </form>
                        }
                    </td>
                    <td class="px-4 py-3">
                        @if (u.IsRevoked)
                        {
                            <span class="text-[10px] bg-neutral-800 text-white px-2 py-0.5 rounded-full">Revoked</span>
                        }
                        else if (u.IsLocked)
                        {
                            <span class="text-[10px] bg-red-50 text-red-700 px-2 py-0.5 rounded-full">Locked</span>
                        }
                        else
                        {
                            <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-center text-xs text-neutral-600">@u.OrderCount</td>
                    <td class="px-4 py-3 text-right text-xs font-medium @(u.TotalSpend > 0 ? "text-emerald-600" : "text-neutral-400")">
                        ₦@u.TotalSpend.ToString("N0")
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-400 whitespace-nowrap">
                        @(u.LastLoginAt.HasValue ? u.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yy") : "Never")
                    </td>
                    <td class="px-6 py-3 text-right">
                        @if (!isSelf)
                        {
                            <div class="flex items-center justify-end gap-3 whitespace-nowrap">
                                <button type="button" data-no-loading="1"
                                        onclick="setPin('@u.Id', '@u.Email')"
                                        class="text-xs text-brand-500 hover:text-brand-700 transition-colors">Set PIN</button>
                                <button type="button" data-no-loading="1"
                                        onclick="resetPwd('@u.Id', '@u.Email')"
                                        class="text-xs text-amber-500 hover:text-amber-700 transition-colors">Reset PW</button>
                                @if (u.RoleName != "Customer" && !u.IsAdmin)
                                {
                                    <a asp-area="Admin" asp-controller="Users" asp-action="Stores" asp-route-id="@u.Id"
                                       class="text-xs text-neutral-500 hover:text-neutral-800 transition-colors">Branches</a>
                                }
                                <form asp-area="Admin" asp-controller="Users" asp-action="ToggleLock" asp-route-id="@u.Id"
                                      method="post" class="inline" onsubmit="return confirm('@(u.IsLocked ? "Unlock" : "Lock") @u.Email?')">
                                    @Html.AntiForgeryToken()
                                    <button data-no-loading="1" class="text-xs @(u.IsLocked ? "text-emerald-500 hover:text-emerald-800" : "text-red-400 hover:text-red-700") transition-colors">
                                        @(u.IsLocked ? "Unlock" : "Lock")
                                    </button>
                                </form>
                                <form asp-area="Admin" asp-controller="Users" asp-action="@(u.IsRevoked ? "Restore" : "Revoke")" asp-route-id="@u.Id"
                                      method="post" class="inline"
                                      onsubmit="return confirm('@(u.IsRevoked ? "Restore access for" : "Revoke access for — they will be signed out and blocked from signing in:") @u.Email?')">
                                    @Html.AntiForgeryToken()
                                    <button data-no-loading="1" class="text-xs font-medium @(u.IsRevoked ? "text-emerald-600 hover:text-emerald-800" : "text-red-500 hover:text-red-700") transition-colors">
                                        @(u.IsRevoked ? "Restore" : "Revoke")
                                    </button>
                                </form>
                                @if (!u.IsAdmin)
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@u.Id"
                                          method="post" class="inline"
                                          onsubmit="return confirm('Permanently delete @u.Email? This cannot be undone. (Accounts with orders can\'t be deleted — revoke instead.)')">
                                        @Html.AntiForgeryToken()
                                        <button data-no-loading="1" class="text-xs font-medium text-red-500 hover:text-red-700 transition-colors">Delete</button>
                                    </form>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-[10px] text-neutral-300">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-end gap-2 mt-4">
        @for (int p = 1; p <= Model.TotalPages; p++)
        {
            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               asp-route-page="@p" asp-route-q="@Model.SearchQuery"
               asp-route-role="@Model.RoleFilter" asp-route-status="@Model.StatusFilter"
               class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(p == Model.CurrentPage ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">
                @p
            </a>
        }
    </div>
}

@section Scripts {
<script>
function resetPwd(id, email) {
    const pwd = prompt('Enter a new password for ' + email + ' (min 8 characters):');
    if (pwd === null) return;            // cancelled
    if (pwd.length < 8) { alert('Password must be at least 8 characters.'); return; }
    document.getElementById('reset-pwd-' + id).value = pwd;
    document.getElementById('reset-' + id).submit();
}
function setPin(id, email) {
    const pin = prompt('Set a 4–8 digit POS PIN for ' + email + '\n(leave blank and press OK to remove their PIN):');
    if (pin === null) return;            // cancelled
    if (pin !== '' && !/^\d{4,8}$/.test(pin)) { alert('PIN must be 4–8 digits.'); return; }
    document.getElementById('setpin-val-' + id).value = pin;
    document.getElementById('setpin-' + id).submit();
}
</script>
}
