@model SterlingLams.Web.Areas.Admin.ViewModels.AdminCreateUserViewModel
@{
    ViewData["Title"] = "New User";
}

<div class="flex items-center gap-3 mb-6">
    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
       class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Users</a>
    <span class="text-neutral-200">/</span>
    <span class="text-xs text-neutral-600">New User</span>
</div>

<div class="max-w-lg">
    <form asp-area="Admin" asp-controller="Users" asp-action="Create" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="FirstName" class="block text-xs text-neutral-500 mb-1">First Name <span class="text-red-400">*</span></label>
                    <input asp-for="FirstName" required
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="LastName" class="block text-xs text-neutral-500 mb-1">Last Name <span class="text-red-400">*</span></label>
                    <input asp-for="LastName" required
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-xs text-neutral-500 mb-1">Email <span class="text-red-400">*</span></label>
                <input asp-for="Email" type="email" required autocomplete="off"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <div>
                <label asp-for="Phone" class="block text-xs text-neutral-500 mb-1">Phone</label>
                <input asp-for="Phone" type="tel" placeholder="+234 800 000 0000"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <div>
                <label asp-for="Password" class="block text-xs text-neutral-500 mb-1">Password <span class="text-red-400">*</span></label>
                <div class="flex gap-2">
                    <input asp-for="Password" type="text" id="pwd-field" required minlength="8" autocomplete="new-password"
                           class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
                    <button type="button" onclick="genPwd()"
                            class="px-3 py-2 border border-neutral-200 text-neutral-600 text-xs rounded-sm hover:bg-neutral-50 transition-colors whitespace-nowrap">
                        Generate
                    </button>
                </div>
                <p class="text-[11px] text-neutral-400 mt-1">Minimum 8 characters. Share this securely with the user.</p>
            </div>

            <div>
                <label asp-for="Role" class="block text-xs text-neutral-500 mb-1">Role <span class="text-red-400">*</span></label>
                <select asp-for="Role" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm bg-white focus:outline-none focus:border-neutral-400">
                    @foreach (var r in (ViewBag.Roles as string[]) ?? Array.Empty<string>())
                    {
                        <option value="@r">@r</option>
                    }
                </select>
                <p class="text-[11px] text-neutral-400 mt-1">Staff members can sign in to the backend (with this role) and shop the storefront. To add a storefront-only account, use “New customer” on the Customers page.</p>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                Create User
            </button>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function genPwd() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789!@@#$';
    let pwd = '';
    for (let i = 0; i < 12; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
    document.getElementById('pwd-field').value = pwd;
}
</script>
}
