@model SterlingLams.Web.Models.ViewModels.ProductDetailViewModel
@using SterlingLams.Web.Services
@inject ISettingsService SettingsService
@{
    ViewData["Title"] = Model.Name;
    ViewData["Description"] = Model.ShortDescription;
    ViewData["OgType"] = "product";
    ViewData["OgImage"] = Model.ImageUrls.FirstOrDefault();
    Layout = "_Layout";

    // Low-stock nudge (storefront): show "Low stock" at/below this qty without ever revealing the count.
    var lowStockThreshold = (int)await SettingsService.GetDecimalAsync("inventory.low_stock_threshold", 5);
    // Admin can switch the whole low-stock nudge off (threshold 0 = nothing ever reads as low).
    if (!await SettingsService.GetBoolAsync("inventory.show_low_stock_nudge", true)) lowStockThreshold = 0;
    var bestBranchQty = Model.StoreStock.Any() ? Model.StoreStock.Max(s => s.Quantity) : 0;
    var isLowStock = Model.IsAvailableAnywhere && bestBranchQty <= lowStockThreshold;

    var fullDescription = !string.IsNullOrWhiteSpace(Model.Description)
        ? Model.Description
        : (Model.ShortDescription ?? "");
    var shippingPolicy = await SettingsService.GetAsync("shipping.returns_policy", "");

    // The size & length guide only makes sense for wearables that need sizing — rings, bracelets/
    // bangles, necklaces and anklets. Explicit allow-list (by category slug) so lookalikes like
    // "key-rings", "earrings" and "bracelet-watches" don't show it.
    var sizeGuideCategories = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "rings", "bracelets", "bracelets-bangles", "necklaces", "necklaces-pendants", "anklets"
    };
    var showSizeGuide = sizeGuideCategories.Contains(Model.CategorySlug ?? "");

    // ── Structured data (Product + breadcrumbs) ──────────────────────────────
    var sdReq = Context.Request;
    var sdBase = $"{sdReq.Scheme}://{sdReq.Host}";
    var sdUrl = sdBase + sdReq.Path;
    string SdAbs(string u) => string.IsNullOrEmpty(u) ? u : (u.StartsWith("/") ? sdBase + u : u);
    // Real values so the Offer enrichments Google wants aren't fabricated: national shipping rate
    // and the configured return window (default 7 days). priceValidUntil silences Google's warning.
    var sdShipFee = await SettingsService.GetDecimalAsync("shipping.national_standard_fee", 7500);
    var sdReturnDays = (int)await SettingsService.GetDecimalAsync("shipping.return_days", 7);
    var sdPriceValidUntil = DateTime.UtcNow.AddYears(1).ToString("yyyy-MM-dd");
    var jsonOpts = new System.Text.Json.JsonSerializerOptions
    {
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };
    var productLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org/",
        ["@type"] = "Product",
        ["name"] = Model.Name,
        ["image"] = Model.ImageUrls.Select(SdAbs).ToArray(),
        ["description"] = string.IsNullOrWhiteSpace(fullDescription) ? Model.Name : SterlingLams.Web.Services.ProductHtml.ToPlainText(fullDescription),
        ["sku"] = string.IsNullOrWhiteSpace(Model.Sku) ? null : Model.Sku,
        ["brand"] = new Dictionary<string, object?> { ["@type"] = "Brand", ["name"] = "Sterlin Glams" },
        ["category"] = Model.CategoryName,
        ["aggregateRating"] = Model.ReviewCount > 0 ? new Dictionary<string, object?>
        {
            ["@type"] = "AggregateRating",
            ["ratingValue"] = Model.AverageRating,
            ["reviewCount"] = Model.ReviewCount,
        } : null,
        ["offers"] = new Dictionary<string, object?>
        {
            ["@type"] = "Offer",
            ["url"] = sdUrl,
            ["priceCurrency"] = Model.Currency,
            ["price"] = Model.EffectivePrice,
            ["priceValidUntil"] = sdPriceValidUntil,
            ["availability"] = Model.IsAvailableAnywhere ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
            ["itemCondition"] = "https://schema.org/NewCondition",
            ["shippingDetails"] = new Dictionary<string, object?>
            {
                ["@type"] = "OfferShippingDetails",
                ["shippingRate"] = new Dictionary<string, object?>
                {
                    ["@type"] = "MonetaryAmount",
                    ["value"] = sdShipFee,
                    ["currency"] = Model.Currency,
                },
                ["shippingDestination"] = new Dictionary<string, object?>
                {
                    ["@type"] = "DefinedRegion",
                    ["addressCountry"] = "NG",
                },
            },
            ["hasMerchantReturnPolicy"] = new Dictionary<string, object?>
            {
                ["@type"] = "MerchantReturnPolicy",
                ["applicableCountry"] = "NG",
                ["returnPolicyCategory"] = "https://schema.org/MerchantReturnFiniteReturnWindow",
                ["merchantReturnDays"] = sdReturnDays,
                ["returnMethod"] = "https://schema.org/ReturnByMail",
                ["returnFees"] = "https://schema.org/ReturnShippingFees",
            },
        },
    }, jsonOpts);
    var breadcrumbLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new object[]
        {
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Home", ["item"] = sdBase },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = Model.CategoryName, ["item"] = $"{sdBase}/products?category={Model.CategorySlug}" },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 3, ["name"] = Model.Name, ["item"] = sdUrl },
        },
    }, jsonOpts);
}

@section Head {
    <script type="application/ld+json" nonce="@Context.Items["csp-nonce"]">@Html.Raw(productLd)</script>
    <script type="application/ld+json" nonce="@Context.Items["csp-nonce"]">@Html.Raw(breadcrumbLd)</script>
    <style>
        /* Rich-text product description authored in the back office */
        .prod-rich-desc ul { list-style: disc; padding-left: 1.5rem; margin: 0.5rem 0; }
        .prod-rich-desc ol { list-style: decimal; padding-left: 1.5rem; margin: 0.5rem 0; }
        .prod-rich-desc li { margin: 0.2rem 0; }
        .prod-rich-desc p { margin: 0.5rem 0; }
        .prod-rich-desc h2, .prod-rich-desc h3, .prod-rich-desc h4 { font-weight: 500; color: #1f2937; margin: 0.75rem 0 0.4rem; }
        .prod-rich-desc strong, .prod-rich-desc b { font-weight: 600; color: #374151; }
        .prod-rich-desc blockquote { border-left: 2px solid #e5e7eb; padding-left: 1rem; color: #6b7280; margin: 0.5rem 0; }
    </style>
}

@* Antiforgery token for the AJAX POSTs on this page (Add to Bag, wishlist, notify-restock).
   Rendering it here also sets the antiforgery cookie, which CartController's
   [ValidateAntiForgeryToken] requires. *@
@Html.AntiForgeryToken()

<div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-neutral-400 tracking-wider mb-10 flex gap-2 items-center">
        <a asp-controller="Home" asp-action="Index" class="hover:text-neutral-700 transition-colors">Home</a>
        <span>/</span>
        <a asp-controller="Products" asp-action="Index" asp-route-category="@Model.CategorySlug" class="hover:text-neutral-700 transition-colors">@Model.CategoryName</a>
        <span>/</span>
        <span class="text-neutral-700">@Model.Name</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">

        <!-- ─── Image Gallery ─────────────────────────────────────────── -->
        <div class="space-y-3">
            <!-- Zoom container: hover to zoom, click to toggle pinned zoom -->
            <div class="aspect-square bg-neutral-50 overflow-hidden zoom-container cursor-zoom-in relative" id="zoom-container">
                <img id="main-image" src="@Img.Cld(Model.PrimaryImageUrl, 1000)" alt="@Model.Name" width="800" height="800"
                     class="w-full h-full object-cover object-center transition-transform duration-300 will-change-transform" />
                <partial name="_DiscountBadge" model="Model.DiscountPercent" />
            </div>
            @if (Model.ImageUrls.Count > 1)
            {
                @* Mobile: a single swipeable row (many-image products would otherwise stack into a
                   tall grid and push the buy box off-screen). md+: the 4-column grid. *@
                <div class="flex md:grid md:grid-cols-4 gap-2 overflow-x-auto pb-1 snap-x">
                    @foreach (var (url, i) in Model.ImageUrls.Select((u, i) => (u, i)))
                    {
                        <button type="button" data-img-url="@Img.Cld(url, 1000)"
                                class="thumb-btn shrink-0 w-16 md:w-auto aspect-square bg-neutral-50 overflow-hidden border-2 @(i == 0 ? "border-brand-500" : "border-transparent") hover:border-brand-300 transition-colors snap-start">
                            <img src="@Img.Cld(url, 150, 150)" alt="@Model.Name view @(i+1)" loading="lazy" width="150" height="150" class="w-full h-full object-cover" />
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Mobile fullscreen image lightbox (tap-to-open; hover-zoom is desktop-only) -->
        <div id="img-lightbox" class="hidden fixed inset-0 z-[300] bg-black md:hidden" role="dialog" aria-modal="true" aria-label="Product image">
            <button type="button" id="lightbox-close" class="absolute top-4 right-4 z-10 text-white p-2" aria-label="Close image">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div id="lightbox-stage" class="w-full h-full flex items-center justify-center p-4">
                <img id="lightbox-img" src="" alt="@Model.Name" class="max-w-full max-h-full object-contain" />
            </div>
            @if (Model.ImageUrls.Count > 1)
            {
                <button type="button" id="lightbox-prev" class="absolute left-1 top-1/2 -translate-y-1/2 text-white p-3" aria-label="Previous image">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button type="button" id="lightbox-next" class="absolute right-1 top-1/2 -translate-y-1/2 text-white p-3" aria-label="Next image">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
                </button>
                <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-xs tracking-[0.2em]"></div>
            }
        </div>

        <!-- ─── Product Info ──────────────────────────────────────────── -->
        <div class="flex flex-col">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-2">@Model.CategoryName</p>
            <h1 class="font-cormorant text-4xl font-light text-neutral-900 mb-2">@Model.Name</h1>
            @if (Model.ReviewsEnabled && Model.ReviewCount > 0)
            {
                <a href="#product-tabs" data-tab-jump="reviews" class="inline-flex items-center gap-2 mb-4 text-sm w-fit">
                    <span class="text-base leading-none">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(Model.AverageRating) ? "text-brand-500" : "text-neutral-300")">★</span>
                        }
                    </span>
                    <span class="text-neutral-500 hover:text-neutral-900 underline underline-offset-2">@Model.AverageRating.ToString("0.0") (@Model.ReviewCount)</span>
                </a>
            }
            <p class="mb-2 flex items-baseline gap-3 flex-wrap" id="price-block">
                <span id="price-effective" class="text-2xl font-light @(Model.IsOnSale ? "text-brand-600" : "text-neutral-800")">@Model.FormattedPrice</span>
                <span id="price-regular" class="text-lg font-light text-neutral-400 line-through @(Model.IsOnSale ? "" : "hidden")">@Model.FormattedRegularPrice</span>
            </p>
            @{
                // "Only N left" urgency: for a simple (no-variant) product we know the exact total
                // now; for a variant product the count is filled in by JS once an option is chosen.
                var totalLeft = Model.TotalStock;
                var showCountNudge = !Model.Variants.Any() && totalLeft > 0 && totalLeft <= lowStockThreshold;
                var nudgeVisible = Model.Variants.Any() ? isLowStock : showCountNudge;
            }
            <p id="low-stock-nudge" class="text-sm text-amber-600 font-medium mb-6 flex items-center gap-1.5 @(nudgeVisible ? "" : "hidden")">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span id="low-stock-text">@(showCountNudge ? $"Only {totalLeft} left — order soon" : "Low stock — order soon")</span>
            </p>
            @{
                // Positive "in stock" affirmation — shown when comfortably in stock (not low, not sold out).
                var inStockStores = Model.StoreStock.Count(s => s.Quantity > 0);
                var showInStock = !Model.Variants.Any() && Model.IsAvailableAnywhere && !nudgeVisible;
            }
            <p id="in-stock-line" class="text-sm text-emerald-700 font-medium mb-6 flex items-center gap-2 @(showInStock ? "" : "hidden")">
                <span class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0"></span>
                <span>In stock@(inStockStores > 1 ? $" — available at {inStockStores} stores" : inStockStores == 1 ? " — ready to collect or ship" : ", ready to ship")</span>
            </p>

            @if (!string.IsNullOrEmpty(Model.ShortDescription))
            {
                <p class="text-sm text-neutral-500 leading-relaxed mb-4 font-light">@Model.ShortDescription</p>
            }

            @if (showSizeGuide)
            {
                <button type="button" data-size-guide-open
                        class="inline-flex items-center gap-1.5 text-xs tracking-[0.12em] uppercase text-neutral-500 hover:text-brand-500 transition-colors mb-8">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7h18M3 12h18M3 17h18"/>
                    </svg>
                    Size &amp; length guide
                </button>
            }

            <!-- ─── Store Stock (per branch, with counts) ───────────────── -->
            @if (Model.StoreStock.Any())
            {
                <div class="mb-8" id="store-stock">
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-4">Availability by branch</p>
                    @if (Model.Variants.Any())
                    {
                        @* Variant product: counts are per chosen option, so wait for a selection. *@
                        <p id="stock-prompt" class="text-sm text-neutral-400">Select an option above to see stock at each branch.</p>
                        <div id="store-stock-list" class="space-y-2.5 hidden"></div>
                    }
                    else
                    {
                        <div class="space-y-2.5">
                            @foreach (var store in Model.StoreStock)
                            {
                                var qty = store.Quantity;
                                var low = qty > 0 && qty <= lowStockThreshold;
                                <div class="flex items-center justify-between rounded-lg border border-neutral-100 px-4 py-3 transition-colors hover:border-neutral-200">
                                    <span class="flex items-center gap-2.5 min-w-0">
                                        <span class="w-2 h-2 rounded-full flex-shrink-0 @(qty == 0 ? "bg-neutral-300" : low ? "bg-amber-500" : "bg-emerald-500")"></span>
                                        <span class="text-sm text-neutral-700 truncate">@store.StoreName.Replace("Sterlin Glams ", "")</span>
                                    </span>
                                    @if (qty > 0)
                                    {
                                        <span class="text-xs font-medium px-2.5 py-1 rounded-full whitespace-nowrap @(low ? "bg-amber-50 text-amber-700" : "bg-emerald-50 text-emerald-700")">@qty in stock</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-400 whitespace-nowrap">Out of stock</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- ─── Variants / Option Selector ───────────────────────── -->
            @if (Model.Variants.Any())
            {
                var attributeNames = Model.Variants
                    .SelectMany(v => v.AttributeLabels.Select(a => a.AttributeName))
                    .Distinct().ToList();

                <div class="mb-8 space-y-4" id="variant-selectors">
                    @foreach (var attrName in attributeNames)
                    {
                        var distinctValues = Model.Variants
                            .SelectMany(v => v.AttributeLabels.Where(a => a.AttributeName == attrName))
                            .GroupBy(a => a.Value)
                            .Select(g => g.First())
                            .ToList();

                        <div>
                            <label class="block text-xs tracking-[0.2em] uppercase text-neutral-500 mb-2">
                                @attrName
                            </label>
                            <select class="attr-select w-full border border-neutral-300 px-4 py-3 text-sm text-neutral-700
                                           focus:outline-none focus:border-neutral-900 bg-white transition-colors appearance-none
                                           cursor-pointer"
                                    data-attr="@attrName">
                                <option value="">— Select @attrName —</option>
                                @foreach (var val in distinctValues)
                                {
                                    <option value="@val.Value">@val.Value</option>
                                }
                            </select>
                        </div>
                    }

                    <input type="hidden" id="selected-variant-id" value="" />
                    <p id="select-colour-prompt" class="text-xs text-amber-600 hidden">
                        Please select all options before adding to bag.
                    </p>
                </div>

                <script id="variants-data" type="application/json">
                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Variants.Select(v => new {
                        id = v.Id,
                        name = v.Name,
                        priceAdjustment = v.PriceAdjustment,
                        imageUrl = v.ImageUrl,
                        inStock = v.Available > 0,
                        available = v.Available,
                        lowStock = v.Available > 0 && v.Available <= lowStockThreshold,
                        // Per-branch stock for this variant, shown once the customer picks the option.
                        stores = v.StoreStock.Select(s => new {
                            name = s.StoreName.Replace("Sterlin Glams ", ""),
                            qty = s.Quantity,
                            low = s.Quantity > 0 && s.Quantity <= lowStockThreshold
                        }),
                        attributes = v.AttributeLabels.ToDictionary(a => a.AttributeName, a => a.Value)
                    })))
                </script>
            }

            <!-- ─── Actions ───────────────────────────────────────────── -->
            <div class="mb-8">
                @if (Model.IsAvailableAnywhere)
                {
                    <!-- Quantity -->
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-3">Quantity</p>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="flex items-center border border-neutral-300">
                            <button id="qty-minus" type="button"
                                    class="w-10 h-10 flex items-center justify-center text-neutral-600 hover:bg-neutral-50 transition-colors text-lg leading-none">−</button>
                            <span id="qty-display" class="w-12 text-center text-sm border-x border-neutral-300 py-2">1</span>
                            <button id="qty-plus" type="button"
                                    class="w-10 h-10 flex items-center justify-center text-neutral-600 hover:bg-neutral-50 transition-colors text-lg leading-none">+</button>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button id="add-to-cart"
                                data-product-id="@Model.Id"
                                data-has-variants="@(Model.Variants.Any() ? "true" : "false")"
                                class="flex-1 bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-4 px-8 rounded-md hover:bg-brand-600 transition-colors duration-300">
                            Add to Bag
                        </button>
                        <button id="wishlist-btn"
                                data-product-id="@Model.Id"
                                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                                class="border border-neutral-300 px-4 rounded-md hover:border-brand-500 hover:text-brand-500 transition-colors">
                            <svg class="w-5 h-5 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                                 fill="@(Model.IsInWishlist ? "currentColor" : "none")"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <!-- Out of stock — back-in-stock email capture -->
                    <div class="border border-neutral-200 p-6 bg-neutral-50">
                        <p class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-1">Currently Unavailable</p>
                        <p class="text-sm text-neutral-500 font-light mb-5">
                            @Model.OutOfStockMessage Enter your email and we'll notify you the moment it's back.
                        </p>
                        <form id="notify-form" class="flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="email" name="email" required
                                   placeholder="your@email.com"
                                   class="flex-1 min-w-0 border border-neutral-300 px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition-colors" />
                            <button type="submit"
                                    class="bg-brand-500 text-white text-xs tracking-[0.15em] uppercase px-6 py-3 rounded-md hover:bg-brand-600 transition-colors whitespace-nowrap">
                                Notify Me
                            </button>
                        </form>
                        <p id="notify-success" class="hidden text-xs text-emerald-600 mt-3 tracking-wide">
                            You're on the list! We'll email you when this item is restocked.
                        </p>
                    </div>
                    <div class="flex gap-3 mt-4">
                        <button disabled
                                class="flex-1 bg-neutral-200 text-neutral-400 text-xs tracking-[0.2em] uppercase py-4 px-8 cursor-not-allowed">
                            Out of Stock
                        </button>
                        <button id="wishlist-btn"
                                data-product-id="@Model.Id"
                                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                                class="border border-neutral-300 px-4 rounded-md hover:border-brand-500 hover:text-brand-500 transition-colors">
                            <svg class="w-5 h-5 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                                 fill="@(Model.IsInWishlist ? "currentColor" : "none")"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>

            <!-- ─── Wishlist link + meta (SKU / Category) ──────────────── -->
            <div class="mb-8">
                <button id="wishlist-link" type="button" data-product-id="@Model.Id"
                        class="inline-flex items-center gap-2 text-sm text-neutral-600 hover:text-brand-500 transition-colors">
                    <svg id="wishlist-link-icon" class="w-4 h-4 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                         fill="@(Model.IsInWishlist ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <span id="wishlist-link-text">@(Model.IsInWishlist ? "In your wishlist" : "Add to wishlist")</span>
                </button>

                <div class="border-t border-neutral-100 mt-5 pt-5 space-y-1.5 text-sm">
                    @if (!string.IsNullOrEmpty(Model.Sku))
                    {
                        <p class="text-neutral-500">SKU: <span class="text-neutral-700">@Model.Sku</span></p>
                    }
                    <p class="text-neutral-500">Category:
                        <a asp-controller="Products" asp-action="Index" asp-route-category="@Model.CategorySlug"
                           class="text-neutral-700 hover:text-brand-500 transition-colors">@Model.CategoryName</a>
                    </p>
                </div>
            </div>

            <!-- ─── Specifications ─────────────────────────────────────── -->
            @{
                // Only show static colour detail if there are NO variants (variants show it interactively above)
                var showColourDetail = !Model.Variants.Any() && !string.IsNullOrEmpty(Model.Metal);
                var showDetails = showColourDetail || !string.IsNullOrEmpty(Model.Weight);
            }
            @if (showDetails)
            {
                <div class="border-t border-neutral-100 pt-8">
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-4">Details</p>
                    <dl class="space-y-2">
                        @if (showColourDetail)
                        {
                            <div class="flex justify-between text-sm">
                                <dt class="text-neutral-500 font-light">Colour</dt>
                                <dd class="text-neutral-800">@Model.Metal</dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Weight))
                        {
                            <div class="flex justify-between text-sm">
                                <dt class="text-neutral-500 font-light">Weight</dt>
                                <dd class="text-neutral-800">@Model.Weight</dd>
                            </div>
                        }
                    </dl>
                </div>
            }
        </div>
    </div>

    <!-- ─── Product Tabs ──────────────────────────────────────────────────── -->
    <div class="mt-20 border-t border-neutral-100 pt-10" id="product-tabs">
        <div class="flex justify-center gap-8 border-b border-neutral-100 mb-8">
            <button type="button" data-tab="description"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-brand-500 text-neutral-900 transition-colors">
                Description
            </button>
            <button type="button" data-tab="reviews"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-transparent text-neutral-400 hover:text-neutral-700 transition-colors">
                Reviews (@Model.ReviewCount)
            </button>
            <button type="button" data-tab="shipping"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-transparent text-neutral-400 hover:text-neutral-700 transition-colors">
                Shipping &amp; Return Policy
            </button>
        </div>

        <div class="max-w-3xl mx-auto">
            <!-- Description -->
            <div class="prod-tab-panel" data-panel="description">
                @if (!string.IsNullOrWhiteSpace(fullDescription))
                {
                    if (SterlingLams.Web.Services.ProductHtml.LooksLikeHtml(fullDescription))
                    {
                        <div class="prod-rich-desc text-sm text-neutral-600 leading-relaxed font-light break-words">@Html.Raw(SterlingLams.Web.Services.ProductHtml.Sanitize(fullDescription))</div>
                    }
                    else
                    {
                        <div class="text-sm text-neutral-600 leading-relaxed font-light break-words" style="white-space: pre-line;">@fullDescription</div>
                    }
                }
                else
                {
                    <p class="text-sm text-neutral-400">No description available for this product.</p>
                }
            </div>

            <!-- Reviews -->
            <div class="prod-tab-panel hidden" data-panel="reviews">
                @if (TempData["ReviewSuccess"] != null)
                {
                    <div class="mb-6 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-md">@TempData["ReviewSuccess"]</div>
                }
                @if (TempData["ReviewError"] != null)
                {
                    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-md">@TempData["ReviewError"]</div>
                }

                @if (Model.ReviewCount > 0)
                {
                    <div class="flex flex-col sm:flex-row gap-8 items-center sm:items-start mb-10">
                        <div class="text-center shrink-0">
                            <div class="text-5xl font-light text-neutral-900">@Model.AverageRating.ToString("0.0")</div>
                            <div class="text-base leading-none mt-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= Math.Round(Model.AverageRating) ? "text-brand-500" : "text-neutral-300")">★</span>
                                }
                            </div>
                            <div class="text-xs text-neutral-400 mt-2">@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s")</div>
                        </div>
                        <div class="flex-1 w-full space-y-1.5">
                            @for (int s = 5; s >= 1; s--)
                            {
                                var c = Model.RatingBreakdown.GetValueOrDefault(s);
                                var pct = Model.ReviewCount > 0 ? (int)Math.Round(c * 100.0 / Model.ReviewCount) : 0;
                                <div class="flex items-center gap-3 text-xs text-neutral-500">
                                    <span class="w-10 whitespace-nowrap">@s ★</span>
                                    <div class="flex-1 bg-neutral-100 h-2 rounded-full overflow-hidden"><div class="bg-brand-500 h-2" style="width:@pct%"></div></div>
                                    <span class="w-6 text-right">@c</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.CanReview)
                {
                    @if (Model.HasReviewed)
                    {
                        <p class="text-sm text-neutral-500 mb-8">You've already reviewed this product — thank you!</p>
                    }
                    else
                    {
                        <form asp-controller="Reviews" asp-action="Submit" method="post" class="mb-10 bg-stone-50 p-6 rounded-md">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="slug" value="@Model.Slug" />
                            <h3 class="text-sm font-medium text-neutral-800 mb-3">Write a review</h3>
                            <div id="star-input" class="flex gap-1 text-2xl text-neutral-300 mb-3" data-rating="0">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <button type="button" class="star-pick leading-none hover:text-brand-400 transition-colors" data-val="@i" aria-label="@i stars">★</button>
                                }
                            </div>
                            <input type="hidden" name="rating" id="review-rating" value="0" />
                            <input name="title" maxlength="120" placeholder="Add a title (optional)" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm mb-3 focus:outline-none focus:border-brand-400" />
                            <textarea name="body" rows="4" required maxlength="2000" placeholder="Share your thoughts about this piece…" class="w-full border border-neutral-200 rounded-md px-3 py-2 text-sm mb-3 focus:outline-none focus:border-brand-400"></textarea>
                            <button type="submit" class="bg-brand-500 text-white text-xs tracking-[0.2em] uppercase px-8 py-3 rounded-md hover:bg-brand-600 transition-colors">Submit review</button>
                        </form>
                    }
                }
                else
                {
                    <p class="text-sm text-neutral-500 mb-8 text-center">
                        <a href="/Account/Login?returnUrl=@Uri.EscapeDataString("/products/" + Model.Slug)" class="text-brand-600 underline underline-offset-2">Sign in</a> to write a review.
                    </p>
                }

                @if (Model.Reviews.Any())
                {
                    <div class="space-y-6">
                        @foreach (var r in Model.Reviews)
                        {
                            <div class="border-b border-neutral-100 pb-5 last:border-0">
                                <div class="flex items-center justify-between">
                                    <div class="text-sm leading-none">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span class="@(i <= r.Rating ? "text-brand-500" : "text-neutral-300")">★</span>
                                        }
                                    </div>
                                    <span class="text-xs text-neutral-400">@r.CreatedAt.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="flex items-center gap-2 mt-1.5">
                                    <span class="text-sm font-medium text-neutral-800">@r.AuthorName</span>
                                    @if (r.IsVerifiedBuyer)
                                    {
                                        <span class="text-[10px] bg-emerald-50 text-emerald-600 px-2 py-0.5 rounded-full">Verified buyer</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(r.Title))
                                {
                                    <p class="text-sm font-medium text-neutral-800 mt-2">@r.Title</p>
                                }
                                <p class="text-sm text-neutral-600 mt-1 leading-relaxed whitespace-pre-line">@r.Body</p>
                                @if (!string.IsNullOrWhiteSpace(r.AdminReply))
                                {
                                    <div class="mt-3 ml-4 bg-stone-50 border-l-2 border-brand-300 p-3 rounded">
                                        <span class="text-xs font-medium text-neutral-500">Sterlin Glams replied</span>
                                        <p class="text-sm text-neutral-600 mt-1">@r.AdminReply</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-neutral-400 text-center">No reviews yet. Be the first to review &ldquo;@Model.Name&rdquo;.</p>
                }
            </div>

            <!-- Shipping & Return Policy -->
            <div class="prod-tab-panel hidden" data-panel="shipping">
                @if (!string.IsNullOrWhiteSpace(shippingPolicy))
                {
                    <div class="text-sm text-neutral-600 leading-relaxed font-light break-words" style="white-space: pre-line;">@shippingPolicy</div>
                }
                else
                {
                    <p class="text-sm text-neutral-400">Shipping & return details are available at checkout.</p>
                }
            </div>
        </div>
    </div>

    <!-- ─── Frequently Bought Together ────────────────────────────────────── -->
    @if (Model.FrequentlyBoughtTogether.Any())
    {
        <div class="mt-24">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-3">Pairs well with</p>
                <h2 class="font-cormorant text-3xl font-light">Frequently Bought Together</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var p in Model.FrequentlyBoughtTogether)
                {
                    <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug" class="group">
                        <div class="aspect-square bg-neutral-50 mb-3 overflow-hidden">
                            <img src="@p.PrimaryImageUrl" alt="@p.Name"
                                 loading="lazy" width="400" height="400"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <h3 class="text-sm font-light text-neutral-700 group-hover:text-neutral-900 transition-colors">@p.Name</h3>
                        @if (p.IsOnSale)
                        {
                            <p class="text-xs mt-1"><span class="text-brand-600">@p.FormattedPrice</span> <span class="text-neutral-400 line-through ml-1">@p.FormattedRegularPrice</span></p>
                        }
                        else
                        {
                            <p class="text-xs text-neutral-400 mt-1">@p.FormattedPrice</p>
                        }
                    </a>
                }
            </div>
        </div>
    }

    <!-- ─── Related Products ──────────────────────────────────────────────── -->
    @if (Model.RelatedProducts.Any())
    {
        <div class="mt-24">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-3">You may also like</p>
                <h2 class="font-cormorant text-3xl font-light">Related Pieces</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var p in Model.RelatedProducts)
                {
                    <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug" class="group">
                        <div class="aspect-square bg-neutral-50 mb-3 overflow-hidden">
                            <img src="@p.PrimaryImageUrl" alt="@p.Name"
                                 loading="lazy" width="400" height="400"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <h3 class="text-sm font-light text-neutral-700 group-hover:text-neutral-900 transition-colors">@p.Name</h3>
                        @if (p.IsOnSale)
                        {
                            <p class="text-xs mt-1"><span class="text-brand-600">@p.FormattedPrice</span> <span class="text-neutral-400 line-through ml-1">@p.FormattedRegularPrice</span></p>
                        }
                        else
                        {
                            <p class="text-xs text-neutral-400 mt-1">@p.FormattedPrice</p>
                        }
                    </a>
                }
            </div>
        </div>
    }
</div>

@if (showSizeGuide)
{
    <partial name="_SizeGuideModal" />
}

@* Sticky mobile buy bar — keeps price + Add to Bag reachable without scrolling past the gallery. *@
@if (Model.IsAvailableAnywhere)
{
    <div id="sticky-buy" class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-white/95 backdrop-blur border-t border-neutral-200 px-4 py-3 flex items-center gap-3" style="box-shadow:0 -2px 12px rgba(0,0,0,0.06);">
        <div class="min-w-0">
            <div class="text-[10px] uppercase tracking-wide text-neutral-400 leading-none truncate">@Model.CategoryName</div>
            <div id="sticky-price" class="text-base font-semibold text-neutral-900 leading-tight">@Model.FormattedPrice</div>
        </div>
        <button id="sticky-add" type="button"
                class="flex-1 bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-3 rounded-sm hover:bg-brand-600 active:bg-brand-700 transition-colors">
            Add to Bag
        </button>
    </div>
    <div class="h-20 md:hidden" aria-hidden="true"></div> @* spacer so content isn't hidden behind the bar *@
}

@section Scripts {
<script nonce="@Context.Items["csp-nonce"]">
(function () {
    let selectedVariantId = null;
    let qty = 1;

    // ── Image zoom: desktop = move-to-zoom; touch/mobile = tap to open fullscreen lightbox ──
    const zoomContainer = document.getElementById('zoom-container');
    const mainImg = document.getElementById('main-image');
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    if (zoomContainer && mainImg && canHover) {
        // Desktop: hover anywhere on the image to zoom into that point.
        zoomContainer.addEventListener('mousemove', (e) => {
            const rect = zoomContainer.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            mainImg.style.transformOrigin = `${x}% ${y}%`;
            mainImg.style.transform = 'scale(1.9)';
        });
        zoomContainer.addEventListener('mouseleave', () => {
            mainImg.style.transform = 'scale(1)';
            mainImg.style.transformOrigin = 'center center';
        });
    }

    // Touch/mobile: tap the image to open a swipeable fullscreen viewer.
    const lightbox = document.getElementById('img-lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    if (zoomContainer && mainImg && lightbox && lightboxImg && !canHover) {
        zoomContainer.classList.remove('cursor-zoom-in');
        const thumbs = Array.from(document.querySelectorAll('.thumb-btn'));
        const images = thumbs.length ? thumbs.map(b => b.getAttribute('data-img-url'))
                                     : [mainImg.getAttribute('src')];
        const counter = document.getElementById('lightbox-counter');
        let idx = 0;
        const show = (i) => {
            idx = (i + images.length) % images.length;
            lightboxImg.src = images[idx];
            if (counter) counter.textContent = (idx + 1) + ' / ' + images.length;
        };
        const open = () => {
            const cur = images.indexOf(mainImg.getAttribute('src'));
            show(cur >= 0 ? cur : 0);
            lightbox.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        };
        const close = () => {
            lightbox.classList.add('hidden');
            document.body.style.overflow = '';
        };
        zoomContainer.addEventListener('click', open);
        document.getElementById('lightbox-close')?.addEventListener('click', close);
        document.getElementById('lightbox-prev')?.addEventListener('click', () => show(idx - 1));
        document.getElementById('lightbox-next')?.addEventListener('click', () => show(idx + 1));
        // Tap the dark area (not the image/controls) to close.
        lightbox.addEventListener('click', (e) => {
            if (e.target.id === 'img-lightbox' || e.target.id === 'lightbox-stage') close();
        });
        // Swipe left/right to change image.
        let startX = 0;
        lightbox.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
        lightbox.addEventListener('touchend', (e) => {
            const dx = e.changedTouches[0].clientX - startX;
            if (Math.abs(dx) > 50 && images.length > 1) show(dx < 0 ? idx + 1 : idx - 1);
        }, { passive: true });
    }

    // ── Thumbnail switch ──────────────────────────────────────────────────────
    window.switchMainImage = function(url, btn) {
        if (mainImg) {
            mainImg.style.transform = 'scale(1)';
            mainImg.src = url;
        }
        document.querySelectorAll('.thumb-btn').forEach(b => {
            b.classList.remove('border-brand-500');
            b.classList.add('border-transparent');
        });
        btn.classList.remove('border-transparent');
        btn.classList.add('border-brand-500');
    };

    // ── Qty selector ──────────────────────────────────────────────────────
    const qtyDisplay = document.getElementById('qty-display');
    document.getElementById('qty-minus')?.addEventListener('click', () => {
        if (qty > 1) { qty--; qtyDisplay.textContent = qty; }
    });
    document.getElementById('qty-plus')?.addEventListener('click', () => {
        if (qty < 10) { qty++; qtyDisplay.textContent = qty; }
    });

    // ── Dropdown-based variant selection ──────────────────────────────────────
    const variantsDataEl = document.getElementById('variants-data');
    const variants    = variantsDataEl ? JSON.parse(variantsDataEl.textContent) : [];
    const selectedAttrs = {};
    const hasVariants = document.getElementById('add-to-cart')?.dataset.hasVariants === 'true';

    // Base price + sale (for live price update when a priced variant is chosen).
    const PRICE = {
        regular: @Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture),
        sale: @(Model.IsOnSale ? Model.SalePrice!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null")
    };
    const priceEff = document.getElementById('price-effective');
    const priceReg = document.getElementById('price-regular');
    const fmtPrice = n => '₦' + Math.round(n).toLocaleString('en-US');
    const defaultImg = mainImg ? mainImg.getAttribute('src') : null;

    // Swap the main image to a selected variant's image (e.g. pick "Gold" → gold photo).
    // Works on partial selection: shows the first variant matching the chosen attributes.
    function applyVariantImage() {
        if (!mainImg) return;
        const entries = Object.entries(selectedAttrs);
        let url = defaultImg;
        if (entries.length) {
            const match = variants.find(v => v.imageUrl && entries.every(([k, val]) => v.attributes[k] === val));
            if (match) url = match.imageUrl;
        }
        if (!url || mainImg.getAttribute('src') === url) return;
        mainImg.style.transform = 'scale(1)';
        mainImg.src = url;
        document.querySelectorAll('.thumb-btn').forEach(b => {
            const on = b.getAttribute('data-img-url') === url;
            b.classList.toggle('border-brand-500', on);
            b.classList.toggle('border-transparent', !on);
        });
    }

    // Re-price using the resolved variant's adjustment (regular + sale both shift).
    function applyVariantPrice() {
        if (!priceEff) return;
        let adj = 0;
        if (selectedVariantId) {
            const v = variants.find(x => x.id === selectedVariantId);
            if (v && v.priceAdjustment) adj = v.priceAdjustment;
        }
        const reg = PRICE.regular + adj;
        if (PRICE.sale != null) {
            priceEff.textContent = fmtPrice(PRICE.sale + adj);
            if (priceReg) { priceReg.textContent = fmtPrice(reg); priceReg.classList.remove('hidden'); }
        } else {
            priceEff.textContent = fmtPrice(reg);
            if (priceReg) priceReg.classList.add('hidden');
        }
    }

    // Per-branch stock display for the chosen variant.
    const stockList = document.getElementById('store-stock-list');
    const stockPrompt = document.getElementById('stock-prompt');
    const escHtml = s => { const d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML; };
    function renderVariantStock(stores) {
        if (!stockList) return;
        stockList.innerHTML = (stores || []).map(s => {
            const dot = s.qty === 0 ? 'bg-neutral-300' : (s.low ? 'bg-amber-500' : 'bg-emerald-500');
            const right = s.qty > 0
                ? '<span class="text-xs font-medium px-2.5 py-1 rounded-full whitespace-nowrap ' + (s.low ? 'bg-amber-50 text-amber-700' : 'bg-emerald-50 text-emerald-700') + '">' + s.qty + ' in stock</span>'
                : '<span class="text-xs px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-400 whitespace-nowrap">Out of stock</span>';
            return '<div class="flex items-center justify-between rounded-lg border border-neutral-100 px-4 py-3 transition-colors hover:border-neutral-200">'
                 + '<span class="flex items-center gap-2.5 min-w-0"><span class="w-2 h-2 rounded-full flex-shrink-0 ' + dot + '"></span>'
                 + '<span class="text-sm text-neutral-700 truncate">' + escHtml(s.name) + '</span></span>' + right + '</div>';
        }).join('');
        stockList.classList.remove('hidden');
        stockPrompt?.classList.add('hidden');
    }
    function resetVariantStock() {
        stockList?.classList.add('hidden');
        stockPrompt?.classList.remove('hidden');
    }

    // Variant dropdown change handler (wired via addEventListener below — CSP-safe).
    window.onAttrSelectChange = function(attr, val) {
        if (val) selectedAttrs[attr] = val;
        else     delete selectedAttrs[attr];

        document.getElementById('select-colour-prompt')?.classList.add('hidden');

        const allSelects = document.querySelectorAll('.attr-select');
        const allPicked  = [...allSelects].every(s => s.value !== '');

        if (allPicked) {
            const match = variants.find(v =>
                Object.entries(selectedAttrs).every(([k, v2]) => v.attributes[k] === v2)
            );
            if (match) {
                selectedVariantId = match.id;
                // Low-stock nudge follows the chosen variant, now with the exact count.
                const nudge = document.getElementById('low-stock-nudge');
                const nudgeText = document.getElementById('low-stock-text');
                if (nudgeText) {
                    nudgeText.textContent = (match.available > 0)
                        ? `Only ${match.available} left — order soon`
                        : 'Low stock — order soon';
                }
                nudge?.classList.toggle('hidden', !match.lowStock);
                renderVariantStock(match.stores);
                // The main price (below) already updates to this variant's full price via
                // applyVariantPrice(), so no separate "+₦X for this option" note is needed.
            } else {
                selectedVariantId = null;
                resetVariantStock();
            }
        } else {
            selectedVariantId = null;
            resetVariantStock();
        }

        applyVariantImage();
        applyVariantPrice();
    }

    // Validate all dropdowns are selected — and that the chosen variant is in stock — before add-to-cart
    document.getElementById('add-to-cart')?.addEventListener('click', function(e) {
        const prompt = document.getElementById('select-colour-prompt');
        if (hasVariants && !selectedVariantId) {
            e.stopImmediatePropagation();
            if (prompt) { prompt.textContent = 'Please select all options before adding to bag.'; prompt.classList.remove('hidden'); }
            document.getElementById('variant-selectors')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            return false;
        }
        if (hasVariants && selectedVariantId) {
            const v = variants.find(x => x.id === selectedVariantId);
            if (v && !v.inStock) {
                e.stopImmediatePropagation();
                if (prompt) { prompt.textContent = 'Sorry, this option is out of stock.'; prompt.classList.remove('hidden'); }
                return false;
            }
        }
    }, true);

    // ── Add to cart ───────────────────────────────────────────────────────────
    document.getElementById('add-to-cart')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        btn.disabled = true;
        btn.textContent = 'Adding…';

        const productId = @Model.Id;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const body = new URLSearchParams({ productId, quantity: qty, __RequestVerificationToken: token });
        if (selectedVariantId) body.append('variantId', selectedVariantId);

        try {
            const res  = await fetch('/Cart/Add', { method: 'POST', body });
            const data = res.ok ? await res.json().catch(() => null) : null;
            if (data && data.success) {
                updateCartBadge(data.cartCount);
                showToast(`Added to bag — ${qty > 1 ? qty + ' items' : '@Model.Name'}`);
            } else {
                showToast((data && data.message) || 'Sorry, we couldn’t add this to your bag.');
            }
        } catch {
            showToast('Sorry, we couldn’t add this to your bag.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Add to Bag';
        }
    });

    // ── Wishlist toggle ───────────────────────────────────────────────────────
    async function toggleWishlist() {
        const productId = @Model.Id;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res = await fetch('/Wishlist/Toggle', { method: 'POST', body: new URLSearchParams({ productId, __RequestVerificationToken: token }) });
        const data = await res.json();
        if (data.success) location.reload();
    }
    document.getElementById('wishlist-btn')?.addEventListener('click', toggleWishlist);
    document.getElementById('wishlist-link')?.addEventListener('click', toggleWishlist);

    // ── Product tabs (Description / Reviews / Shipping & Return Policy) ─────────
    document.querySelectorAll('.prod-tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const target = btn.dataset.tab;
            document.querySelectorAll('.prod-tab-btn').forEach(b => {
                const active = b === btn;
                b.classList.toggle('border-brand-500', active);
                b.classList.toggle('text-neutral-900', active);
                b.classList.toggle('border-transparent', !active);
                b.classList.toggle('text-neutral-400', !active);
            });
            document.querySelectorAll('.prod-tab-panel').forEach(p => {
                p.classList.toggle('hidden', p.dataset.panel !== target);
            });
        });
    });

    // Jump to the Reviews tab from the star summary near the title.
    document.querySelectorAll('[data-tab-jump]').forEach(el => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            document.querySelector('.prod-tab-btn[data-tab="' + el.dataset.tabJump + '"]')?.click();
            document.getElementById('product-tabs')?.scrollIntoView({ behavior: 'smooth' });
        });
    });

    // Review star picker.
    (function () {
        const wrap = document.getElementById('star-input');
        if (!wrap) return;
        const input = document.getElementById('review-rating');
        const stars = [...wrap.querySelectorAll('.star-pick')];
        function paint(n) { stars.forEach((s, i) => s.classList.toggle('text-brand-500', i < n)); }
        stars.forEach(s => {
            s.addEventListener('mouseenter', () => paint(+s.dataset.val));
            s.addEventListener('click', () => { input.value = s.dataset.val; wrap.dataset.rating = s.dataset.val; });
        });
        wrap.addEventListener('mouseleave', () => paint(+wrap.dataset.rating || 0));
    })();

    // If we just submitted (or arrived at #reviews), open the Reviews tab.
    if (location.hash === '#reviews' || @( (TempData["ReviewSuccess"] != null || TempData["ReviewError"] != null) ? "true" : "false" )) {
        document.querySelector('.prod-tab-btn[data-tab="reviews"]')?.click();
    }

    // ── Back-in-stock notify form ─────────────────────────────────────────────
    document.getElementById('notify-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.currentTarget;
        const btn = form.querySelector('button[type="submit"]');
        const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        btn.disabled = true;
        btn.textContent = 'Saving…';
        try {
            await fetch('/Products/NotifyRestock', {
                method: 'POST',
                body: new URLSearchParams({
                    productId: form.productId.value,
                    email: form.email.value,
                    __RequestVerificationToken: token
                })
            });
            document.getElementById('notify-success')?.classList.remove('hidden');
            form.email.value = '';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Notify Me';
        }
    });

    // CSP-safe wiring (replaces inline onclick/onchange on thumbnails + variant selects).
    document.querySelectorAll('.thumb-btn').forEach(t =>
        t.addEventListener('click', () => window.switchMainImage(t.dataset.imgUrl, t)));
    document.querySelectorAll('.attr-select').forEach(s =>
        s.addEventListener('change', () => window.onAttrSelectChange(s.dataset.attr, s.value)));

    // ── Sticky mobile buy bar ──────────────────────────────────────────────
    (function () {
        const stickyAdd = document.getElementById('sticky-add');
        if (!stickyAdd) return;
        const stickyPrice = document.getElementById('sticky-price');
        const mainAdd = document.getElementById('add-to-cart');
        const priceEl = document.getElementById('price-effective');
        const variantsWrap = document.getElementById('variant-selectors');

        // Keep the sticky price in sync with the main price (which updates on variant change).
        if (priceEl && stickyPrice) {
            new MutationObserver(() => { stickyPrice.textContent = priceEl.textContent; })
                .observe(priceEl, { childList: true, characterData: true, subtree: true });
        }

        stickyAdd.addEventListener('click', () => {
            if (mainAdd) mainAdd.click();   // reuse ALL existing logic (variant validation, stock, toast)
            // If the main button flagged "select options", bring the picker into view.
            const prompt = document.getElementById('select-colour-prompt');
            if (variantsWrap && prompt && !prompt.classList.contains('hidden')) {
                variantsWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    })();
})();
</script>
}
