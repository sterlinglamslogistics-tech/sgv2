@model SterlingLams.Web.Models.ViewModels.ProductDetailViewModel
@using SterlingLams.Web.Services
@inject ISettingsService SettingsService
@{
    ViewData["Title"] = Model.Name;
    ViewData["Description"] = Model.ShortDescription;
    ViewData["OgType"] = "product";
    ViewData["OgImage"] = Model.ImageUrls.FirstOrDefault();
    Layout = "_Layout";

    var fullDescription = !string.IsNullOrWhiteSpace(Model.Description)
        ? Model.Description
        : (Model.ShortDescription ?? "");
    var shippingPolicy = await SettingsService.GetAsync("shipping.returns_policy", "");

    // ── Structured data (Product + breadcrumbs) ──────────────────────────────
    var sdReq = Context.Request;
    var sdBase = $"{sdReq.Scheme}://{sdReq.Host}";
    var sdUrl = sdBase + sdReq.Path;
    string SdAbs(string u) => string.IsNullOrEmpty(u) ? u : (u.StartsWith("/") ? sdBase + u : u);
    var jsonOpts = new System.Text.Json.JsonSerializerOptions
    {
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };
    var productLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org/",
        ["@type"] = "Product",
        ["name"] = Model.Name,
        ["image"] = Model.ImageUrls.Select(SdAbs).ToArray(),
        ["description"] = string.IsNullOrWhiteSpace(fullDescription) ? Model.Name : fullDescription,
        ["sku"] = string.IsNullOrWhiteSpace(Model.Sku) ? null : Model.Sku,
        ["brand"] = new Dictionary<string, object?> { ["@type"] = "Brand", ["name"] = "Sterlin Glams" },
        ["category"] = Model.CategoryName,
        ["offers"] = new Dictionary<string, object?>
        {
            ["@type"] = "Offer",
            ["url"] = sdUrl,
            ["priceCurrency"] = Model.Currency,
            ["price"] = Model.Price,
            ["availability"] = Model.IsAvailableAnywhere ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
            ["itemCondition"] = "https://schema.org/NewCondition",
        },
    }, jsonOpts);
    var breadcrumbLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new object[]
        {
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Home", ["item"] = sdBase },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = Model.CategoryName, ["item"] = $"{sdBase}/products?category={Model.CategorySlug}" },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 3, ["name"] = Model.Name, ["item"] = sdUrl },
        },
    }, jsonOpts);
}

@section Head {
    <script type="application/ld+json">@Html.Raw(productLd)</script>
    <script type="application/ld+json">@Html.Raw(breadcrumbLd)</script>
}

@* Antiforgery token for the AJAX POSTs on this page (Add to Bag, wishlist, notify-restock).
   Rendering it here also sets the antiforgery cookie, which CartController's
   [ValidateAntiForgeryToken] requires. *@
@Html.AntiForgeryToken()

<div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-neutral-400 tracking-wider mb-10 flex gap-2 items-center">
        <a asp-controller="Home" asp-action="Index" class="hover:text-neutral-700 transition-colors">Home</a>
        <span>/</span>
        <a asp-controller="Products" asp-action="Index" asp-route-category="@Model.CategorySlug" class="hover:text-neutral-700 transition-colors">@Model.CategoryName</a>
        <span>/</span>
        <span class="text-neutral-700">@Model.Name</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-16 lg:gap-24">

        <!-- ─── Image Gallery ─────────────────────────────────────────── -->
        <div class="space-y-3">
            <!-- Zoom container: hover to zoom, click to toggle pinned zoom -->
            <div class="aspect-square bg-neutral-50 overflow-hidden zoom-container cursor-zoom-in" id="zoom-container">
                <img id="main-image" src="@Model.PrimaryImageUrl" alt="@Model.Name"
                     class="w-full h-full object-cover object-center transition-transform duration-300 will-change-transform" />
            </div>
            @if (Model.ImageUrls.Count > 1)
            {
                <div class="grid grid-cols-4 gap-2">
                    @foreach (var (url, i) in Model.ImageUrls.Select((u, i) => (u, i)))
                    {
                        <button onclick="switchMainImage('@url', this)"
                                class="thumb-btn aspect-square bg-neutral-50 overflow-hidden border-2 @(i == 0 ? "border-brand-500" : "border-transparent") hover:border-brand-300 transition-colors">
                            <img src="@url" alt="@Model.Name view @(i+1)" class="w-full h-full object-cover" />
                        </button>
                    }
                </div>
            }
        </div>

        <!-- ─── Product Info ──────────────────────────────────────────── -->
        <div class="flex flex-col">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-2">@Model.CategoryName</p>
            <h1 class="font-cormorant text-4xl font-light text-neutral-900 mb-4">@Model.Name</h1>
            <p class="text-2xl font-light text-neutral-800 mb-8">@Model.FormattedPrice</p>

            @if (!string.IsNullOrEmpty(Model.ShortDescription))
            {
                <p class="text-sm text-neutral-500 leading-relaxed mb-8 font-light">@Model.ShortDescription</p>
            }

            <!-- ─── Store Stock ────────────────────────────────────────── -->
            @if (Model.StoreStock.Any())
            {
                <div class="mb-8">
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-4">Availability</p>
                    <div class="space-y-2">
                        @foreach (var store in Model.StoreStock)
                        {
                            <div class="flex items-center justify-between py-2.5 border-b border-neutral-100">
                                <span class="text-sm text-neutral-700">@store.StoreName</span>
                                @if (store.IsAvailable)
                                {
                                    <span class="text-xs text-emerald-700 tracking-wider">
                                        @store.Quantity in stock
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs text-neutral-400 tracking-wider">Out of stock</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ─── Variants / Option Selector ───────────────────────── -->
            @if (Model.Variants.Any())
            {
                var attributeNames = Model.Variants
                    .SelectMany(v => v.AttributeLabels.Select(a => a.AttributeName))
                    .Distinct().ToList();

                <div class="mb-8 space-y-4" id="variant-selectors">
                    @foreach (var attrName in attributeNames)
                    {
                        var distinctValues = Model.Variants
                            .SelectMany(v => v.AttributeLabels.Where(a => a.AttributeName == attrName))
                            .GroupBy(a => a.Value)
                            .Select(g => g.First())
                            .ToList();

                        <div>
                            <label class="block text-xs tracking-[0.2em] uppercase text-neutral-500 mb-2">
                                @attrName
                            </label>
                            <select class="attr-select w-full border border-neutral-300 px-4 py-3 text-sm text-neutral-700
                                           focus:outline-none focus:border-neutral-900 bg-white transition-colors appearance-none
                                           cursor-pointer"
                                    data-attr="@attrName"
                                    onchange="onAttrSelectChange('@attrName', this.value)">
                                <option value="">— Select @attrName —</option>
                                @foreach (var val in distinctValues)
                                {
                                    <option value="@val.Value">@val.Value</option>
                                }
                            </select>
                        </div>
                    }

                    <input type="hidden" id="selected-variant-id" value="" />
                    <p id="variant-price-adj" class="text-xs text-neutral-400 hidden"></p>
                    <p id="select-colour-prompt" class="text-xs text-amber-600 hidden">
                        Please select all options before adding to bag.
                    </p>
                </div>

                <script id="variants-data" type="application/json">
                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Variants.Select(v => new {
                        id = v.Id,
                        name = v.Name,
                        priceAdjustment = v.PriceAdjustment,
                        available = v.Available,
                        attributes = v.AttributeLabels.ToDictionary(a => a.AttributeName, a => a.Value)
                    })))
                </script>
            }

            <!-- ─── Actions ───────────────────────────────────────────── -->
            <div class="mb-8">
                @if (Model.IsAvailableAnywhere)
                {
                    <!-- Quantity -->
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-3">Quantity</p>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="flex items-center border border-neutral-300">
                            <button id="qty-minus" type="button"
                                    class="w-10 h-10 flex items-center justify-center text-neutral-600 hover:bg-neutral-50 transition-colors text-lg leading-none">−</button>
                            <span id="qty-display" class="w-12 text-center text-sm border-x border-neutral-300 py-2">1</span>
                            <button id="qty-plus" type="button"
                                    class="w-10 h-10 flex items-center justify-center text-neutral-600 hover:bg-neutral-50 transition-colors text-lg leading-none">+</button>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button id="add-to-cart"
                                data-product-id="@Model.Id"
                                data-has-variants="@(Model.Variants.Any() ? "true" : "false")"
                                class="flex-1 bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-4 px-8 hover:bg-brand-600 transition-colors duration-300">
                            Add to Bag
                        </button>
                        <button id="wishlist-btn"
                                data-product-id="@Model.Id"
                                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                                class="border border-neutral-300 px-4 hover:border-brand-500 hover:text-brand-500 transition-colors">
                            <svg class="w-5 h-5 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                                 fill="@(Model.IsInWishlist ? "currentColor" : "none")"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <!-- Out of stock — back-in-stock email capture -->
                    <div class="border border-neutral-200 p-6 bg-neutral-50">
                        <p class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-1">Currently Unavailable</p>
                        <p class="text-sm text-neutral-500 font-light mb-5">
                            This piece is out of stock. Enter your email and we'll notify you the moment it's back.
                        </p>
                        <form id="notify-form" class="flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="email" name="email" required
                                   placeholder="your@email.com"
                                   class="flex-1 border border-neutral-300 px-4 py-3 text-sm focus:outline-none focus:border-brand-500 transition-colors" />
                            <button type="submit"
                                    class="bg-brand-500 text-white text-xs tracking-[0.15em] uppercase px-6 py-3 hover:bg-brand-600 transition-colors whitespace-nowrap">
                                Notify Me
                            </button>
                        </form>
                        <p id="notify-success" class="hidden text-xs text-emerald-600 mt-3 tracking-wide">
                            You're on the list! We'll email you when this item is restocked.
                        </p>
                    </div>
                    <div class="flex gap-3 mt-4">
                        <button disabled
                                class="flex-1 bg-neutral-200 text-neutral-400 text-xs tracking-[0.2em] uppercase py-4 px-8 cursor-not-allowed">
                            Out of Stock
                        </button>
                        <button id="wishlist-btn"
                                data-product-id="@Model.Id"
                                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                                class="border border-neutral-300 px-4 hover:border-brand-500 hover:text-brand-500 transition-colors">
                            <svg class="w-5 h-5 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                                 fill="@(Model.IsInWishlist ? "currentColor" : "none")"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>

            <!-- ─── Wishlist link + meta (SKU / Category) ──────────────── -->
            <div class="mb-8">
                <button id="wishlist-link" type="button" data-product-id="@Model.Id"
                        class="inline-flex items-center gap-2 text-sm text-neutral-600 hover:text-brand-500 transition-colors">
                    <svg id="wishlist-link-icon" class="w-4 h-4 @(Model.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                         fill="@(Model.IsInWishlist ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <span id="wishlist-link-text">@(Model.IsInWishlist ? "In your wishlist" : "Add to wishlist")</span>
                </button>

                <div class="border-t border-neutral-100 mt-5 pt-5 space-y-1.5 text-sm">
                    @if (!string.IsNullOrEmpty(Model.Sku))
                    {
                        <p class="text-neutral-500">SKU: <span class="text-neutral-700">@Model.Sku</span></p>
                    }
                    <p class="text-neutral-500">Category:
                        <a asp-controller="Products" asp-action="Index" asp-route-category="@Model.CategorySlug"
                           class="text-neutral-700 hover:text-brand-500 transition-colors">@Model.CategoryName</a>
                    </p>
                </div>
            </div>

            <!-- Reserve for pickup -->
            <a asp-controller="Checkout" asp-action="Index"
               class="text-center text-xs tracking-[0.2em] uppercase border border-neutral-300 py-4 hover:border-neutral-900 transition-colors mb-8 block">
                Reserve for Store Pickup
            </a>

            <!-- ─── Specifications ─────────────────────────────────────── -->
            @{
                // Only show static colour detail if there are NO variants (variants show it interactively above)
                var showColourDetail = !Model.Variants.Any() && !string.IsNullOrEmpty(Model.Metal);
                var showDetails = showColourDetail || !string.IsNullOrEmpty(Model.Weight);
            }
            @if (showDetails)
            {
                <div class="border-t border-neutral-100 pt-8">
                    <p class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-4">Details</p>
                    <dl class="space-y-2">
                        @if (showColourDetail)
                        {
                            <div class="flex justify-between text-sm">
                                <dt class="text-neutral-500 font-light">Colour</dt>
                                <dd class="text-neutral-800">@Model.Metal</dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Weight))
                        {
                            <div class="flex justify-between text-sm">
                                <dt class="text-neutral-500 font-light">Weight</dt>
                                <dd class="text-neutral-800">@Model.Weight</dd>
                            </div>
                        }
                    </dl>
                </div>
            }
        </div>
    </div>

    <!-- ─── Product Tabs ──────────────────────────────────────────────────── -->
    <div class="mt-20 border-t border-neutral-100 pt-10" id="product-tabs">
        <div class="flex justify-center gap-8 border-b border-neutral-100 mb-8">
            <button type="button" data-tab="description"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-brand-500 text-neutral-900 transition-colors">
                Description
            </button>
            <button type="button" data-tab="reviews"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-transparent text-neutral-400 hover:text-neutral-700 transition-colors">
                Reviews (0)
            </button>
            <button type="button" data-tab="shipping"
                    class="prod-tab-btn pb-3 text-xs tracking-[0.15em] uppercase border-b-2 border-transparent text-neutral-400 hover:text-neutral-700 transition-colors">
                Shipping &amp; Return Policy
            </button>
        </div>

        <div class="max-w-3xl mx-auto">
            <!-- Description -->
            <div class="prod-tab-panel" data-panel="description">
                @if (!string.IsNullOrWhiteSpace(fullDescription))
                {
                    <div class="text-sm text-neutral-600 leading-relaxed font-light" style="white-space: pre-line;">@fullDescription</div>
                }
                else
                {
                    <p class="text-sm text-neutral-400">No description available for this product.</p>
                }
            </div>

            <!-- Reviews -->
            <div class="prod-tab-panel hidden text-center py-6" data-panel="reviews">
                <p class="text-sm text-neutral-500">There are no reviews yet.</p>
                <p class="text-xs text-neutral-400 mt-1">Be the first to review &ldquo;@Model.Name&rdquo;.</p>
            </div>

            <!-- Shipping & Return Policy -->
            <div class="prod-tab-panel hidden" data-panel="shipping">
                @if (!string.IsNullOrWhiteSpace(shippingPolicy))
                {
                    <div class="text-sm text-neutral-600 leading-relaxed font-light" style="white-space: pre-line;">@shippingPolicy</div>
                }
                else
                {
                    <p class="text-sm text-neutral-400">Shipping & return details are available at checkout.</p>
                }
            </div>
        </div>
    </div>

    <!-- ─── Frequently Bought Together ────────────────────────────────────── -->
    @if (Model.FrequentlyBoughtTogether.Any())
    {
        <div class="mt-24">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-3">Pairs well with</p>
                <h2 class="font-cormorant text-3xl font-light">Frequently Bought Together</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var p in Model.FrequentlyBoughtTogether)
                {
                    <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug" class="group">
                        <div class="aspect-square bg-neutral-50 mb-3 overflow-hidden">
                            <img src="@p.PrimaryImageUrl" alt="@p.Name"
                                 loading="lazy"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <h3 class="text-sm font-light text-neutral-700 group-hover:text-neutral-900 transition-colors">@p.Name</h3>
                        <p class="text-xs text-neutral-400 mt-1">@p.FormattedPrice</p>
                    </a>
                }
            </div>
        </div>
    }

    <!-- ─── Related Products ──────────────────────────────────────────────── -->
    @if (Model.RelatedProducts.Any())
    {
        <div class="mt-24">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-3">You may also like</p>
                <h2 class="font-cormorant text-3xl font-light">Related Pieces</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var p in Model.RelatedProducts)
                {
                    <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug" class="group">
                        <div class="aspect-square bg-neutral-50 mb-3 overflow-hidden">
                            <img src="@p.PrimaryImageUrl" alt="@p.Name"
                                 loading="lazy"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <h3 class="text-sm font-light text-neutral-700 group-hover:text-neutral-900 transition-colors">@p.Name</h3>
                        <p class="text-xs text-neutral-400 mt-1">@p.FormattedPrice</p>
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
(function () {
    let selectedVariantId = null;
    let qty = 1;

    // ── Image zoom (mouse-move zoom within container) ─────────────────────────
    const zoomContainer = document.getElementById('zoom-container');
    const mainImg = document.getElementById('main-image');

    if (zoomContainer && mainImg) {
        zoomContainer.addEventListener('mousemove', (e) => {
            const rect = zoomContainer.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            mainImg.style.transformOrigin = `${x}% ${y}%`;
            mainImg.style.transform = 'scale(1.9)';
        });
        zoomContainer.addEventListener('mouseleave', () => {
            mainImg.style.transform = 'scale(1)';
            mainImg.style.transformOrigin = 'center center';
        });
    }

    // ── Thumbnail switch ──────────────────────────────────────────────────────
    window.switchMainImage = function(url, btn) {
        if (mainImg) {
            mainImg.style.transform = 'scale(1)';
            mainImg.src = url;
        }
        document.querySelectorAll('.thumb-btn').forEach(b => {
            b.classList.remove('border-brand-500');
            b.classList.add('border-transparent');
        });
        btn.classList.remove('border-transparent');
        btn.classList.add('border-brand-500');
    };

    // ── Qty selector ──────────────────────────────────────────────────────
    const qtyDisplay = document.getElementById('qty-display');
    document.getElementById('qty-minus')?.addEventListener('click', () => {
        if (qty > 1) { qty--; qtyDisplay.textContent = qty; }
    });
    document.getElementById('qty-plus')?.addEventListener('click', () => {
        if (qty < 10) { qty++; qtyDisplay.textContent = qty; }
    });

    // ── Dropdown-based variant selection ──────────────────────────────────────
    const variantsDataEl = document.getElementById('variants-data');
    const variants    = variantsDataEl ? JSON.parse(variantsDataEl.textContent) : [];
    const selectedAttrs = {};
    const hasVariants = document.getElementById('add-to-cart')?.dataset.hasVariants === 'true';

    // Exposed on window: the dropdowns call this via inline onchange="…", which
    // resolves in global scope — a plain in-IIFE function would be undefined there.
    window.onAttrSelectChange = function(attr, val) {
        if (val) selectedAttrs[attr] = val;
        else     delete selectedAttrs[attr];

        document.getElementById('select-colour-prompt')?.classList.add('hidden');

        const allSelects = document.querySelectorAll('.attr-select');
        const allPicked  = [...allSelects].every(s => s.value !== '');

        if (allPicked) {
            const match = variants.find(v =>
                Object.entries(selectedAttrs).every(([k, v2]) => v.attributes[k] === v2)
            );
            if (match) {
                selectedVariantId = match.id;
                const adjEl = document.getElementById('variant-price-adj');
                if (match.priceAdjustment && match.priceAdjustment !== 0 && adjEl) {
                    const sign = match.priceAdjustment > 0 ? '+' : '';
                    adjEl.textContent = `${sign}₦${Math.abs(match.priceAdjustment).toLocaleString()} for this option`;
                    adjEl.classList.remove('hidden');
                } else if (adjEl) {
                    adjEl.classList.add('hidden');
                }
            } else {
                selectedVariantId = null;
            }
        } else {
            selectedVariantId = null;
        }
    }

    // Validate all dropdowns are selected — and that the chosen variant is in stock — before add-to-cart
    document.getElementById('add-to-cart')?.addEventListener('click', function(e) {
        const prompt = document.getElementById('select-colour-prompt');
        if (hasVariants && !selectedVariantId) {
            e.stopImmediatePropagation();
            if (prompt) { prompt.textContent = 'Please select all options before adding to bag.'; prompt.classList.remove('hidden'); }
            document.getElementById('variant-selectors')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            return false;
        }
        if (hasVariants && selectedVariantId) {
            const v = variants.find(x => x.id === selectedVariantId);
            if (v && (v.available ?? 0) <= 0) {
                e.stopImmediatePropagation();
                if (prompt) { prompt.textContent = 'Sorry, this option is out of stock.'; prompt.classList.remove('hidden'); }
                return false;
            }
        }
    }, true);

    // ── Add to cart ───────────────────────────────────────────────────────────
    document.getElementById('add-to-cart')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        btn.disabled = true;
        btn.textContent = 'Adding…';

        const productId = @Model.Id;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const body = new URLSearchParams({ productId, quantity: qty, __RequestVerificationToken: token });
        if (selectedVariantId) body.append('variantId', selectedVariantId);

        try {
            const res  = await fetch('/Cart/Add', { method: 'POST', body });
            const data = res.ok ? await res.json().catch(() => null) : null;
            if (data && data.success) {
                updateCartBadge(data.cartCount);
                showToast(`Added to bag — ${qty > 1 ? qty + ' items' : '@Model.Name'}`);
            } else {
                showToast((data && data.message) || 'Sorry, we couldn’t add this to your bag.');
            }
        } catch {
            showToast('Sorry, we couldn’t add this to your bag.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Add to Bag';
        }
    });

    // ── Wishlist toggle ───────────────────────────────────────────────────────
    async function toggleWishlist() {
        const productId = @Model.Id;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res = await fetch('/Wishlist/Toggle', { method: 'POST', body: new URLSearchParams({ productId, __RequestVerificationToken: token }) });
        const data = await res.json();
        if (data.success) location.reload();
    }
    document.getElementById('wishlist-btn')?.addEventListener('click', toggleWishlist);
    document.getElementById('wishlist-link')?.addEventListener('click', toggleWishlist);

    // ── Product tabs (Description / Reviews / Shipping & Return Policy) ─────────
    document.querySelectorAll('.prod-tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const target = btn.dataset.tab;
            document.querySelectorAll('.prod-tab-btn').forEach(b => {
                const active = b === btn;
                b.classList.toggle('border-brand-500', active);
                b.classList.toggle('text-neutral-900', active);
                b.classList.toggle('border-transparent', !active);
                b.classList.toggle('text-neutral-400', !active);
            });
            document.querySelectorAll('.prod-tab-panel').forEach(p => {
                p.classList.toggle('hidden', p.dataset.panel !== target);
            });
        });
    });

    // ── Back-in-stock notify form ─────────────────────────────────────────────
    document.getElementById('notify-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.currentTarget;
        const btn = form.querySelector('button[type="submit"]');
        const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        btn.disabled = true;
        btn.textContent = 'Saving…';
        try {
            await fetch('/Products/NotifyRestock', {
                method: 'POST',
                body: new URLSearchParams({
                    productId: form.productId.value,
                    email: form.email.value,
                    __RequestVerificationToken: token
                })
            });
            document.getElementById('notify-success')?.classList.remove('hidden');
            form.email.value = '';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Notify Me';
        }
    });
})();
</script>
}
