@model SterlingLams.Web.Models.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = Model.PageTitle ?? "Collections";
    Layout = "_Layout";

    // Self-canonical that keeps the category but drops page/sort/filter noise (avoids duplicates).
    var canonBase = $"{Context.Request.Scheme}://{Context.Request.Host}/products";
    ViewData["Canonical"] = string.IsNullOrWhiteSpace(Model.Filters.Category)
        ? canonBase
        : $"{canonBase}?category={Model.Filters.Category}";
}

<div class="max-w-7xl mx-auto px-6 py-12">
    @Html.AntiForgeryToken()
    <partial name="_QuickViewModal" />

    <!-- Page Header -->
    <div class="text-center mb-12">
        <h1 class="font-cormorant text-5xl font-light text-neutral-900">
            @(Model.PageTitle ?? "Our Collections")
        </h1>
        @if (Model.TotalCount > 0)
        {
            <p class="text-sm text-neutral-400 mt-3">@Model.TotalCount pieces</p>
        }
    </div>

    <div class="flex gap-8 lg:gap-12">

        <!-- ─── Sidebar Filters ────────────────────────────────────────────── -->
        <aside class="hidden lg:block w-56 flex-shrink-0">
            <form method="get" id="filter-form">
                <!-- Category -->
                @if (Model.Filters.Categories.Any())
                {
                    <div class="mb-8">
                        <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Category</h3>
                        <ul class="space-y-2">
                            @foreach (var cat in Model.Filters.Categories)
                            {
                                <li>
                                    <a asp-action="Index" asp-route-category="@cat.Slug"
                                       class="text-sm @(Model.Filters.Category == cat.Slug ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors flex justify-between">
                                        <span>@cat.Name</span>
                                        <span class="text-neutral-300">@cat.Count</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Metal -->
                @if (Model.Filters.AvailableMetals.Any())
                {
                    <div class="mb-8">
                        <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Metal</h3>
                        <ul class="space-y-2">
                            @foreach (var metal in Model.Filters.AvailableMetals)
                            {
                                <li>
                                    <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer hover:text-neutral-900 transition-colors">
                                        <input type="checkbox" name="metal" value="@metal"
                                               @(Model.Filters.Metal == metal ? "checked" : "")
                                               class="rounded-none border-neutral-300 text-neutral-900" />
                                        @metal
                                    </label>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Price Range -->
                <div class="mb-8">
                    <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Price</h3>
                    <div class="space-y-2">
                        <input type="number" name="minPrice" value="@Model.Filters.MinPrice" placeholder="Min ₦"
                               class="w-full border border-neutral-200 text-sm px-3 py-2 focus:outline-none focus:border-neutral-900" />
                        <input type="number" name="maxPrice" value="@Model.Filters.MaxPrice" placeholder="Max ₦"
                               class="w-full border border-neutral-200 text-sm px-3 py-2 focus:outline-none focus:border-neutral-900" />
                    </div>
                </div>

                <!-- Availability -->
                <div class="mb-8">
                    <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                        <input type="checkbox" name="inStockOnly" value="true"
                               @(Model.Filters.InStockOnly == true ? "checked" : "") />
                        In stock only
                    </label>
                </div>

                <button type="submit"
                        class="w-full bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-3 hover:bg-brand-600 transition-colors">
                    Apply Filters
                </button>

                @if (!string.IsNullOrEmpty(Model.Filters.Category) || !string.IsNullOrEmpty(Model.Filters.Metal) || Model.Filters.MinPrice.HasValue)
                {
                    <a asp-action="Index" class="block text-center mt-3 text-xs text-neutral-400 hover:text-brand-500 transition-colors">
                        Clear all
                    </a>
                }
            </form>
        </aside>

        <!-- ─── Product Grid ───────────────────────────────────────────────── -->
        <div class="flex-1 min-w-0">

            <!-- Mobile category nav (the sidebar is hidden on phones/tablets) -->
            @if (Model.Filters.Categories.Any())
            {
                <details class="lg:hidden mb-6 border border-neutral-200 rounded-sm group" open="@(!string.IsNullOrEmpty(Model.Filters.Category))">
                    <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between">
                        <span class="text-xs tracking-[0.2em] uppercase text-neutral-500">
                            Category@(string.IsNullOrEmpty(Model.Filters.Category) ? "" : ": " + (Model.Filters.Categories.FirstOrDefault(c => c.Slug == Model.Filters.Category)?.Name ?? ""))
                        </span>
                        <svg class="w-4 h-4 text-neutral-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <ul class="px-4 pb-3 pt-1 space-y-2.5 max-h-72 overflow-y-auto border-t border-neutral-100">
                        <li>
                            <a asp-action="Index" class="flex justify-between text-sm @(string.IsNullOrEmpty(Model.Filters.Category) ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors">
                                <span>All Pieces</span>
                            </a>
                        </li>
                        @foreach (var cat in Model.Filters.Categories)
                        {
                            <li>
                                <a asp-action="Index" asp-route-category="@cat.Slug"
                                   class="flex justify-between text-sm @(Model.Filters.Category == cat.Slug ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors">
                                    <span>@cat.Name</span>
                                    <span class="text-neutral-300">@cat.Count</span>
                                </a>
                            </li>
                        }
                    </ul>
                </details>
            }

            <!-- Sort bar -->
            <div class="flex items-center justify-between mb-8 pb-4 border-b border-neutral-100">
                <p class="text-xs text-neutral-400">
                    Showing @((Model.Page - 1) * Model.PageSize + 1)–@Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount
                </p>
                <select name="sortBy" form="filter-form" data-autosubmit
                        class="text-xs border border-neutral-200 px-3 py-2 text-neutral-600 focus:outline-none focus:border-neutral-900 bg-white">
                    <option value="newest" selected="@(Model.Filters.SortBy == "newest")">Newest</option>
                    <option value="price_asc" selected="@(Model.Filters.SortBy == "price_asc")">Price: Low to High</option>
                    <option value="price_desc" selected="@(Model.Filters.SortBy == "price_desc")">Price: High to Low</option>
                    <option value="name" selected="@(Model.Filters.SortBy == "name")">Name</option>
                </select>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-24">
                    <p class="font-cormorant text-2xl font-light text-neutral-400">No pieces found</p>
                    <p class="text-sm text-neutral-400 mt-2">Try adjusting your filters.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                    @foreach (var product in Model.Products)
                    {
                        <div class="group">
                            <!-- Image -->
                            <a asp-controller="Products" asp-action="Detail" asp-route-slug="@product.Slug"
                               class="block aspect-square bg-neutral-50 overflow-hidden relative mb-4">
                                <img src="@product.PrimaryImageUrl" alt="@product.Name"
                                     loading="lazy"
                                     class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 @(product.SecondaryImageUrl != null ? "group-hover:opacity-0" : "")" />
                                @if (product.SecondaryImageUrl != null)
                                {
                                    <img src="@product.SecondaryImageUrl" alt="@product.Name" loading="lazy"
                                         class="absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105" />
                                }

                                <partial name="_DiscountBadge" model="product.DiscountPercent" />
                                @if (product.IsNewArrival)
                                {
                                    <span class="absolute top-3 right-3 bg-brand-500 text-white text-[9px] tracking-widest uppercase px-2 py-1">
                                        New
                                    </span>
                                }
                                @if (!product.IsAvailable)
                                {
                                    <div class="absolute inset-0 bg-white/50 flex items-center justify-center">
                                        <span class="text-xs tracking-widest uppercase text-neutral-500">Sold Out</span>
                                    </div>
                                }

                                <!-- Quick actions on hover -->
                                <div class="absolute bottom-3 right-3 flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    @if (product.IsAvailable)
                                    {
                                        <button class="add-to-bag-quick bg-white shadow p-2 hover:bg-brand-500 hover:text-white transition-colors"
                                                data-product-id="@product.Id"
                                                data-product-slug="@product.Slug"
                                                data-has-variants="@(product.HasVariants ? "true" : "false")"
                                                aria-label="Add to bag" title="Add to bag">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                      d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-.534 1.872-1.683 1.872-2.946 0-1.66-1.34-3-3-3H6.272M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
                                            </svg>
                                        </button>
                                    }
                                    <button class="wishlist-toggle bg-white shadow p-2 hover:bg-brand-500 hover:text-white transition-colors"
                                            data-product-id="@product.Id"
                                            aria-label="Wishlist">
                                        <svg class="w-4 h-4 @(product.IsInWishlist ? "fill-brand-500 text-brand-500" : "")"
                                             fill="@(product.IsInWishlist ? "currentColor" : "none")"
                                             stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                        </svg>
                                    </button>
                                </div>
                            </a>

                            <!-- Info -->
                            <a asp-controller="Products" asp-action="Detail" asp-route-slug="@product.Slug">
                                <p class="text-[10px] tracking-[0.2em] uppercase text-neutral-400 mb-1">@product.CategoryName</p>
                                <h3 class="text-sm font-light text-neutral-800 group-hover:text-neutral-900 transition-colors leading-snug mb-2">
                                    @product.Name
                                </h3>
                                @if (product.IsOnSale)
                                {
                                    <p class="text-sm"><span class="text-neutral-400 line-through">@product.FormattedRegularPrice</span> <span class="text-brand-600 font-medium ml-1">@product.FormattedPrice</span></p>
                                }
                                else
                                {
                                    <p class="text-sm text-neutral-700">@product.FormattedPrice</p>
                                }
                            </a>

                            <!-- CTA: Select Options (variants) / Add to Cart (simple) / Sold Out -->
                            <partial name="_ProductCardCta" model="product" />
                        </div>
                    }
                </div>

                <!-- Pagination — windowed, preserves filters -->
                @if (Model.TotalPages > 1)
                {
                    var cur = Model.Page;
                    var last = Model.TotalPages;
                    var start = Math.Max(1, cur - 2);
                    var end = Math.Min(last, cur + 2);
                    Func<int, Dictionary<string, string>> rd = pg => new Dictionary<string, string>
                    {
                        ["page"] = pg.ToString(),
                        ["category"] = Model.Filters.Category ?? "",
                        ["sortBy"] = Model.Filters.SortBy ?? "",
                        ["search"] = Model.Filters.Search ?? "",
                        ["metal"] = Model.Filters.Metal ?? "",
                        ["minPrice"] = Model.Filters.MinPrice?.ToString() ?? "",
                        ["maxPrice"] = Model.Filters.MaxPrice?.ToString() ?? "",
                        ["inStockOnly"] = Model.Filters.InStockOnly == true ? "true" : "",
                    };
                    var cls = "min-w-10 h-10 px-2 flex items-center justify-center text-xs border border-neutral-200 text-neutral-600 hover:border-brand-500 hover:text-brand-500 transition-colors";

                    <div class="flex justify-center items-center gap-1.5 mt-16 flex-wrap">
                        @if (cur > 1)
                        {
                            <a asp-action="Index" asp-all-route-data="rd(1)" class="@cls">« First</a>
                            <a asp-action="Index" asp-all-route-data="rd(cur - 1)" class="@cls">‹ Prev</a>
                        }
                        @if (start > 1)
                        {
                            <a asp-action="Index" asp-all-route-data="rd(1)" class="@cls">1</a>
                            @if (start > 2) { <span class="px-1 text-neutral-300">…</span> }
                        }
                        @for (int i = start; i <= end; i++)
                        {
                            <a asp-action="Index" asp-all-route-data="rd(i)"
                               class="w-10 h-10 flex items-center justify-center text-xs border @(i == cur ? "border-brand-500 bg-brand-500 text-white" : "border-neutral-200 text-neutral-600 hover:border-brand-500 hover:text-brand-500") transition-colors">@i</a>
                        }
                        @if (end < last)
                        {
                            @if (end < last - 1) { <span class="px-1 text-neutral-300">…</span> }
                            <a asp-action="Index" asp-all-route-data="rd(last)" class="@cls">@last</a>
                        }
                        @if (cur < last)
                        {
                            <a asp-action="Index" asp-all-route-data="rd(cur + 1)" class="@cls">Next ›</a>
                            <a asp-action="Index" asp-all-route-data="rd(last)" class="@cls">Last »</a>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>
