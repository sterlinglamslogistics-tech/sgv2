@model SterlingLams.Web.Models.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = Model.PageTitle ?? "Collections";
    Layout = "_Layout";

    // Base URL (current filters, minus page) for the "View more" progressive-load button.
    var qsParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Filters.Category)) { qsParts.Add("category=" + Uri.EscapeDataString(Model.Filters.Category)); }
    if (!string.IsNullOrWhiteSpace(Model.Filters.SortBy)) { qsParts.Add("sortBy=" + Uri.EscapeDataString(Model.Filters.SortBy)); }
    if (!string.IsNullOrWhiteSpace(Model.Filters.Search)) { qsParts.Add("search=" + Uri.EscapeDataString(Model.Filters.Search)); }
    if (!string.IsNullOrWhiteSpace(Model.Filters.Metal)) { qsParts.Add("metal=" + Uri.EscapeDataString(Model.Filters.Metal)); }
    if (Model.Filters.MinPrice.HasValue) { qsParts.Add("minPrice=" + Model.Filters.MinPrice.Value); }
    if (Model.Filters.MaxPrice.HasValue) { qsParts.Add("maxPrice=" + Model.Filters.MaxPrice.Value); }
    if (Model.Filters.InStockOnly == true) { qsParts.Add("inStockOnly=true"); }
    var loadMoreBaseUrl = "/products" + (qsParts.Count > 0 ? "?" + string.Join("&", qsParts) : "");
    var shownNow = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);

    // Self-canonical that keeps the category but drops page/sort/filter noise (avoids duplicates).
    var canonBase = $"{Context.Request.Scheme}://{Context.Request.Host}/products";
    ViewData["Canonical"] = string.IsNullOrWhiteSpace(Model.Filters.Category)
        ? canonBase
        : $"{canonBase}?category={Model.Filters.Category}";

    // BreadcrumbList structured data (OP-39): Home > Collections, or Home > <Category> on a filtered view.
    var sdBase = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var hasCategory = !string.IsNullOrWhiteSpace(Model.Filters.Category);
    var crumbLeafName = hasCategory ? (Model.PageTitle ?? "Collections") : "Collections";
    var crumbLeafUrl = hasCategory ? $"{sdBase}/products?category={Model.Filters.Category}" : $"{sdBase}/products";
    var breadcrumbLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new object[]
        {
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Home", ["item"] = sdBase },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = crumbLeafName, ["item"] = crumbLeafUrl },
        },
    });
}

@section Head {
    <script type="application/ld+json" nonce="@Context.Items["csp-nonce"]">@Html.Raw(breadcrumbLd)</script>
}

<div class="max-w-7xl mx-auto px-6 py-12">
    @* Antiforgery token comes from _QuickViewModal's placeholder (filled by /site/header-state)
       so this page stays output-cacheable — no server-rendered token / Set-Cookie. *@
    <partial name="_QuickViewModal" />

    <!-- Page Header -->
    <div class="text-center mb-12">
        <h1 class="font-cormorant text-5xl font-light text-neutral-900">
            @(Model.PageTitle ?? "Our Collections")
        </h1>
        @if (Model.TotalCount > 0)
        {
            <p class="text-sm text-neutral-400 mt-3">@Model.TotalCount pieces</p>
        }
    </div>

    <div class="flex gap-8 lg:gap-12">

        <!-- ─── Sidebar Filters ────────────────────────────────────────────── -->
        <aside class="hidden lg:block w-56 flex-shrink-0">
            <form method="get" id="filter-form">
                <!-- Category -->
                @if (Model.Filters.Categories.Any())
                {
                    <div class="mb-8">
                        <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Category</h3>
                        <ul class="space-y-2">
                            @foreach (var cat in Model.Filters.Categories)
                            {
                                <li>
                                    <a asp-action="Index" asp-route-category="@cat.Slug"
                                       class="text-sm @(Model.Filters.Category == cat.Slug ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors flex justify-between">
                                        <span>@cat.Name</span>
                                        <span class="text-neutral-300">@cat.Count</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Metal -->
                @if (Model.Filters.AvailableMetals.Any())
                {
                    <div class="mb-8">
                        <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Metal</h3>
                        <ul class="space-y-2">
                            @foreach (var metal in Model.Filters.AvailableMetals)
                            {
                                <li>
                                    <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer hover:text-neutral-900 transition-colors">
                                        <input type="checkbox" name="metal" value="@metal"
                                               @(Model.Filters.Metal == metal ? "checked" : "")
                                               class="rounded-none border-neutral-300 text-neutral-900" />
                                        @metal
                                    </label>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Price Range -->
                <div class="mb-8">
                    <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-400 mb-4">Price</h3>
                    <div class="space-y-2">
                        <input type="number" name="minPrice" value="@Model.Filters.MinPrice" placeholder="Min ₦"
                               class="w-full border border-neutral-200 text-sm px-3 py-2 focus:outline-none focus:border-neutral-900" />
                        <input type="number" name="maxPrice" value="@Model.Filters.MaxPrice" placeholder="Max ₦"
                               class="w-full border border-neutral-200 text-sm px-3 py-2 focus:outline-none focus:border-neutral-900" />
                    </div>
                </div>

                <!-- Availability -->
                <div class="mb-8">
                    <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                        <input type="checkbox" name="inStockOnly" value="true"
                               @(Model.Filters.InStockOnly == true ? "checked" : "") />
                        In stock only
                    </label>
                </div>

                <button type="submit"
                        class="w-full bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-3 hover:bg-brand-600 transition-colors">
                    Apply Filters
                </button>

                @if (!string.IsNullOrEmpty(Model.Filters.Category) || !string.IsNullOrEmpty(Model.Filters.Metal) || Model.Filters.MinPrice.HasValue)
                {
                    <a asp-action="Index" class="block text-center mt-3 text-xs text-neutral-400 hover:text-brand-500 transition-colors">
                        Clear all
                    </a>
                }
            </form>
        </aside>

        <!-- ─── Product Grid ───────────────────────────────────────────────── -->
        <div class="flex-1 min-w-0">

            <!-- Mobile category nav (the sidebar is hidden on phones/tablets) -->
            @if (Model.Filters.Categories.Any())
            {
                @* Collapsed by default on mobile — taps to open (never auto-expands, even within a category). *@
                <details class="lg:hidden mb-6 border border-neutral-200 rounded-sm group">
                    <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between">
                        <span class="text-xs tracking-[0.2em] uppercase text-neutral-500">
                            Category@(string.IsNullOrEmpty(Model.Filters.Category) ? "" : ": " + (Model.Filters.Categories.FirstOrDefault(c => c.Slug == Model.Filters.Category)?.Name ?? ""))
                        </span>
                        <svg class="w-4 h-4 text-neutral-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <ul class="px-4 pb-3 pt-1 space-y-2.5 max-h-72 overflow-y-auto border-t border-neutral-100">
                        <li>
                            <a asp-action="Index" class="flex justify-between text-sm @(string.IsNullOrEmpty(Model.Filters.Category) ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors">
                                <span>All Pieces</span>
                            </a>
                        </li>
                        @foreach (var cat in Model.Filters.Categories)
                        {
                            <li>
                                <a asp-action="Index" asp-route-category="@cat.Slug"
                                   class="flex justify-between text-sm @(Model.Filters.Category == cat.Slug ? "text-neutral-900 font-medium" : "text-neutral-500") hover:text-neutral-900 transition-colors">
                                    <span>@cat.Name</span>
                                    <span class="text-neutral-300">@cat.Count</span>
                                </a>
                            </li>
                        }
                    </ul>
                </details>
            }

            <!-- Sort bar -->
            <div class="flex items-center justify-between mb-8 pb-4 border-b border-neutral-100">
                <p class="text-xs text-neutral-400">
                    Showing @((Model.Page - 1) * Model.PageSize + 1)–@Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount
                </p>
                <select name="sortBy" form="filter-form" data-autosubmit
                        class="text-xs border border-neutral-200 px-3 py-2 text-neutral-600 focus:outline-none focus:border-neutral-900 bg-white">
                    <option value="newest" selected="@(Model.Filters.SortBy == "newest")">Newest</option>
                    <option value="price_asc" selected="@(Model.Filters.SortBy == "price_asc")">Price: Low to High</option>
                    <option value="price_desc" selected="@(Model.Filters.SortBy == "price_desc")">Price: High to Low</option>
                    <option value="name" selected="@(Model.Filters.SortBy == "name")">Name</option>
                </select>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-24">
                    <p class="font-cormorant text-2xl font-light text-neutral-400">No pieces found</p>
                    <p class="text-sm text-neutral-400 mt-2">Try adjusting your filters.</p>
                </div>
            }
            else
            {
                <div id="product-grid" class="grid grid-cols-2 md:grid-cols-3 gap-6">
                    <partial name="_ProductCards" model="Model.Products" />
                </div>

                <!-- Progressive "View more" (appends the next page in place) + Back to top -->
                <div class="mt-16 flex flex-col items-center gap-8">
                    <p class="text-sm text-neutral-500">
                        Showing 1–<span id="shown-count">@shownNow</span> of @Model.TotalCount
                    </p>
                    @if (Model.Page < Model.TotalPages)
                    {
                        <div id="load-more-wrap" class="w-full max-w-xl">
                            <button type="button" id="load-more-btn"
                                    data-url="@loadMoreBaseUrl" data-next="@(Model.Page + 1)" data-total="@Model.TotalPages"
                                    data-count="@Model.TotalCount" data-size="@Model.PageSize"
                                    class="w-full border border-neutral-300 py-4 text-xs tracking-[0.2em] uppercase text-neutral-800 hover:bg-brand-500 hover:border-brand-500 hover:text-white transition-colors">
                                <span data-label>View more</span>
                            </button>
                        </div>
                    }
                    <button type="button" id="back-to-top"
                            class="flex items-center gap-2 text-xs tracking-[0.2em] uppercase text-neutral-700 hover:text-neutral-900 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5M5 12l7-7 7 7" />
                        </svg>
                        Back to top
                    </button>
                </div>
            }
        </div>
    </div>
</div>
