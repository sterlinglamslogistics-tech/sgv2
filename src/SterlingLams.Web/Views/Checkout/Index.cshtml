@model SterlingLams.Web.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="max-w-5xl mx-auto px-6 py-12">
    <div class="text-center mb-12">
        <h1 class="font-cormorant text-4xl font-light">Checkout</h1>
    </div>

    <form asp-action="PlaceOrder" method="post" id="checkout-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SelectedDeliveryType" id="selected-delivery-type" value="Standard" />
        <input type="hidden" name="TimeframeAcknowledged" id="ack-input" value="false" />

        <div class="grid md:grid-cols-5 gap-12">

            <!-- ─── Left: Fulfillment + Details ─────────────────────────── -->
            <div class="md:col-span-3 space-y-10">

                @* ── Guest Contact Section (unauthenticated only) ─────────── *@
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <section class="border border-brand-200 bg-brand-50 p-6">
                        <div class="flex items-start gap-4 mb-5">
                            <svg class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            <div>
                                <p class="text-xs tracking-[0.2em] uppercase text-brand-600 mb-1">Checking Out as Guest</p>
                                <p class="text-sm text-neutral-600 font-light">
                                    Already have an account?
                                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Checkout"
                                       class="text-brand-500 hover:text-brand-700 underline underline-offset-2">Sign in</a>
                                    for faster checkout and order tracking.
                                </p>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Full Name</label>
                                <input asp-for="GuestName" type="text" autocomplete="name"
                                       class="form-input" placeholder="Jane Smith" />
                            </div>
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Email <span class="text-red-400">*</span></label>
                                <input asp-for="GuestEmail" type="email" autocomplete="email" required
                                       class="form-input @(ViewData.ModelState["GuestEmail"]?.Errors.Any() == true ? "border-red-400" : "")"
                                       placeholder="your@email.com" />
                                <span asp-validation-for="GuestEmail" class="text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Phone</label>
                                <input asp-for="GuestPhone" type="tel" autocomplete="tel"
                                       class="form-input" placeholder="+234 800 000 0000" />
                            </div>
                        </div>
                    </section>
                }

                <!-- Step 1: Fulfillment Type -->
                <section>
                    <h2 class="font-cormorant text-2xl font-light mb-6">How would you like to receive your order?</h2>
                    <div class="grid @(Model.PickupAvailable ? "grid-cols-2" : "grid-cols-1") gap-3">
                        <label class="fulfillment-option border border-neutral-300 p-5 cursor-pointer hover:border-neutral-900 transition-colors has-[:checked]:border-neutral-900 has-[:checked]:bg-neutral-50">
                            <input type="radio" name="FulfillmentType" value="Delivery" class="sr-only"
                                   @(Model.FulfillmentType == FulfillmentChoice.Delivery ? "checked" : "") />
                            <svg class="w-5 h-5 text-neutral-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12h12l1-12"/>
                            </svg>
                            <p class="text-sm font-medium text-neutral-800">Home Delivery</p>
                            <p class="text-xs text-neutral-400 mt-1 font-light">Lagos, Abuja & Nationwide</p>
                        </label>

                        @if (Model.PickupAvailable)
                        {
                            <label class="fulfillment-option border border-neutral-300 p-5 cursor-pointer hover:border-neutral-900 transition-colors has-[:checked]:border-neutral-900 has-[:checked]:bg-neutral-50">
                                <input type="radio" name="FulfillmentType" value="StorePickup" class="sr-only"
                                       @(Model.FulfillmentType == FulfillmentChoice.StorePickup ? "checked" : "") />
                                <svg class="w-5 h-5 text-neutral-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9"/>
                                </svg>
                                <p class="text-sm font-medium text-neutral-800">Store Pickup</p>
                                <p class="text-xs text-neutral-400 mt-1 font-light">Ready within 2 hours</p>
                            </label>
                        }
                    </div>
                </section>

                <!-- Step 2a: Delivery Address -->
                <section id="delivery-section" class="@(Model.FulfillmentType == FulfillmentChoice.StorePickup ? "hidden" : "")">
                    <h2 class="font-cormorant text-2xl font-light mb-6">Delivery Address</h2>

                    @if (Model.SavedAddresses.Any())
                    {
                        <div class="mb-6 space-y-2" id="saved-addresses">
                            <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Use a saved address</label>
                            @foreach (var a in Model.SavedAddresses)
                            {
                                <label class="saved-addr-card flex items-start gap-3 border rounded-sm p-3 cursor-pointer transition-colors @(Model.SelectedAddressId == a.Id ? "border-neutral-900" : "border-neutral-200 hover:border-neutral-400")">
                                    <input type="radio" name="saved-address" class="mt-1 saved-addr-radio" value="@a.Id"
                                           data-fullname="@a.FullName" data-phone="@a.Phone" data-line1="@a.Line1" data-line2="@a.Line2"
                                           data-city="@a.City" data-state="@a.State" data-postal="@a.PostalCode"
                                           @(Model.SelectedAddressId == a.Id ? "checked" : "") />
                                    <span class="text-sm">
                                        <span class="font-medium text-neutral-800">@a.Label@(a.IsDefault ? " · Default" : "")</span><br />
                                        <span class="text-neutral-500">@a.FullName, @a.Line1, @a.City, @a.State</span>
                                    </span>
                                </label>
                            }
                            <label class="saved-addr-card flex items-center gap-3 border border-neutral-200 hover:border-neutral-400 rounded-sm p-3 cursor-pointer transition-colors">
                                <input type="radio" name="saved-address" class="saved-addr-radio" value="new" />
                                <span class="text-sm text-neutral-700">+ Use a new address</span>
                            </label>
                        </div>
                    }

                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Full Name</label>
                                <input asp-for="DeliveryAddress.FullName" class="form-input" placeholder="Jane Smith" autocomplete="name" />
                                <span asp-validation-for="DeliveryAddress.FullName" class="text-xs text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Phone</label>
                                <input asp-for="DeliveryAddress.Phone" type="tel" class="form-input" placeholder="+234 800 000 0000" />
                                <span asp-validation-for="DeliveryAddress.Phone" class="text-xs text-red-500 mt-1 block"></span>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Address Line 1</label>
                            <input asp-for="DeliveryAddress.Line1" class="form-input" placeholder="Street address" autocomplete="address-line1" />
                            <span asp-validation-for="DeliveryAddress.Line1" class="text-xs text-red-500 mt-1 block"></span>
                        </div>
                        <div>
                            <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Address Line 2 <span class="text-neutral-300">(optional)</span></label>
                            <input asp-for="DeliveryAddress.Line2" class="form-input" placeholder="Apartment, suite, estate, etc." autocomplete="address-line2" />
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <!-- State dropdown -->
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">State</label>
                                <select asp-for="DeliveryAddress.State" id="state-select"
                                        class="form-input bg-white">
                                    <option value="">— Select state —</option>
                                    @foreach (var state in Model.NigerianStates)
                                    {
                                        <option value="@state" selected="@(Model.DeliveryAddress.State == state)">@state</option>
                                    }
                                </select>
                                <span asp-validation-for="DeliveryAddress.State" class="text-xs text-red-500 mt-1 block"></span>
                            </div>

                            <!-- City — LGA dropdown when Lagos, free text otherwise -->
                            <div>
                                <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">City / Area</label>

                                <!-- Lagos LGA dropdown (hidden unless Lagos selected) -->
                                <select id="lagos-lga-select" class="form-input bg-white hidden">
                                    <option value="">— Select area —</option>
                                    @foreach (var lga in Model.LagosLGAs.OrderBy(x => x))
                                    {
                                        <option value="@lga">@lga</option>
                                    }
                                </select>

                                <!-- Free text city input (shown by default) -->
                                <input id="city-input" asp-for="DeliveryAddress.City"
                                       class="form-input" placeholder="City" autocomplete="address-level2" />
                                <span asp-validation-for="DeliveryAddress.City" class="text-xs text-red-500 mt-1 block"></span>
                            </div>
                        </div>

                        <label class="flex items-center gap-2 text-sm text-neutral-500">
                            <input asp-for="DeliveryAddress.SaveAddress" type="checkbox" class="rounded-none border-neutral-300 text-neutral-900" />
                            Save this address for future orders
                        </label>
                    </div>

                    <!-- Delivery Type Selector (shown after state is picked) -->
                    <div id="delivery-options-section" class="mt-8 hidden">
                        <h3 class="text-xs tracking-[0.2em] uppercase text-neutral-500 mb-4">Select Delivery Option</h3>
                        <div id="delivery-options-grid" class="grid grid-cols-1 gap-3 sm:grid-cols-2"></div>
                        <p id="delivery-zone-note" class="text-xs text-neutral-400 mt-3"></p>
                    </div>
                </section>

                <!-- Step 2b: Store Pickup -->
                <section id="pickup-section" class="@(Model.FulfillmentType == FulfillmentChoice.Delivery ? "hidden" : "")">
                    <h2 class="font-cormorant text-2xl font-light mb-6">Select a Store</h2>
                    <div class="space-y-3">
                        @foreach (var store in Model.AvailableStores)
                        {
                            <label class="flex gap-4 border border-neutral-200 p-5 cursor-pointer hover:border-neutral-900 transition-colors has-[:checked]:border-neutral-900 has-[:checked]:bg-neutral-50">
                                <input type="radio" name="SelectedStoreId" value="@store.StoreId" class="mt-1 text-neutral-900 focus:ring-0" />
                                <div>
                                    <p class="text-sm font-medium text-neutral-800">@store.StoreName</p>
                                    <p class="text-xs text-neutral-400 font-light mt-0.5">@store.Address</p>
                                    @if (!string.IsNullOrEmpty(store.OpeningHours))
                                    {
                                        <p class="text-xs text-neutral-400 font-light">@store.OpeningHours</p>
                                    }
                                </div>
                            </label>
                        }
                    </div>
                </section>

                <!-- Step 3: Order notes + newsletter -->
                <section>
                    <h2 class="font-cormorant text-2xl font-light mb-6">Additional details</h2>
                    <label asp-for="OrderNotes" class="block text-xs tracking-[0.2em] uppercase text-neutral-500 mb-2">
                        Order notes <span class="text-neutral-300 normal-case tracking-normal">(optional)</span>
                    </label>
                    <textarea asp-for="OrderNotes" rows="4"
                              placeholder="Notes about your order, e.g. special notes for delivery."
                              class="w-full border border-neutral-200 px-4 py-3 text-sm focus:outline-none focus:border-neutral-900 transition-colors resize-none"></textarea>
                    <label class="flex items-start gap-3 mt-5 cursor-pointer">
                        <input asp-for="SubscribeNewsletter" type="checkbox" class="mt-0.5 rounded-none border-neutral-300 text-neutral-900" />
                        <span class="text-sm text-neutral-600 font-light">Subscribe to our newsletter</span>
                    </label>
                </section>
            </div>

            <!-- ─── Right: Order Summary + Payment ──────────────────────── -->
            <div class="md:col-span-2">
                <div class="bg-neutral-50 p-6 sticky top-28">
                    <h2 class="font-cormorant text-xl font-light mb-6">Order Summary</h2>

                    <div class="space-y-4 mb-6 max-h-72 overflow-y-auto pr-1">
                        @foreach (var item in Model.Cart.Items)
                        {
                            <div class="flex gap-3">
                                <img src="@Img.Cld(item.ImageUrl, 128, 128)" alt="@item.ProductName" loading="lazy" class="w-16 h-16 object-cover flex-shrink-0" />
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs text-neutral-700 leading-snug">@item.ProductName</p>
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <p class="text-[11px] text-neutral-400">@item.VariantName</p>
                                    }
                                    <p class="text-[11px] text-neutral-400 mt-0.5">Qty: @item.Quantity</p>
                                </div>
                                <span class="text-xs text-neutral-700 flex-shrink-0">@item.FormattedLineTotal</span>
                            </div>
                        }
                    </div>

                    <div class="border-t border-neutral-200 pt-4 space-y-2 mb-6">
                        <div class="flex justify-between text-sm">
                            <span class="text-neutral-500 font-light">Subtotal</span>
                            <span>@Model.FormattedSubtotal</span>
                        </div>
                        @if (Model.HasDiscount)
                        {
                            <div class="flex justify-between text-sm">
                                <span class="text-emerald-600 font-light">Discount (@Model.AppliedDiscountCode)</span>
                                <span class="text-emerald-600">@Model.FormattedDiscount</span>
                            </div>
                        }
                        @if (Model.LoyaltyAvailable)
                        {
                            <div class="flex items-start justify-between text-sm gap-3 pt-1">
                                <label class="flex items-start gap-2 cursor-pointer select-none">
                                    <input type="checkbox" name="RedeemPoints" value="true" id="redeem-points"
                                           class="mt-0.5 rounded-none border-neutral-300 text-neutral-900" />
                                    <span class="text-neutral-600 font-light">Use @Model.LoyaltyPointsBalance loyalty points
                                        <span class="block text-[11px] text-neutral-400">₦@Model.LoyaltyMaxDiscount.ToString("N0") off this order</span>
                                    </span>
                                </label>
                                <span id="summary-loyalty" class="text-emerald-600">—</span>
                            </div>
                        }
                        <div class="flex justify-between text-sm">
                            <span class="text-neutral-500 font-light">Delivery</span>
                            <span id="summary-delivery">—</span>
                        </div>
                        @if (Model.GiftCardsAvailable)
                        {
                            <div class="pt-2">
                                <label class="block text-[11px] tracking-[0.12em] uppercase text-neutral-400 mb-1.5">Gift card</label>
                                <input asp-for="GiftCardCode" class="w-full border border-neutral-200 px-3 py-2 text-sm font-mono tracking-wider focus:outline-none focus:border-neutral-400" placeholder="SLGC-XXXX-XXXX" autocomplete="off" autocapitalize="characters" />
                                <span asp-validation-for="GiftCardCode" class="block text-xs text-red-500 mt-1"></span>
                                <p class="text-[11px] text-neutral-400 mt-1 font-light">Your card balance is applied when you pay; any remainder is charged to your card.</p>
                            </div>
                        }
                        <div class="flex justify-between text-sm font-medium border-t border-neutral-200 pt-3 mt-3">
                            <span>Total</span>
                            <span id="summary-total">@Model.FormattedSubtotal</span>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 text-xs text-neutral-400 mb-6">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                        <span>Secure checkout · SSL encrypted</span>
                    </div>

                    <p class="text-[11px] text-neutral-400 font-light leading-relaxed mb-4 pt-4 border-t border-neutral-200">
                        Your personal data will be used to process your order, support your experience throughout this website, and for other purposes described in our
                        <a asp-controller="Home" asp-action="Privacy" target="_blank" class="font-medium text-neutral-600 underline hover:text-neutral-800">privacy policy</a>.
                    </p>
                    <label class="flex items-start gap-2 mb-1 cursor-pointer">
                        <input asp-for="AcceptTerms" type="checkbox" id="accept-terms" class="mt-0.5 rounded-none border-neutral-300 text-neutral-900" />
                        <span class="text-xs text-neutral-600 font-light">
                            I have read and agree to the website
                            <a asp-controller="Home" asp-action="Terms" target="_blank" class="font-medium text-neutral-600 underline hover:text-neutral-800">terms and conditions</a>
                            <span class="text-brand-500">*</span>
                        </span>
                    </label>
                    <span asp-validation-for="AcceptTerms" class="block text-xs text-red-500 mb-3"></span>
                    <p id="terms-error" class="hidden text-xs text-red-500 mb-3">Please accept the terms and conditions.</p>

                    <button type="submit"
                            class="w-full bg-brand-500 text-white text-xs tracking-[0.2em] uppercase py-4 hover:bg-brand-600 transition-colors duration-300">
                        Proceed to Payment
                    </button>

                    <p class="text-[11px] text-neutral-400 text-center mt-4 font-light">
                        You'll be redirected to Paystack's secure payment page.
                    </p>

                    <div class="mt-5 pt-5 border-t border-neutral-100">
                        @{ ViewData["PaymentBadgesCaption"] = "Your payment is secure · 256-bit SSL"; }
                        <partial name="_PaymentBadges" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Delivery-timeframe agreement modal (shown when an item ships from a far branch) -->
<div id="tf-modal" class="hidden fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-lg rounded-sm shadow-xl p-6">
        <h3 class="font-cormorant text-2xl font-light text-neutral-900 mb-1">A note on delivery timing</h3>
        <p class="text-sm text-neutral-500 mb-4">Some items in your bag aren't stocked at a branch near you, so they'll take a little longer to reach you:</p>
        <ul id="tf-list" class="mb-4"></ul>
        <p class="text-xs text-neutral-400 mb-5">You can remove an item to keep only what's available nearby, or agree to the longer timeframe and continue to payment.</p>
        <div class="flex gap-3 justify-end">
            <button type="button" id="tf-cancel" class="px-4 py-2.5 text-xs tracking-widest uppercase border border-neutral-300 text-neutral-600 hover:border-neutral-900 transition-colors">Go back</button>
            <button type="button" id="tf-agree" class="px-4 py-2.5 text-xs tracking-widest uppercase bg-brand-500 text-white hover:bg-brand-600 transition-colors">I agree, continue</button>
        </div>
    </div>
</div>

@section Scripts {
<script nonce="@Context.Items["csp-nonce"]">
// ── Pricing data from server ───────────────────────────────────────────────
const PRICING = @Html.Raw(Model.DeliveryPricingJson);
const SUBTOTAL = @Model.Subtotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
const DISCOUNT = @Model.DiscountAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
const FREE_SHIPPING = @(Model.Cart.FreeShipping ? "true" : "false");
const LOYALTY_DISCOUNT = @Model.LoyaltyMaxDiscount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
let CURRENT_FEE = 0;

// ── Fulfillment toggle ────────────────────────────────────────────────────
function toggleFulfillment(type) {
    document.getElementById('delivery-section').classList.toggle('hidden', type !== 'delivery');
    document.getElementById('pickup-section').classList.toggle('hidden', type !== 'pickup');
    if (type === 'pickup') {
        updateSummary(0);
    }
}

// ── State / area change → resolve distance zone → show delivery options ───
function currentStateValue() {
    var el = document.querySelector('[name="DeliveryAddress.State"]');
    return el ? el.value : '';
}
function stateKeyFor(state) {
    if (state === 'Lagos' || PRICING.lagosLGAs.some(function (l) { return l === state; })) return 'Lagos';
    if (PRICING.abujaKeywords.some(function (kw) { return state.indexOf(kw) >= 0; })) return 'Abuja';
    return 'National';
}
function zoneForArea(key, area) {
    var zones = (PRICING.zones && PRICING.zones[key]) ? PRICING.zones[key] : null;
    if (!zones || !zones.length) return null;
    if (area) {
        var a = String(area).trim().toLowerCase();
        var m = zones.find(function (z) { return (z.areas || []).some(function (x) { return String(x).trim().toLowerCase() === a; }); });
        if (m) return m;
    }
    return zones[0]; // area not listed → the state's first zone is the default
}
function onStateChanged(state) {
    var areaSelect = document.getElementById('lagos-lga-select');
    var cityInput  = document.getElementById('city-input');
    var key = stateKeyFor(state);
    var zones = (PRICING.zones && PRICING.zones[key]) ? PRICING.zones[key] : null;

    if (zones && zones.length) {
        // Rebuild the area dropdown from this state's zones (grouped by zone name).
        var prev = (areaSelect.value || cityInput.value || '');
        areaSelect.innerHTML = '<option value="">— Select area —</option>';
        zones.forEach(function (z) {
            var og = document.createElement('optgroup'); og.label = z.name;
            (z.areas || []).forEach(function (a) { var o = document.createElement('option'); o.value = a; o.textContent = a; og.appendChild(o); });
            areaSelect.appendChild(og);
        });
        if (prev && [].slice.call(areaSelect.options).some(function (o) { return o.value === prev; })) areaSelect.value = prev;
        areaSelect.classList.remove('hidden');
        cityInput.classList.add('hidden');
        onAreaChanged();
    } else {
        areaSelect.classList.add('hidden');
        cityInput.classList.remove('hidden');
        renderDeliveryOptions(PRICING.national, 'National', '');
    }
}
function onAreaChanged() {
    var areaSelect = document.getElementById('lagos-lga-select');
    var cityInput  = document.getElementById('city-input');
    var key = stateKeyFor(currentStateValue());
    var area = areaSelect.value;
    if (area) cityInput.value = area;   // keep the (required, hidden) City field in sync
    var z = zoneForArea(key, area);
    if (!z) { renderDeliveryOptions(PRICING.national, 'National', ''); return; }
    renderDeliveryOptions([
        { type: 'Express',  label: 'Express Delivery',  fee: z.expressFee,  timeframe: z.expressDays  },
        { type: 'Standard', label: 'Standard Delivery', fee: z.standardFee, timeframe: z.standardDays },
    ], key, z.name);
}

function renderDeliveryOptions(options, key, zoneName) {
    const section = document.getElementById('delivery-options-section');
    const grid    = document.getElementById('delivery-options-grid');
    const note    = document.getElementById('delivery-zone-note');

    grid.innerHTML = '';
    section.classList.remove('hidden');

    const stateLabels = { Lagos: 'Lagos', Abuja: 'Abuja FCT', National: 'Nationwide' };
    const stateLabel = stateLabels[key] || 'your area';
    note.textContent = zoneName ? `Delivery to ${zoneName} — ${stateLabel}.` : `Showing delivery options for ${stateLabel}.`;

    options.forEach((opt, i) => {
        const card = document.createElement('label');
        card.className = 'delivery-opt-card border border-neutral-300 p-4 cursor-pointer hover:border-neutral-900 transition-colors';
        card.innerHTML = `
            <input type="radio" name="_deliveryTypeUI" value="${opt.type}" class="sr-only" ${i === 0 ? 'checked' : ''} />
            <div class="flex items-start justify-between mb-1">
                <p class="text-sm font-medium text-neutral-800">${opt.label}</p>
                <p class="text-sm font-medium text-neutral-900">&#8358;${Number(opt.fee).toLocaleString()}</p>
            </div>
            <p class="text-xs text-neutral-400">${opt.timeframe}</p>
        `;
        // CSP-safe: wire the change handler instead of an inline onchange attribute.
        card.querySelector('input[name="_deliveryTypeUI"]').addEventListener('change', () => selectDeliveryType(opt.type, opt.fee));
        card.addEventListener('click', () => {
            document.querySelectorAll('.delivery-opt-card').forEach(c => c.classList.remove('border-neutral-900','bg-neutral-50'));
            card.classList.add('border-neutral-900','bg-neutral-50');
        });
        grid.appendChild(card);
    });

    // Auto-select first option
    if (options.length > 0) selectDeliveryType(options[0].type, options[0].fee);
    document.querySelectorAll('.delivery-opt-card')[0]?.classList.add('border-neutral-900','bg-neutral-50');
}

function selectDeliveryType(type, fee) {
    document.getElementById('selected-delivery-type').value = type;
    updateSummary(fee);
}

function updateSummary(fee) {
    if (FREE_SHIPPING) fee = 0;   // free-shipping promo waives the delivery fee
    CURRENT_FEE = fee;
    const redeem = document.getElementById('redeem-points');
    const loyalty = (redeem && redeem.checked) ? parseFloat(LOYALTY_DISCOUNT) : 0;
    const total = parseFloat(SUBTOTAL) - parseFloat(DISCOUNT) + parseFloat(fee) - loyalty;
    document.getElementById('summary-delivery').textContent = fee === 0 ? 'Free' : '₦' + Number(fee).toLocaleString();
    const loyaltyEl = document.getElementById('summary-loyalty');
    if (loyaltyEl) loyaltyEl.textContent = loyalty > 0 ? '-₦' + Number(loyalty).toLocaleString() : '—';
    document.getElementById('summary-total').textContent    = '₦' + Math.round(Math.max(0, total)).toLocaleString();
}

// ── Init ──────────────────────────────────────────────────────────────────
(function init() {
    // CSP-safe wiring (replaces inline onchange attributes).
    document.querySelectorAll('input[name="FulfillmentType"]').forEach(r =>
        r.addEventListener('change', () => toggleFulfillment(r.value === 'StorePickup' ? 'pickup' : 'delivery')));
    document.getElementById('state-select')?.addEventListener('change', e => onStateChanged(e.target.value));
    document.getElementById('lagos-lga-select')?.addEventListener('change', () => onAreaChanged());
    document.getElementById('redeem-points')?.addEventListener('change', () => updateSummary(CURRENT_FEE));

    // Saved-address picker: fill the form from the chosen saved address (or clear for a new one).
    function setVal(id, v) { var el = document.getElementById(id); if (el) el.value = v || ''; }
    document.querySelectorAll('.saved-addr-radio').forEach(radio => {
        radio.addEventListener('change', () => {
            document.querySelectorAll('.saved-addr-card').forEach(c =>
                c.classList.toggle('border-neutral-900', c.contains(radio) && radio.checked));
            const d = radio.dataset;
            if (radio.value === 'new') {
                ['DeliveryAddress_FullName', 'DeliveryAddress_Phone', 'DeliveryAddress_Line1', 'DeliveryAddress_Line2', 'city-input'].forEach(id => setVal(id, ''));
                document.getElementById('DeliveryAddress_FullName')?.focus();
            } else {
                setVal('DeliveryAddress_FullName', d.fullname);
                setVal('DeliveryAddress_Phone', d.phone);
                setVal('DeliveryAddress_Line1', d.line1);
                setVal('DeliveryAddress_Line2', d.line2);
                var st = document.getElementById('state-select');
                if (st) { st.value = d.state || ''; onStateChanged(st.value); }
                setVal('city-input', d.city);
                var lga = document.getElementById('lagos-lga-select');
                if (lga && !lga.classList.contains('hidden')) lga.value = d.city || '';
            }
        });
    });

    const stateVal = document.getElementById('state-select').value;
    if (stateVal) onStateChanged(stateVal);
})();

// ── Delivery-timeframe agreement (far-stock items) ─────────────────────────
(function timeframeGate() {
    const form = document.getElementById('checkout-form');
    if (!form) return;
    const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const modal = document.getElementById('tf-modal');
    const list = document.getElementById('tf-list');
    const ack = document.getElementById('ack-input');
    let ackPassed = false;

    function esc(s){ const d=document.createElement('div'); d.textContent = s==null?'':String(s); return d.innerHTML; }

    async function removeItem(pid, vid){
        const fd = new URLSearchParams();
        fd.set('__RequestVerificationToken', token);
        fd.set('productId', pid);
        if (vid !== null && vid !== undefined) fd.set('variantId', vid);
        try { await fetch('/Cart/Remove', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: fd.toString()}); } catch {}
        window.location.reload();
    }

    function showModal(items){
        list.innerHTML = '';
        items.forEach(it => {
            const li = document.createElement('li');
            li.className = 'flex items-start justify-between gap-3 py-3 border-b border-neutral-100';
            li.innerHTML = '<div class="min-w-0"><div class="text-sm text-neutral-800 break-words">' + esc(it.productName) + '</div>'
                + '<div class="text-xs text-amber-600 mt-0.5">Ships from our ' + esc(it.sourceStore) + ' store · allow ' + esc(it.eta) + '</div></div>';
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'text-xs text-red-500 hover:text-red-700 whitespace-nowrap shrink-0';
            btn.textContent = 'Remove';
            btn.addEventListener('click', () => removeItem(it.productId, it.variantId));
            li.appendChild(btn);
            list.appendChild(li);
        });
        modal.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
        // Terms & conditions must be accepted (checked on every submit, even after the timeframe step).
        const terms = document.getElementById('accept-terms');
        if (terms && !terms.checked) {
            e.preventDefault();
            document.getElementById('terms-error')?.classList.remove('hidden');
            terms.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        document.getElementById('terms-error')?.classList.add('hidden');

        if (ackPassed) return; // already agreed → let it through
        e.preventDefault();
        const ff = form.querySelector('input[name="FulfillmentType"]:checked')?.value || 'Delivery';
        const fd = new URLSearchParams();
        fd.set('__RequestVerificationToken', token);
        fd.set('fulfillmentType', ff);
        fd.set('state', document.getElementById('state-select')?.value || '');
        fd.set('city', document.getElementById('city-input')?.value || '');
        const storeId = form.querySelector('input[name="SelectedStoreId"]:checked')?.value;
        if (storeId) fd.set('storeId', storeId);

        let data = { delayed: [] };
        try {
            const r = await fetch('/Checkout/FulfilmentPreview', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: fd.toString()});
            data = await r.json();
        } catch { /* on error, don't block the sale */ }

        if (!data.delayed || data.delayed.length === 0) { ackPassed = true; form.submit(); return; }
        showModal(data.delayed);
    });

    document.getElementById('tf-agree')?.addEventListener('click', () => {
        ack.value = 'true'; ackPassed = true;
        modal.classList.add('hidden');
        form.submit();
    });
    document.getElementById('tf-cancel')?.addEventListener('click', () => modal.classList.add('hidden'));
})();
</script>
}
