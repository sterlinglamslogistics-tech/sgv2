<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@ViewData["Description"] ?? "Sterlin Glams — Luxury Jewellery. Timeless elegance crafted for you."" />
    <title>@ViewData["Title"] — Sterlin Glams</title>

    <!-- Fonts: Cormorant Garamond (luxury serif) + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Tailwind compiled output -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-white text-neutral-900 font-inter antialiased">

    <!-- ─── Navigation ──────────────────────────────────────────────────── -->
    @await Html.PartialAsync("_Navigation")

    <!-- ─── Flash Messages ─────────────────────────────────────────────── -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-emerald-50 border-b border-emerald-200 px-6 py-3 text-center text-sm text-emerald-800">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-b border-red-200 px-6 py-3 text-center text-sm text-red-800">
            @TempData["Error"]
        </div>
    }

    <!-- ─── Main Content ────────────────────────────────────────────────── -->
    <main>
        @RenderBody()
    </main>

    <!-- ─── Footer ──────────────────────────────────────────────────────── -->
    @await Html.PartialAsync("_Footer")

    <!-- ─── Toast ───────────────────────────────────────────────────────── -->
    <div id="toast"
         class="fixed bottom-6 right-6 z-[9999] bg-neutral-900 text-white text-xs tracking-wide px-5 py-3 shadow-xl transition-all duration-300 translate-y-4 opacity-0 pointer-events-none max-w-xs">
        <span id="toast-message"></span>
    </div>

    <!-- Scripts -->
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
