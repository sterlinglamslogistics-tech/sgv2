@model List<SterlingLams.Web.Models.Domain.BlogPost>
@{
    ViewData["Title"] = "Journal";
    Layout = "_Layout";
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="max-w-6xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-3">Sterlin Glams</p>
        <h1 class="font-cormorant text-4xl md:text-5xl font-light">The Journal</h1>
        <p class="text-sm text-neutral-500 font-light mt-3 max-w-xl mx-auto">Styling notes, lookbooks and stories from behind the jewellery.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-sm text-neutral-400 py-16">No posts yet — check back soon.</div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var p in Model)
            {
                <a asp-controller="Journal" asp-action="Detail" asp-route-slug="@p.Slug" class="group block">
                    <div class="aspect-[4/3] overflow-hidden bg-neutral-100 mb-4">
                        @if (!string.IsNullOrEmpty(p.CoverImageUrl))
                        {
                            <img src="@Img.Cld(p.CoverImageUrl, 700)" alt="@p.Title" loading="lazy" decoding="async"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        }
                    </div>
                    <p class="text-[11px] tracking-[0.2em] uppercase text-neutral-400 mb-1">@(p.PublishedAt?.ToString("dd MMM yyyy"))</p>
                    <h2 class="font-cormorant text-2xl font-light text-neutral-900 group-hover:text-brand-600 transition-colors leading-snug">@p.Title</h2>
                    @if (!string.IsNullOrWhiteSpace(p.Excerpt))
                    {
                        <p class="text-sm text-neutral-500 font-light mt-2 line-clamp-3">@p.Excerpt</p>
                    }
                    <span class="inline-block mt-3 text-xs tracking-[0.2em] uppercase text-brand-600 border-b border-brand-200 pb-0.5">Read more</span>
                </a>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 mt-14 text-xs">
                @for (int pg = 1; pg <= totalPages; pg++)
                {
                    <a asp-controller="Journal" asp-action="Index" asp-route-page="@pg"
                       class="px-3 py-1.5 border @(pg == page ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400") transition-colors">@pg</a>
                }
            </div>
        }
    }
</div>
