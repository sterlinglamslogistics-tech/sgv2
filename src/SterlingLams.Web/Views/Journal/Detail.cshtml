@model SterlingLams.Web.Models.Domain.BlogPost
@{
    Layout = "_Layout";
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.MetaTitle) ? Model.Title : Model.MetaTitle;
    ViewData["Description"] = string.IsNullOrWhiteSpace(Model.MetaDescription) ? Model.Excerpt : Model.MetaDescription;
    ViewData["OgType"] = "article";
    if (!string.IsNullOrEmpty(Model.CoverImageUrl)) { ViewData["OgImage"] = Model.CoverImageUrl; }

    var more = ViewBag.More as List<SterlingLams.Web.Models.Domain.BlogPost> ?? new();
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var articleLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BlogPosting",
        ["headline"] = Model.Title,
        ["description"] = Model.Excerpt,
        ["image"] = string.IsNullOrEmpty(Model.CoverImageUrl) ? null : Model.CoverImageUrl,
        ["datePublished"] = Model.PublishedAt?.ToString("yyyy-MM-dd"),
        ["dateModified"] = Model.UpdatedAt.ToString("yyyy-MM-dd"),
        ["author"] = new Dictionary<string, object?> { ["@type"] = "Organization", ["name"] = string.IsNullOrWhiteSpace(Model.AuthorName) ? "Sterlin Glams" : Model.AuthorName },
        ["publisher"] = new Dictionary<string, object?> { ["@type"] = "Organization", ["name"] = "Sterlin Glams" },
        ["mainEntityOfPage"] = $"{baseUrl}/journal/{Model.Slug}",
    }, new System.Text.Json.JsonSerializerOptions { DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull });
}

@section Head {
    <script type="application/ld+json" nonce="@Context.Items["csp-nonce"]">@Html.Raw(articleLd)</script>
}

<article class="max-w-3xl mx-auto px-6 pt-14">
    <a asp-controller="Journal" asp-action="Index" class="text-xs tracking-[0.2em] uppercase text-neutral-400 hover:text-brand-500 transition-colors">← The Journal</a>

    <header class="text-center mt-6 mb-8">
        <p class="text-[11px] tracking-[0.25em] uppercase text-neutral-400 mb-3">
            @(Model.PublishedAt?.ToString("dd MMMM yyyy"))@(string.IsNullOrWhiteSpace(Model.AuthorName) ? "" : $" · {Model.AuthorName}")
        </p>
        <h1 class="font-cormorant text-4xl md:text-5xl font-light leading-tight">@Model.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Excerpt))
        {
            <p class="text-base text-neutral-500 font-light mt-4 max-w-2xl mx-auto">@Model.Excerpt</p>
        }
    </header>
</article>

@if (!string.IsNullOrEmpty(Model.CoverImageUrl))
{
    <div class="max-w-4xl mx-auto px-6 mb-2">
        <img src="@Img.Cld(Model.CoverImageUrl, 1200)" alt="@Model.Title" decoding="async" class="w-full max-h-[34rem] object-cover" />
    </div>
}

<partial name="_PageProse" model="Model.Body" />

@if (more.Any())
{
    <div class="max-w-6xl mx-auto px-6 pb-20">
        <h2 class="font-cormorant text-3xl font-light text-center mb-10">More from the Journal</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            @foreach (var p in more)
            {
                <a asp-controller="Journal" asp-action="Detail" asp-route-slug="@p.Slug" class="group block">
                    <div class="aspect-[4/3] overflow-hidden bg-neutral-100 mb-3">
                        @if (!string.IsNullOrEmpty(p.CoverImageUrl))
                        {
                            <img src="@Img.Cld(p.CoverImageUrl, 600)" alt="@p.Title" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        }
                    </div>
                    <h3 class="font-cormorant text-xl font-light text-neutral-900 group-hover:text-brand-600 transition-colors leading-snug">@p.Title</h3>
                </a>
            }
        </div>
    </div>
}
