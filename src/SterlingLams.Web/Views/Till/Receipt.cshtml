@model SterlingLams.Web.Models.Domain.Order
@using SterlingLams.Web.Services
@inject ISettingsService Settings
@{
    Layout = null;
    var siteName = await Settings.GetAsync("general.site_name", "Sterlin Glams");
    var receiptHeader = await Settings.GetAsync("pos.receipt_header", "");
    var receiptFooter = await Settings.GetAsync("pos.receipt_footer", "Thank you for shopping with us!");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Receipt @Model.OrderNumber</title>
    <style>
        body { font-family: 'Courier New', monospace; color:#111; margin:0; padding:16px; }
        .r { width:300px; margin:0 auto; }
        h1 { font-size:16px; text-align:center; margin:0 0 2px; letter-spacing:2px; }
        .c { text-align:center; } .muted { color:#555; }
        .row { display:flex; justify-content:space-between; font-size:12px; margin:2px 0; }
        hr { border:none; border-top:1px dashed #999; margin:10px 0; }
        table { width:100%; border-collapse:collapse; font-size:12px; } td { padding:2px 0; }
        .right { text-align:right; } .total { font-size:14px; font-weight:bold; }
        .btns { width:300px; margin:16px auto 0; display:flex; gap:8px; }
        .btns button, .btns a { flex:1; padding:8px; font-size:12px; text-align:center; border:1px solid #ccc; background:#fff; cursor:pointer; text-decoration:none; color:#111; border-radius:3px; }
        @@media print { .btns { display:none; } body { padding:0; } }
    </style>
</head>
<body onload="window.print()">
    <div class="r">
        <h1>@siteName.ToUpper()</h1>
        <p class="c muted" style="font-size:12px;margin:0 0 8px;">@(Model.PickupStore?.Name ?? "Store")</p>
        @if (!string.IsNullOrWhiteSpace(receiptHeader))
        {
            <p class="c muted" style="font-size:11px;margin:0 0 8px;">@receiptHeader</p>
        }
        <hr />
        <div class="row"><span>Receipt</span><span>@Model.OrderNumber</span></div>
        <div class="row"><span>Date</span><span>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span></div>
        <div class="row"><span>Payment</span><span>@Model.PaymentProvider</span></div>
        @if (Model.User != null && !string.IsNullOrWhiteSpace(Model.User.FullName))
        {
            <div class="row"><span>Served by</span><span>@Model.User.FullName</span></div>
        }
        @if (Model.Customer != null)
        {
            <div class="row"><span>Customer</span><span>@Model.Customer.FullName@(string.IsNullOrEmpty(Model.Customer.PhoneNumber) ? "" : $" · {Model.Customer.PhoneNumber}")</span></div>
        }
        <hr />
        <table>
            @foreach (var item in Model.Items)
            {
                <tr><td>@item.Quantity× @item.ProductName@(item.VariantName != null ? $" ({item.VariantName})" : "")</td><td class="right">₦@item.LineTotal.ToString("N0")</td></tr>
            }
        </table>
        <hr />
        <div class="row total"><span>TOTAL</span><span>₦@Model.Total.ToString("N0")</span></div>
        @if (Model.AmountTendered.HasValue)
        {
            <div class="row"><span>Tendered</span><span>₦@Model.AmountTendered.Value.ToString("N0")</span></div>
            <div class="row"><span>Change</span><span>₦@((Model.ChangeGiven ?? 0).ToString("N0"))</span></div>
        }
        <hr />
        <p class="c muted" style="font-size:11px;white-space:pre-line;">@receiptFooter</p>
    </div>
    <div class="btns"><button onclick="window.print()">Print</button><a href="/Till">Next sale</a></div>
</body>
</html>
