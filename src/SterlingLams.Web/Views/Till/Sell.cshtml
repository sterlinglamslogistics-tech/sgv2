        <div class="relative flex-1 min-w-[240px] max-w-md">
            <svg class="w-4 h-4 text-neutral-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input id="stocklookup-search" type="text" autocomplete="off" placeholder="Search name, SKU, or scan barcode…"
                   class="w-full pl-9 pr-4 py-2.5 text-sm border border-neutral-200 rounded-lg focus:outline-none focus:border-brand-500" />
        </div>
        <div class="flex items-center gap-2">
            <label for="stocklookup-location" class="text-[10px] text-neutral-400 font-medium uppercase tracking-wide">Filter by location</label>
            <select id="stocklookup-location" class="text-sm border border-neutral-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand-500">
                <option value="">All locations</option>
            </select>
        </div>
    </div>
