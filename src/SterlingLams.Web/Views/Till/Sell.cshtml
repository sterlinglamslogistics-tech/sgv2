        <p class="text-center text-neutral-400 py-8 text-xs">Search for a product to see stock levels.</p>
    </div>
    <div id="stocklookup-detail" class="hidden flex-1 overflow-y-auto text-sm px-6 py-4"></div>
</div>

@section Scripts {
<script>
(function () {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const fmt = n => '₦' + Number(n || 0).toLocaleString('en-NG', { maximumFractionDigits: 0 });
    // Cart is persisted per register + session so an accidental refresh / crash doesn't lose an in-progress sale.
    const TILL_CART_KEY = 'till_cart_@(Model.Id)_@(session?.Id ?? 0)';

    // ── Clock ─────────────────────────────────────────────────────────────────
    function tick() {
        const now = new Date();
        const t = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const d = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
        const c = document.getElementById('till-clock');
        const dt = document.getElementById('till-date-top');
        if (c) c.textContent = t;
        if (dt) dt.textContent = d;
    }
    tick(); setInterval(tick, 1000);

    // ── Tabs ──────────────────────────────────────────────────────────────────
    const tabPanels = { products: document.getElementById('tab-products'), customers: document.getElementById('tab-customers'), orders: document.getElementById('tab-orders') };
    document.querySelectorAll('.till-tab').forEach(btn => {
        btn.addEventListener('click', () => {
            const name = btn.dataset.tab;
            document.querySelectorAll('.till-tab').forEach(b => {
                b.classList.remove('border-brand-500', 'text-brand-500');
                b.classList.add('border-transparent', 'text-neutral-400');
            });
            btn.classList.remove('border-transparent', 'text-neutral-400');
            btn.classList.add('border-brand-500', 'text-brand-500');
            Object.values(tabPanels).forEach(p => p.classList.add('hidden'));
            tabPanels[name].classList.remove('hidden');
            if (name === 'orders') loadOrders();
            if (name === 'customers') searchCustomers('');
        });
    });

    // ── Category palette ──────────────────────────────────────────────────────
    const palettes = [
        'bg-brand-500 text-white', 'bg-neutral-800 text-white', 'bg-violet-600 text-white',
        'bg-sky-600 text-white', 'bg-emerald-600 text-white', 'bg-amber-500 text-white',
        'bg-rose-600 text-white', 'bg-indigo-600 text-white', 'bg-teal-600 text-white',
        'bg-orange-500 text-white', 'bg-pink-600 text-white', 'bg-cyan-600 text-white',
    ];

    const catGrid = document.getElementById('cat-grid');
    const resultsEl = document.getElementById('till-results');
    const searchBox = document.getElementById('till-search');
    const homeBtn = document.getElementById('home-btn');
    const breadcrumbDivider = document.getElementById('breadcrumb-divider');
    const breadcrumbCat = document.getElementById('breadcrumb-cat');
    let activeCategoryId = null, debounce, lastResults = [];

    async function loadCategories() {
        const res = await fetch('/Till/Categories');
        const cats = await res.json();
        if (!cats.length) {
            catGrid.innerHTML = '<p class="col-span-full text-sm text-neutral-400 py-8 text-center">No categories found. Products will show below.</p>';
            showAllProducts();
            return;
        }
        catGrid.innerHTML = cats.map((c, i) => {
            const palette = palettes[i % palettes.length];
            return `<button type="button" class="cat-tile ${palette} rounded-xl p-4 flex flex-col items-center justify-center gap-2 min-h-[90px] text-center hover:opacity-90 active:scale-95 transition-all shadow-sm" data-id="${c.id}" data-name="${c.name}">
                <span class="text-3xl">${catEmoji(c.name)}</span>
                <span class="text-xs font-semibold uppercase tracking-wide leading-tight">${c.name}</span>
            </button>`;
        }).join('');
        catGrid.querySelectorAll('.cat-tile').forEach(b => b.addEventListener('click', () => {
            activeCategoryId = +b.dataset.id;
            showCategoryProducts(activeCategoryId, b.dataset.name);
        }));
    }

    function catEmoji(name) {
        const n = name.toLowerCase();
        if (n.includes('ring')) return '💍';
        if (n.includes('necklace') || n.includes('chain')) return '📿';
        if (n.includes('earring') || n.includes('ear')) return '✨';
        if (n.includes('bracelet') || n.includes('bangle')) return '🔮';
        if (n.includes('watch')) return '⌚';
        if (n.includes('brooch') || n.includes('pin')) return '🔹';
        if (n.includes('pendant')) return '💎';
        if (n.includes('anklet')) return '🦋';
        if (n.includes('hair')) return '🌸';
        if (n.includes('bag') || n.includes('purse')) return '👜';
        return '✦';
    }

    async function showCategoryProducts(catId, catName) {
        catGrid.classList.add('hidden');
        resultsEl.classList.remove('hidden');
        homeBtn.classList.remove('hidden');
        homeBtn.classList.add('flex');
        breadcrumbDivider.classList.remove('hidden');
        breadcrumbCat.classList.remove('hidden');
        breadcrumbCat.textContent = catName;
        resultsEl.innerHTML = '<p class="col-span-full text-sm text-neutral-400 py-6 text-center">Loading…</p>';
        const res = await fetch('/Till/Search?categoryId=' + catId);
        lastResults = await res.json();
        renderProducts(lastResults);
    }

    async function showAllProducts() {
        catGrid.classList.add('hidden');
        resultsEl.classList.remove('hidden');
        homeBtn.classList.add('hidden');
        homeBtn.classList.remove('flex');
        breadcrumbDivider.classList.add('hidden');
        breadcrumbCat.classList.add('hidden');
        activeCategoryId = null;
        const res = await fetch('/Till/Search?q=' + encodeURIComponent(searchBox.value.trim()));
        lastResults = await res.json();
        renderProducts(lastResults);
    }

    homeBtn.addEventListener('click', () => {
        catGrid.classList.remove('hidden');
        resultsEl.classList.add('hidden');
        homeBtn.classList.add('hidden');
        homeBtn.classList.remove('flex');
        breadcrumbDivider.classList.add('hidden');
        breadcrumbCat.classList.add('hidden');
        activeCategoryId = null;
        searchBox.value = '';
    });

    searchBox.addEventListener('input', () => {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
            if (searchBox.value.trim()) {
                activeCategoryId = null;
                catGrid.classList.add('hidden');
                resultsEl.classList.remove('hidden');
                homeBtn.classList.add('hidden');
                homeBtn.classList.remove('flex');
                breadcrumbDivider.classList.add('hidden');
                breadcrumbCat.classList.add('hidden');
                runSearch();
            } else if (activeCategoryId === null) {
                catGrid.classList.remove('hidden');
                resultsEl.classList.add('hidden');
            }
        }, 180);
    });
    searchBox.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); onScan(searchBox.value.trim()); } });

    async function runSearch() {
        const q = searchBox.value.trim();
        const url = '/Till/Search?q=' + encodeURIComponent(q) + (activeCategoryId ? '&categoryId=' + activeCategoryId : '');
        const res = await fetch(url);
        lastResults = await res.json();
        renderProducts(lastResults);
    }

    function renderProducts(items) {
        if (!items.length) {
            resultsEl.innerHTML = '<p class="col-span-full text-sm text-neutral-400 py-8 text-center">No products found.</p>';
            return;
        }
        resultsEl.innerHTML = items.map(p => {
            const out = p.stock <= 0;
            return `<button type="button" ${out ? 'disabled' : ''} class="till-prod text-left bg-white border border-neutral-200 rounded-xl overflow-hidden hover:border-brand-400 hover:shadow-md transition-all ${out ? 'opacity-40' : ''}" data-p='${encodeURIComponent(JSON.stringify(p)).replace(/'/g, '%27')}'>
                <div class="aspect-square bg-neutral-50 relative">${p.image ? `<img src="${p.image}" class="w-full h-full object-cover">` : '<div class="w-full h-full flex items-center justify-center text-neutral-300"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>'}
                    ${out ? '<div class="absolute inset-0 bg-white/60 flex items-center justify-center"><span class="text-[10px] text-red-500 font-medium">Out of stock</span></div>' : ''}
                </div>
                <div class="p-2.5">
                    ${p.sku ? `<p class="text-[10px] text-neutral-400 font-mono leading-none mb-0.5">${p.sku}</p>` : ''}
                    <p class="text-xs text-neutral-800 leading-snug line-clamp-2 font-medium">${p.name}</p>
                    <p class="text-sm text-neutral-700 mt-1 font-semibold">${fmt(p.price)}</p>
                    <p class="text-[10px] ${out ? 'text-red-400' : 'text-emerald-600'} mt-0.5">${out ? 'Out of stock' : p.stock + ' in stock'}</p>
                </div>
            </button>`;
        }).join('');
        resultsEl.querySelectorAll('.till-prod').forEach(b => b.addEventListener('click', () => add(JSON.parse(decodeURIComponent(b.dataset.p)))));
    }

    async function onScan(code) {
        if (!code) return;
        const res = await fetch('/Till/Search?q=' + encodeURIComponent(code));
        const items = await res.json();
        const exact = items.find(p => (p.barcode && p.barcode.toLowerCase() === code.toLowerCase()) || (p.sku && p.sku.toLowerCase() === code.toLowerCase()));
        if (exact && exact.stock > 0) { add(exact); searchBox.value = ''; }
        else { lastResults = items; catGrid.classList.add('hidden'); resultsEl.classList.remove('hidden'); renderProducts(items); }
    }

    // ── Variant picker ────────────────────────────────────────────────────────
    const variantModal = document.getElementById('variant-modal');
    const variantTitle = document.getElementById('variant-title');
    const variantList = document.getElementById('variant-list');
    let resolveVariant = null;
    document.getElementById('variant-cancel').addEventListener('click', () => {
        variantModal.classList.add('hidden');
        if (resolveVariant) { resolveVariant(null); resolveVariant = null; }
    });
    variantModal.addEventListener('click', e => {
        if (e.target === variantModal) {
            variantModal.classList.add('hidden');
            if (resolveVariant) { resolveVariant(null); resolveVariant = null; }
        }
    });

    function pickVariant(p) {
        return new Promise(resolve => {
            resolveVariant = resolve;
            variantTitle.textContent = p.name;
            variantList.innerHTML = p.variants.map((v, i) => {
                const price = p.price + (v.priceAdjustment || 0);
                return `<button type="button" class="variant-opt w-full flex justify-between items-center border border-neutral-200 rounded-lg px-4 py-3 hover:border-brand-500 hover:bg-brand-50 transition-colors text-left" data-idx="${i}">
                    <span class="text-sm text-neutral-800">${v.name}</span>
                    <span class="text-sm font-medium text-neutral-700">${fmt(price)}</span>
                </button>`;
            }).join('');
            variantList.querySelectorAll('.variant-opt').forEach(b => b.addEventListener('click', () => {
                variantModal.classList.add('hidden');
                resolveVariant = null;
                resolve(p.variants[+b.dataset.idx]);
            }));
            variantModal.classList.remove('hidden');
        });
    }

    // ── Cart ──────────────────────────────────────────────────────────────────
    const cartEmpty = document.getElementById('cart-empty');
    const cartItems = document.getElementById('cart-items');
    const cartCountEl = document.getElementById('cart-count');
    const totalDiscountEl = document.getElementById('cart-total-discount');
    const totalEl = document.getElementById('till-total');
    const dueEl = document.getElementById('till-due');
    const tenderedEl = document.getElementById('till-tendered');
    const changeEl = document.getElementById('till-change');
    const payBtn = document.getElementById('till-pay');
    const voidBtn = document.getElementById('till-void-btn');
    let cart = [], method = 'Cash', customer = null;

    // ── Cart persistence ────────────────────────────────────────────────────────
    function saveCart() {
        try { localStorage.setItem(TILL_CART_KEY, JSON.stringify({ cart, method, tendered: tenderedEl.value, customer })); } catch (e) {}
    }
    function clearSavedCart() { try { localStorage.removeItem(TILL_CART_KEY); } catch (e) {} }
    function selectMethod(m) {
        method = m;
        document.querySelectorAll('.till-method').forEach(x => {
            const on = x.dataset.method === m;
            x.classList.toggle('border-2', on); x.classList.toggle('border-brand-500', on); x.classList.toggle('bg-brand-50', on); x.classList.toggle('text-brand-700', on);
            x.classList.toggle('border', !on); x.classList.toggle('border-neutral-200', !on); x.classList.toggle('text-neutral-600', !on);
        });
        document.getElementById('till-cash-row').style.display = m === 'Cash' ? '' : 'none';
    }
    function loadCart() {
        try {
            const saved = JSON.parse(localStorage.getItem(TILL_CART_KEY) || 'null');
            if (!saved) return;
            if (Array.isArray(saved.cart)) cart = saved.cart;
            if (saved.method) selectMethod(saved.method);
            if (saved.tendered) tenderedEl.value = saved.tendered;
            if (saved.customer) { customer = saved.customer; renderCustomerBanner(); }
        } catch (e) {}
    }

    // ── Customer attach ─────────────────────────────────────────────────────────
    const customerBanner = document.getElementById('customer-banner');
    function renderCustomerBanner() {
        if (customer) {
            customerBanner.classList.remove('hidden');
            customerBanner.classList.add('flex');
            document.getElementById('customer-banner-name').textContent = customer.name || 'Customer';
            document.getElementById('customer-banner-phone').textContent = customer.phone || '';
        } else {
            customerBanner.classList.add('hidden');
            customerBanner.classList.remove('flex');
        }
    }
    function setCustomer(c) { customer = c; renderCustomerBanner(); updatePayState(); saveCart(); }
    document.getElementById('customer-remove').addEventListener('click', () => setCustomer(null));

    function gotoTab(name) { document.querySelector(`.till-tab[data-tab="${name}"]`)?.click(); }

    const custSearch = document.getElementById('cust-search');
    const custResults = document.getElementById('cust-results');
    let custDebounce;
    function attachAndGo(c) {
        setCustomer(c);
        custSearch.value = '';
        custResults.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">Search for a customer, or add a new one below.</p>';
        gotoTab('products');
    }
    async function searchCustomers(q) {
        const term = (q || '').trim();
        custResults.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">' + (term ? 'Searching…' : 'Loading customers…') + '</p>';
        try {
            const res = await fetch('/Till/CustomerSearch?q=' + encodeURIComponent(term));
            const list = await res.json();
            if (!list.length) {
                custResults.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">' +
                    (term ? 'No match. Add a new customer below.' : 'No saved customers yet. Add one below.') + '</p>';
                return;
            }
            custResults.innerHTML = list.map(c =>
                `<button type="button" data-cust='${JSON.stringify(c).replace(/'/g, "&#39;")}' class="cust-row w-full text-left px-3 py-2.5 hover:bg-neutral-50 transition-colors flex items-center justify-between gap-2">
                    <span class="min-w-0"><span class="block text-neutral-800 truncate">${c.name || '(no name)'}</span>${c.phone ? `<span class="block text-[11px] text-neutral-400">${c.phone}</span>` : ''}</span>
                    <span class="text-[11px] text-brand-500 font-medium flex-shrink-0">Attach</span>
                </button>`).join('');
            custResults.querySelectorAll('.cust-row').forEach(b =>
                b.addEventListener('click', () => attachAndGo(JSON.parse(b.dataset.cust.replace(/&#39;/g, "'")))));
        } catch { custResults.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">Could not search.</p>'; }
    }
    custSearch.addEventListener('input', () => { clearTimeout(custDebounce); custDebounce = setTimeout(() => searchCustomers(custSearch.value), 250); });

    document.getElementById('cust-add-toggle').addEventListener('click', () => {
        document.getElementById('cust-add-form').classList.toggle('hidden');
    });
    document.getElementById('cust-save').addEventListener('click', async () => {
        const body = {
            firstName: document.getElementById('cust-first').value.trim(),
            lastName: document.getElementById('cust-last').value.trim(),
            phone: document.getElementById('cust-phone').value.trim(),
            email: document.getElementById('cust-email').value.trim() || null
        };
        if (!body.firstName && !body.lastName) { showError('Enter a name.'); return; }
        if (!body.phone && !body.email) { showError('Enter a phone number.'); return; }
        try {
            const res = await fetch('/Till/CustomerQuickAdd', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (data.success) {
                ['cust-first', 'cust-last', 'cust-phone', 'cust-email'].forEach(id => document.getElementById(id).value = '');
                document.getElementById('cust-add-form').classList.add('hidden');
                attachAndGo({ id: data.id, name: data.name, phone: data.phone });
            } else showError(data.message || 'Could not add customer.');
        } catch { showError('Could not add customer.'); }
    });

    async function add(p) {
        let variantId = null, variantName = null, unitPrice = p.price;
        if (p.variants && p.variants.length) {
            const v = await pickVariant(p);
            if (!v) return;
            variantId = v.id; variantName = v.name; unitPrice = p.price + (v.priceAdjustment || 0);
        }
        const key = p.id + '-' + (variantId ?? '');
        const ex = cart.find(c => c.key === key);
        if ((ex ? ex.qty : 0) + 1 > p.stock) { showError('Not enough stock.'); return; }
        if (ex) ex.qty++;
        else cart.push({ key, productId: p.id, variantId, sku: p.sku, name: p.name, variantName, unitPrice, qty: 1, stock: p.stock, note: null, discountAmount: 0, discountReason: null, discountType: null });
        renderCart();
    }

    function renderCart() {
        const totalDiscount = cart.reduce((s, c) => s + (c.discountAmount || 0), 0);
        const total = cart.reduce((s, c) => s + c.unitPrice * c.qty - (c.discountAmount || 0), 0);
        const count = cart.reduce((s, c) => s + c.qty, 0);

        if (!cart.length) {
            cartEmpty.classList.remove('hidden');
            cartItems.classList.add('hidden');
            cartItems.innerHTML = '';
        } else {
            cartEmpty.classList.add('hidden');
            cartItems.classList.remove('hidden');
            cartItems.innerHTML = cart.map((c, i) => {
                const lineTotal = c.unitPrice * c.qty - (c.discountAmount || 0);
                const hasDiscount = (c.discountAmount || 0) > 0;
                const hasNote = !!c.note;
                return `
                <div class="py-2.5">
                    <div class="flex items-start gap-2">
                        <div class="flex-1 min-w-0">
                            ${c.sku ? `<p class="text-[10px] text-neutral-400 font-mono leading-none mb-0.5">${c.sku}</p>` : ''}
                            <p class="text-xs text-neutral-800 font-medium leading-snug">${c.name}${c.variantName ? `<span class="text-neutral-400 font-normal"> · ${c.variantName}</span>` : ''}</p>
                            <p class="text-[11px] text-neutral-500 mt-0.5">${fmt(c.unitPrice)} each${hasDiscount ? ` &nbsp;<span class="text-emerald-600">-${fmt(c.discountAmount)}</span>${c.discountReason ? ` · ${c.discountReason}` : ''}` : ''}</p>
                            ${hasNote ? `<p class="text-[10px] text-brand-500 mt-0.5 italic truncate">"${c.note}"</p>` : ''}
                        </div>
                        <div class="flex items-center border border-neutral-200 rounded-lg overflow-hidden flex-shrink-0">
                            <button type="button" data-dec="${i}" class="w-6 h-6 text-neutral-500 hover:bg-neutral-50 text-sm leading-none">−</button>
                            <span class="w-6 text-center text-xs font-medium">${c.qty}</span>
                            <button type="button" data-inc="${i}" class="w-6 h-6 text-neutral-500 hover:bg-neutral-50 text-sm leading-none">+</button>
                        </div>
                        <span class="text-xs font-semibold text-neutral-800 w-14 text-right flex-shrink-0">${fmt(lineTotal)}</span>
                        <button type="button" data-del="${i}" class="text-neutral-300 hover:text-red-400 transition-colors flex-shrink-0 mt-0.5">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                        </button>
                    </div>
                    <div class="flex gap-1.5 mt-1.5">
                        <button type="button" data-note-open="${i}" class="flex items-center gap-1 text-[11px] px-2 py-0.5 rounded border transition-colors ${hasNote ? 'border-brand-300 bg-brand-50 text-brand-600' : 'border-neutral-200 text-neutral-400 hover:text-neutral-600'}">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                            NOTE
                        </button>
                        <button type="button" data-disc-open="${i}" class="flex items-center gap-1 text-[11px] px-2 py-0.5 rounded border transition-colors ${hasDiscount ? 'border-emerald-300 bg-emerald-50 text-emerald-600' : 'border-neutral-200 text-neutral-400 hover:text-neutral-600'}">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                            DISCOUNT${hasDiscount ? ` (${fmt(c.discountAmount)})` : ''}
                        </button>
                    </div>
                </div>`;
            }).join('');
            cartItems.querySelectorAll('[data-inc]').forEach(b => b.addEventListener('click', () => qty(+b.dataset.inc, 1)));
            cartItems.querySelectorAll('[data-dec]').forEach(b => b.addEventListener('click', () => qty(+b.dataset.dec, -1)));
            cartItems.querySelectorAll('[data-del]').forEach(b => b.addEventListener('click', () => { cart.splice(+b.dataset.del, 1); renderCart(); }));
            cartItems.querySelectorAll('[data-note-open]').forEach(b => b.addEventListener('click', () => openItemModal(+b.dataset.noteOpen, 'notes')));
            cartItems.querySelectorAll('[data-disc-open]').forEach(b => b.addEventListener('click', () => openItemModal(+b.dataset.discOpen, 'discount')));
        }

        cartCountEl.textContent = count;
        totalDiscountEl.textContent = totalDiscount > 0 ? '-' + fmt(totalDiscount) : fmt(0);
        totalEl.textContent = fmt(total);
        dueEl.textContent = fmt(total);
        updatePayState();
        updateChange();
        saveCart();
    }

    // Pay is only enabled once there's a cart AND an attached customer (mandatory on POS).
    function updatePayState() {
        payBtn.disabled = !cart.length || !customer;
        const hint = document.getElementById('till-customer-hint');
        if (hint) hint.classList.toggle('hidden', !(cart.length && !customer));
    }

    function qty(i, d) {
        const c = cart[i];
        if (d > 0 && c.qty + 1 > c.stock) { showError('Not enough stock.'); return; }
        c.qty += d; if (c.qty <= 0) cart.splice(i, 1); renderCart();
    }

    voidBtn.addEventListener('click', () => { cart = []; tenderedEl.value = ''; setCustomer(null); renderCart(); });

    // ── Hold / recall ─────────────────────────────────────────────────────────
    const holdBtn = document.getElementById('till-hold-btn');
    holdBtn.addEventListener('click', async () => {
        if (!cart.length) { showError('Nothing to hold.'); return; }
        holdBtn.disabled = true;
        try {
            const res = await fetch('/Till/Hold', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ customerUserId: customer?.id || null, items: cart })
            });
            const data = await res.json();
            if (data.success) {
                cart = []; tenderedEl.value = ''; setCustomer(null); clearSavedCart(); renderCart();
                refreshHeldBadge();
                showToast('Sale held');
            } else showError(data.message || 'Could not hold the sale.');
        } catch { showError('Could not hold the sale.'); }
        finally { holdBtn.disabled = false; }
    });

    const heldModal = document.getElementById('till-held');
    const heldList = document.getElementById('held-list');
    const heldCountEl = document.getElementById('till-held-count');

    async function refreshHeldBadge() {
        try {
            const res = await fetch('/Till/ParkedSales');
            const list = await res.json();
            heldCountEl.textContent = list.length;
            heldCountEl.classList.toggle('hidden', list.length === 0);
            document.getElementById('hamburger-dot')?.classList.toggle('hidden', list.length === 0);
            return list;
        } catch { return []; }
    }

    function renderHeldList(list) {
        if (!list.length) { heldList.innerHTML = '<p class="text-center text-neutral-400 py-8 text-xs">No held sales.</p>'; return; }
        heldList.innerHTML = list.map(h => {
            const dt = new Date(h.createdAt);
            const when = dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ' ' +
                         dt.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
            const who = h.customerName || h.label || 'Walk-in';
            return `<div class="px-4 py-3 flex items-center gap-3">
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-neutral-800 truncate">${who}</p>
                    <p class="text-[11px] text-neutral-400">${when} · ${h.itemCount} item${h.itemCount === 1 ? '' : 's'} · ${h.cashierName || ''}</p>
                </div>
                <span class="font-semibold text-neutral-800 flex-shrink-0">${fmt(h.total)}</span>
                <button type="button" data-recall="${h.id}" class="flex-shrink-0 text-xs font-medium text-brand-600 border border-brand-200 rounded-lg px-2.5 py-1.5 hover:bg-brand-50 transition-colors">Recall</button>
                <button type="button" data-discard="${h.id}" class="flex-shrink-0 text-neutral-300 hover:text-red-400 transition-colors" title="Discard">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
            </div>`;
        }).join('');
        heldList.querySelectorAll('[data-recall]').forEach(b => b.addEventListener('click', () => recallHeld(+b.dataset.recall)));
        heldList.querySelectorAll('[data-discard]').forEach(b => b.addEventListener('click', () => discardHeld(+b.dataset.discard)));
    }

    async function openHeld() {
        heldModal.classList.remove('hidden');
        heldList.innerHTML = '<p class="text-center text-neutral-400 py-8 text-xs">Loading…</p>';
        renderHeldList(await refreshHeldBadge());
    }

    async function recallHeld(id) {
        if (cart.length && !confirm('Recall this held sale? Your current cart will be replaced.')) return;
        try {
            const res = await fetch('/Till/RecallParkedSale/' + id, {
                method: 'POST', headers: { 'RequestVerificationToken': token }
            });
            const data = await res.json();
            if (!data.success) { showError(data.message || 'Could not recall the sale.'); refreshHeldBadge(); return; }
            cart = JSON.parse(data.cart || '[]');
            setCustomer(data.customerUserId ? { id: data.customerUserId, name: data.customerName } : null);
            tenderedEl.value = '';
            heldModal.classList.add('hidden');
            renderCart();
            refreshHeldBadge();
            gotoTab('products');
        } catch { showError('Could not recall the sale.'); }
    }

    async function discardHeld(id) {
        if (!confirm('Discard this held sale?')) return;
        try {
            await fetch('/Till/DeleteParkedSale/' + id, { method: 'POST', headers: { 'RequestVerificationToken': token } });
        } catch {}
        renderHeldList(await refreshHeldBadge());
    }

    document.getElementById('till-held-btn').addEventListener('click', openHeld);
    document.getElementById('held-close').addEventListener('click', () => heldModal.classList.add('hidden'));
    heldModal.addEventListener('click', e => { if (e.target === heldModal) heldModal.classList.add('hidden'); });

    function showToast(msg) {
        const el = document.createElement('div');
        el.className = 'fixed top-4 left-1/2 -translate-x-1/2 bg-neutral-900 text-white text-sm px-5 py-3 rounded-lg shadow-lg z-[100] transition-opacity';
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 2000);
    }

    // ── Payment method ────────────────────────────────────────────────────────
    document.querySelectorAll('.till-method').forEach(b => b.addEventListener('click', () => {
        selectMethod(b.dataset.method);
        updateChange(); saveCart();
    }));
    tenderedEl.addEventListener('input', () => { updateChange(); saveCart(); });
    function updateChange() {
        const t = cart.reduce((s, c) => s + c.unitPrice * c.qty - (c.discountAmount || 0), 0);
        changeEl.textContent = fmt(Math.max(0, (parseFloat(tenderedEl.value) || 0) - t));
    }

    // ── Keyboard shortcuts ────────────────────────────────────────────────────
    document.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.target.closest('input, button, [contenteditable]') && !payBtn.disabled) {
            e.preventDefault(); payBtn.click();
        }
        if (e.key === 'Escape') {
            variantModal.classList.add('hidden');
            document.getElementById('till-done').classList.add('hidden');
        }
    });

    // ── Scan anywhere ───────────────────────────────────────────────────────────
    // Hardware scanners type a burst of characters then Enter. Capture that burst
    // wherever focus is (so the cashier needn't click the search box first) and route
    // it to onScan. Capture phase + stopImmediatePropagation keeps it from triggering
    // the Enter-to-pay shortcut above.
    let scanBuf = '', scanLast = 0;
    document.addEventListener('keydown', e => {
        const inField = !!e.target.closest('input, textarea, [contenteditable]');
        const now = Date.now();
        if (e.key === 'Enter') {
            if (!inField && scanBuf.length >= 3 && now - scanLast < 120) {
                e.preventDefault(); e.stopImmediatePropagation();
                const code = scanBuf;
                onScan(code);
            }
            scanBuf = '';
            return;
        }
        if (inField) { scanBuf = ''; return; }
        if (e.key.length === 1) {
            if (now - scanLast > 120) scanBuf = '';
            scanBuf += e.key; scanLast = now;
        }
    }, true);

    // ── Checkout ──────────────────────────────────────────────────────────────
    payBtn.addEventListener('click', async () => {
        if (!cart.length) return;
        payBtn.disabled = true; payBtn.querySelector('span').textContent = '…';
        try {
            const res = await fetch('/Till/Checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ paymentMethod: method, amountTendered: parseFloat(tenderedEl.value) || 0,
                    customerUserId: customer?.id || null,
                    items: cart.map(c => ({ productId: c.productId, variantId: c.variantId, quantity: c.qty, note: c.note || null, discountAmount: c.discountAmount || 0, discountReason: c.discountReason || null, discountType: c.discountType || null })) })
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('till-done-info').innerHTML =
                    `<span class="font-medium">${fmt(data.total)}</span> · ${data.orderNumber}` +
                    (data.change > 0 ? `<br>Change due: <span class="font-medium text-emerald-600">${fmt(data.change)}</span>` : '');
                document.getElementById('till-receipt').href = '/Till/Receipt/' + data.orderId;
                cart = []; tenderedEl.value = ''; setCustomer(null); clearSavedCart(); renderCart();
                document.getElementById('till-done').classList.remove('hidden');
            } else showError(data.message || 'Could not complete the sale.');
        } finally { payBtn.querySelector('span').textContent = 'Pay'; updatePayState(); }
    });

    document.getElementById('till-new').addEventListener('click', () => {
        cart = []; tenderedEl.value = ''; setCustomer(null);
        document.getElementById('till-done').classList.add('hidden');
        renderCart();
    });

    // ── Orders tab ────────────────────────────────────────────────────────────
    async function loadOrders() {
        const el = document.getElementById('orders-list');
        el.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">Loading…</p>';
        try {
            const res = await fetch('/Till/RecentOrders');
            const orders = await res.json();
            if (!orders.length) {
                el.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">No sales yet on this till.</p>';
                return;
            }
            el.innerHTML = orders.map(o => {
                const dt = new Date(o.createdAt);
                const when = dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ' ' +
                             dt.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                const who = o.customerName ? ' · ' + o.customerName : '';
                const by = o.cashierName ? ' · by ' + o.cashierName : '';
                return `<div data-receipt="${o.id}" title="View / print receipt"
                     class="px-3 py-2.5 flex items-center gap-2 cursor-pointer hover:bg-neutral-50 transition-colors">
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-neutral-800 truncate">${o.orderNumber}</p>
                        <p class="text-[11px] text-neutral-400 truncate">${when} · ${o.itemCount} item${o.itemCount === 1 ? '' : 's'} · ${o.method}${who}${by}</p>
                    </div>
                    <span class="font-semibold text-neutral-800 flex-shrink-0">${fmt(o.total)}</span>
                    <a href="/Till/Receipt/${o.id}" target="_blank" title="Reprint receipt"
                       class="flex-shrink-0 text-neutral-400 hover:text-brand-500 transition-colors p-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                    </a>
                    <button type="button" data-refund="${o.orderNumber}" title="Refund this sale"
                            class="flex-shrink-0 text-neutral-400 hover:text-red-500 transition-colors p-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h10a4 4 0 014 4v1m-4-9l-4 4 4 4"/></svg>
                    </button>
                </div>`;
            }).join('');
            // Click anywhere on a row (except the action buttons) to view/print the receipt.
            el.querySelectorAll('[data-receipt]').forEach(row =>
                row.addEventListener('click', (e) => {
                    if (e.target.closest('a,button')) return;
                    window.open('/Till/Receipt/' + row.dataset.receipt, '_blank');
                }));
            el.querySelectorAll('[data-refund]').forEach(b =>
                b.addEventListener('click', () => window.tillOpenRefund?.(b.dataset.refund)));
        } catch { el.innerHTML = '<p class="text-center text-neutral-400 py-6 text-xs">Could not load orders.</p>'; }
    }

    function showError(msg) {
        const el = document.createElement('div');
        el.className = 'fixed top-4 left-1/2 -translate-x-1/2 bg-red-600 text-white text-sm px-5 py-3 rounded-lg shadow-lg z-[100] transition-opacity';
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 2500);
    }

    // ── Item note/discount modal ──────────────────────────────────────────────
    let discountReasons = [];
    let modalItemIdx = -1;

    async function loadDiscountReasons() {
        try {
            const res = await fetch('/Till/DiscountReasons');
            discountReasons = await res.json();
        } catch { discountReasons = []; }
    }

    const itemModal = document.getElementById('item-modal');
    const modalItemName = document.getElementById('modal-item-name');

    function openItemModal(idx, tab) {
        modalItemIdx = idx;
        const c = cart[idx];
        modalItemName.textContent = (c.sku ? c.sku + ' · ' : '') + c.name + (c.variantName ? ' · ' + c.variantName : '');
        switchModalTab(tab);
        itemModal.classList.remove('hidden');
    }

    function switchModalTab(tab) {
        document.getElementById('modal-tab-notes').classList.toggle('border-b-2', tab === 'notes');
        document.getElementById('modal-tab-notes').classList.toggle('border-brand-500', tab === 'notes');
        document.getElementById('modal-tab-notes').classList.toggle('text-brand-600', tab === 'notes');
        document.getElementById('modal-tab-notes').classList.toggle('text-neutral-400', tab !== 'notes');
        document.getElementById('modal-tab-discount').classList.toggle('border-b-2', tab === 'discount');
        document.getElementById('modal-tab-discount').classList.toggle('border-brand-500', tab === 'discount');
        document.getElementById('modal-tab-discount').classList.toggle('text-brand-600', tab === 'discount');
        document.getElementById('modal-tab-discount').classList.toggle('text-neutral-400', tab !== 'discount');
        document.getElementById('modal-notes-panel').classList.toggle('hidden', tab !== 'notes');
        document.getElementById('modal-discount-panel').classList.toggle('hidden', tab !== 'discount');

        if (tab === 'notes') {
            document.getElementById('item-note-input').value = cart[modalItemIdx]?.note || '';
        } else {
            showDiscountStep1();
        }
    }

    document.getElementById('modal-tab-notes').addEventListener('click', () => switchModalTab('notes'));
    document.getElementById('modal-tab-discount').addEventListener('click', () => switchModalTab('discount'));
    document.getElementById('item-modal-close').addEventListener('click', () => itemModal.classList.add('hidden'));
    itemModal.addEventListener('click', e => { if (e.target === itemModal) itemModal.classList.add('hidden'); });

    document.getElementById('item-note-clear').addEventListener('click', () => { document.getElementById('item-note-input').value = ''; });
    document.getElementById('item-note-done').addEventListener('click', () => {
        if (modalItemIdx >= 0) {
            cart[modalItemIdx].note = document.getElementById('item-note-input').value.trim() || null;
            renderCart();
        }
        itemModal.classList.add('hidden');
    });

    // Discount flow
    function showDiscountStep1() {
        document.getElementById('discount-step1').classList.remove('hidden');
        document.getElementById('discount-step2').classList.add('hidden');
        document.getElementById('discount-step3').classList.add('hidden');
        const list = document.getElementById('discount-reasons-list');
        if (!discountReasons.length) {
            list.innerHTML = '<p class="px-4 py-6 text-sm text-neutral-400 text-center">No discount reasons configured.<br>Add them in Admin → POS → Discount Reasons.</p>';
            return;
        }
        list.innerHTML = discountReasons.map(r =>
            `<button type="button" data-rid="${r.id}" class="w-full text-left px-4 py-3 border-b border-neutral-100 text-sm text-blue-700 hover:bg-neutral-50 transition-colors">${r.name}</button>`
        ).join('');
        list.querySelectorAll('[data-rid]').forEach(b => b.addEventListener('click', () => showDiscountStep2(+b.dataset.rid)));
    }

    function showDiscountStep2(reasonId) {
        const reason = discountReasons.find(r => r.id === reasonId);
        if (!reason) return;
        document.getElementById('discount-step1').classList.add('hidden');
        document.getElementById('discount-step2').classList.remove('hidden');
        document.getElementById('discount-step3').classList.add('hidden');
        document.getElementById('discount-step2-title').textContent = reason.name;
        document.getElementById('discount-step2-back').onclick = showDiscountStep1;

        const customOptions = [
            { label: 'Discount by Percentage', type: 'Percentage' },
            { label: 'Discount by Amount', type: 'Amount' },
            { label: 'Set New Price', type: 'NewPrice' },
        ];
        const presetOptions = (reason.presets || []).map(p => ({ label: p.label, type: p.type, value: p.value, isPreset: true }));
        const allOptions = [...customOptions, ...presetOptions];

        const list = document.getElementById('discount-types-list');
        list.innerHTML = allOptions.map((opt, i) =>
            `<button type="button" data-oidx="${i}" class="w-full text-left px-4 py-3 border-b border-neutral-100 text-sm text-blue-700 hover:bg-neutral-50 transition-colors">${opt.label}</button>`
        ).join('');
        list.querySelectorAll('[data-oidx]').forEach(b => b.addEventListener('click', () => {
            const opt = allOptions[+b.dataset.oidx];
            if (opt.isPreset) { applyDiscount(reason.name, opt.type, opt.value); itemModal.classList.add('hidden'); renderCart(); }
            else showDiscountStep3(reason.name, opt.type);
        }));
    }

    let numpadValue = '';
    let numpadReasonName = '', numpadType = '';

    function showDiscountStep3(reasonName, type) {
        document.getElementById('discount-step1').classList.add('hidden');
        document.getElementById('discount-step2').classList.add('hidden');
        document.getElementById('discount-step3').classList.remove('hidden');
        document.getElementById('discount-step3-title').textContent = reasonName;
        document.getElementById('discount-type-label').textContent = type === 'Amount' ? '₦' : type === 'NewPrice' ? '₦ new' : '%';
        numpadValue = ''; numpadReasonName = reasonName; numpadType = type;
        document.getElementById('numpad-display').textContent = '';

        const reason = discountReasons.find(r => r.name === reasonName);
        document.getElementById('discount-step3-back').onclick = () => { if (reason) showDiscountStep2(reason.id); else showDiscountStep1(); };
        document.getElementById('discount-update').onclick = () => {
            const val = parseFloat(numpadValue) || 0;
            if (val <= 0) { showError('Enter a value.'); return; }
            applyDiscount(numpadReasonName, numpadType, val);
            itemModal.classList.add('hidden');
            renderCart();
        };
    }

    document.querySelectorAll('[data-num]').forEach(b => b.addEventListener('click', () => {
        if (b.dataset.num === '.' && numpadValue.includes('.')) return;
        if (numpadValue.length >= 9) return;
        numpadValue += b.dataset.num;
        document.getElementById('numpad-display').textContent = numpadValue;
    }));
    document.getElementById('numpad-backspace').addEventListener('click', () => {
        numpadValue = numpadValue.slice(0, -1);
        document.getElementById('numpad-display').textContent = numpadValue;
    });

    function applyDiscount(reasonName, type, value) {
        const c = cart[modalItemIdx];
        if (!c) return;
        const lineTotal = c.unitPrice * c.qty;
        let discountAmount = 0;
        if (type === 'Percentage') discountAmount = lineTotal * (value / 100);
        else if (type === 'Amount') discountAmount = value;
        else if (type === 'NewPrice') discountAmount = Math.max(0, lineTotal - value * c.qty);
        c.discountAmount = Math.min(Math.max(0, discountAmount), lineTotal);
        c.discountReason = reasonName;
        c.discountType = type;
    }

    // Boot
    loadCategories();
    loadDiscountReasons();
    loadCart();
    renderCart();
    refreshHeldBadge();
}());

