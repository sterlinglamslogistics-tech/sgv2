@model SterlingLams.Web.Models.Domain.Order
@{
    ViewData["Title"] = "Order " + Model.OrderNumber;
    Layout = "_Layout";
}

<section class="max-w-4xl mx-auto px-6 py-16">

    <!-- Back + header -->
    <div class="mb-8">
        <a asp-controller="Account" asp-action="Orders"
           class="text-xs tracking-widest uppercase text-neutral-400 hover:text-neutral-700 transition-colors">
            ← My Orders
        </a>
        <div class="flex items-end justify-between gap-4 flex-wrap mt-4">
            <div>
                <h1 class="font-cormorant text-3xl font-light">Order @Model.OrderNumber</h1>
                <p class="text-sm text-neutral-400 mt-1">Placed @Model.CreatedAt.ToString("dddd, MMMM d, yyyy")</p>
            </div>
            <form asp-controller="Cart" asp-action="Reorder" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                <button type="submit" class="text-xs tracking-[0.2em] uppercase border border-neutral-900 text-neutral-900 px-6 py-3 rounded-md hover:bg-neutral-900 hover:text-white transition-colors">Reorder these items</button>
            </form>
        </div>
    </div>

    <!-- Status banner -->
    @{
        var (bannerBg, bannerText, bannerMsg) = Model.Status switch
        {
            OrderStatus.Delivered   => ("bg-emerald-50 border-emerald-100", "text-emerald-800", "Your order has been delivered."),
            OrderStatus.Shipped     => ("bg-blue-50 border-blue-100",    "text-blue-800",    "Your order is on its way."),
            OrderStatus.ReadyForPickup => ("bg-amber-50 border-amber-100", "text-amber-800", "Your order is ready for pickup."),
            OrderStatus.Cancelled   => ("bg-red-50 border-red-100",      "text-red-800",     "This order has been cancelled."),
            OrderStatus.Processing  => ("bg-neutral-50 border-neutral-200","text-neutral-700","Your order is being processed."),
            OrderStatus.AwaitingTransfer => ("bg-amber-50 border-amber-100","text-amber-800","We're preparing your order — some items are coming in from another branch."),
            _                       => ("bg-neutral-50 border-neutral-200","text-neutral-700","Your order is confirmed.")
        };
        string statusLabel = Model.Status == OrderStatus.AwaitingTransfer ? "Preparing your order" : Model.Status.ToString();
    }
    <div class="border rounded-sm px-6 py-4 mb-8 @bannerBg">
        <div class="flex items-center justify-between">
            <p class="text-sm font-medium @bannerText">@bannerMsg</p>
            <span class="text-xs px-3 py-1 rounded-full bg-white/70 @bannerText border border-current/20">@statusLabel</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Items -->
        <div class="lg:col-span-2 space-y-4">
            <h2 class="text-sm tracking-widest uppercase text-neutral-400">Items</h2>

            @foreach (var item in Model.Items)
            {
                var img = item.Product?.Images?.FirstOrDefault();
                <div class="flex gap-4 py-4 border-b border-neutral-100">
                    <div class="w-20 h-20 bg-neutral-50 rounded-sm flex-shrink-0 overflow-hidden">
                        @if (img != null)
                        {
                            <img src="@Img.Cld(img.Url, 160, 160)" alt="@item.ProductName"
                                 loading="lazy" decoding="async" width="80" height="80"
                                 class="w-full h-full object-cover" />
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-sm text-neutral-900">@item.ProductName</p>
                        @if (!string.IsNullOrEmpty(item.VariantName))
                        {
                            <p class="text-xs text-neutral-500 mt-0.5">@item.VariantName</p>
                        }
                        <p class="text-xs text-neutral-400 mt-1">Qty: @item.Quantity</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <p class="text-sm font-medium">₦@item.UnitPrice.ToString("N0")</p>
                        @if (item.Quantity > 1)
                        {
                            <p class="text-xs text-neutral-400">₦@item.LineTotal.ToString("N0") total</p>
                        }
                    </div>
                </div>
            }

            <!-- Totals -->
            <div class="pt-4 space-y-2">
                <div class="flex justify-between text-sm text-neutral-500">
                    <span>Subtotal</span>
                    <span>₦@Model.Subtotal.ToString("N0")</span>
                </div>
                <div class="flex justify-between text-sm text-neutral-500">
                    <span>Delivery fee</span>
                    <span>@(Model.DeliveryFee > 0 ? "₦" + Model.DeliveryFee.ToString("N0") : "Free")</span>
                </div>
                @if (Model.Tax > 0)
                {
                    <div class="flex justify-between text-sm text-neutral-500">
                        <span>VAT</span>
                        <span>₦@Model.Tax.ToString("N0")</span>
                    </div>
                }
                <div class="flex justify-between text-base font-medium border-t border-neutral-100 pt-3">
                    <span>Total</span>
                    <span>₦@Model.Total.ToString("N0")</span>
                </div>
            </div>
        </div>

        <!-- Sidebar: Fulfillment + Payment -->
        <div class="space-y-6">

            <!-- Fulfillment -->
            <div class="bg-neutral-50 rounded-sm p-5">
                <h3 class="text-xs tracking-widest uppercase text-neutral-400 mb-3">Fulfillment</h3>
                <p class="text-sm font-medium text-neutral-800 mb-2">
                    @(Model.FulfillmentType == FulfillmentType.StorePickup ? "Store Pickup" : "Home Delivery")
                </p>
                @if (Model.PickupStore != null)
                {
                    <div class="text-xs text-neutral-500 space-y-0.5">
                        <p class="font-medium text-neutral-700">@Model.PickupStore.Name</p>
                        <p>@Model.PickupStore.Address</p>
                        @if (Model.PickupStore.Phone != null)
                        {
                            <p>@Model.PickupStore.Phone</p>
                        }
                        @if (Model.PickupStore.OpeningHours != null)
                        {
                            <p class="text-neutral-400">@Model.PickupStore.OpeningHours</p>
                        }
                    </div>
                }
                @if (Model.DeliveryAddress != null)
                {
                    var a = Model.DeliveryAddress;
                    <div class="text-xs text-neutral-500 space-y-0.5">
                        <p class="font-medium text-neutral-700">@a.FullName</p>
                        <p>@a.Line1@(a.Line2 != null ? ", " + a.Line2 : "")</p>
                        <p>@a.City, @a.State</p>
                        @if (!string.IsNullOrEmpty(a.Phone))
                        {
                            <p>@a.Phone</p>
                        }
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                {
                    <div class="mt-3 pt-3 border-t border-neutral-200">
                        <p class="text-[10px] tracking-widest uppercase text-neutral-400 mb-1">Tracking number</p>
                        <p class="text-sm font-mono text-neutral-800 select-all break-all">@Model.TrackingNumber</p>
                    </div>
                }
            </div>

            <!-- Payment -->
            <div class="bg-neutral-50 rounded-sm p-5">
                <h3 class="text-xs tracking-widest uppercase text-neutral-400 mb-3">Payment</h3>
                <div class="text-xs space-y-1.5 text-neutral-600">
                    <div class="flex justify-between">
                        <span>Status</span>
                        @if (Model.IsPaid)
                        {
                            <span class="text-emerald-600 font-medium">Paid ✓</span>
                        }
                        else
                        {
                            <span class="text-amber-600 font-medium">Pending</span>
                        }
                    </div>
                    @if (Model.PaidAt.HasValue)
                    {
                        <div class="flex justify-between">
                            <span>Date</span>
                            <span>@Model.PaidAt.Value.ToString("dd MMM yyyy")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PaymentReference))
                    {
                        <div class="flex justify-between items-center">
                            <span>Reference</span>
                            <code class="font-mono text-[10px] text-neutral-500">@Model.PaymentReference</code>
                        </div>
                    }
                </div>
            </div>

            <!-- Need help? -->
            <div class="text-center">
                <p class="text-xs text-neutral-400 mb-2">Questions about this order?</p>
                <a href="mailto:hello@sterlinglams.com?subject=Order @Model.OrderNumber"
                   class="text-xs tracking-widest uppercase border border-neutral-300 px-4 py-2 rounded-sm hover:bg-neutral-50 transition-colors text-neutral-600">
                    Contact Us
                </a>
            </div>
        </div>
    </div>
</section>
