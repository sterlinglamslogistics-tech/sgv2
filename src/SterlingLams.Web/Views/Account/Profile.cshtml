@model SterlingLams.Web.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Account";
    var tab = Model.ActiveTab;
}

<div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Header -->
    <div class="mb-8">
        <p class="section-label">Your account</p>
        <div class="flex items-baseline justify-between">
            <h1 class="font-cormorant text-4xl font-light">Hello, @Model.FirstName</h1>
            <form asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">Sign out</button>
            </form>
        </div>
    </div>

    <!-- Loyalty points -->
    @if (Model.LoyaltyEnabled)
    {
        <div class="mb-8 flex items-center justify-between border border-neutral-200 bg-neutral-50 px-5 py-4 rounded-sm">
            <div>
                <p class="text-xs tracking-[0.15em] uppercase text-neutral-400">Loyalty points</p>
                <p class="font-cormorant text-3xl font-light text-neutral-900">@Model.LoyaltyPoints.ToString("N0")</p>
            </div>
            <p class="text-xs text-neutral-400 max-w-[14rem] text-right">Earn 1 point for every ₦@Model.LoyaltyNairaPerPoint.ToString("N0") spent on completed orders.</p>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-sm">@TempData["Error"]</div>
    }

    <!-- Tab bar -->
    <div class="flex border-b border-neutral-200 mb-10 gap-0 flex-wrap">
        @foreach (var (label, slug) in new[] { ("Profile", "profile"), ("Orders", "orders"), ("Addresses", "addresses"), ("Security", "security") })
        {
            <a asp-action="Profile" asp-route-tab="@slug"
               class="px-5 py-3 text-xs tracking-[0.15em] uppercase transition-colors border-b-2 -mb-px
                      @(tab == slug ? "border-neutral-900 text-neutral-900 font-medium" : "border-transparent text-neutral-400 hover:text-neutral-700")">
                @label
                @if (slug == "orders" && Model.RecentOrders.Any())
                {
                    <span class="ml-1.5 text-[10px] bg-neutral-100 text-neutral-500 px-1.5 py-0.5 rounded-full">@Model.RecentOrders.Count</span>
                }
            </a>
        }
    </div>

    @if (!Model.EmailConfirmed)
    {
        <div class="mb-8 flex flex-wrap items-center justify-between gap-3 border border-amber-200 bg-amber-50 px-5 py-3 rounded-sm">
            <p class="text-xs text-amber-800">Your email <span class="font-medium">@Model.Email</span> isn't confirmed yet.</p>
            <form asp-action="ResendConfirmation" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-xs font-medium text-amber-900 underline hover:no-underline">Resend confirmation link</button>
            </form>
        </div>
    }

    <!-- ─── Profile Tab ──────────────────────────────────────────────────── -->
    @if (tab == "profile")
    {
        <div class="space-y-10">

            <!-- View -->
            <section>
                <div class="flex items-baseline justify-between mb-6">
                    <h2 class="font-cormorant text-2xl font-light">Account Details</h2>
                    <button type="button" id="edit-toggle"
                            class="text-xs tracking-widest uppercase text-neutral-400 hover:text-neutral-900 transition-colors">
                        Edit
                    </button>
                </div>

                <dl class="space-y-4">
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Name</dt>
                        <dd class="text-sm text-neutral-700">@Model.FirstName @Model.LastName</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Email</dt>
                        <dd class="text-sm text-neutral-700">@Model.Email</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Phone</dt>
                        <dd class="text-sm text-neutral-700">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-6">
                        <dt class="text-xs tracking-[0.15em] uppercase text-neutral-400 w-32 flex-shrink-0 pt-0.5">Member since</dt>
                        <dd class="text-sm text-neutral-700">@Model.CreatedAt.ToString("MMMM yyyy")</dd>
                    </div>
                </dl>
            </section>

            <!-- Edit form (hidden by default) -->
            <section id="edit-form" class="hidden border-t border-neutral-100 pt-8">
                <h2 class="font-cormorant text-2xl font-light mb-6">Edit Profile</h2>
                <form asp-action="UpdateProfile" method="post" class="space-y-4 max-w-sm">
                    @Html.AntiForgeryToken()
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">First Name</label>
                            <input name="FirstName" value="@Model.FirstName" required class="form-input" />
                        </div>
                        <div>
                            <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Last Name</label>
                            <input name="LastName" value="@Model.LastName" required class="form-input" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Phone</label>
                        <input name="Phone" type="tel" value="@Model.Phone" placeholder="+234 800 000 0000" class="form-input" />
                    </div>
                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="btn-primary text-sm py-3 px-8">Save Changes</button>
                        <button type="button" id="edit-cancel"
                                class="btn-outline text-sm py-3 px-8">Cancel</button>
                    </div>
                </form>
            </section>

        </div>
    }

    <!-- ─── Orders Tab ───────────────────────────────────────────────────── -->
    @if (tab == "orders")
    {
        <section>
            <h2 class="font-cormorant text-2xl font-light mb-6">Your Orders</h2>

            @if (!Model.RecentOrders.Any())
            {
                <div class="text-center py-16">
                    <p class="text-neutral-400 font-light mb-6">You haven't placed any orders yet.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn-outline">Start Shopping</a>
                </div>
            }
            else
            {
                <div class="divide-y divide-neutral-100">
                    @foreach (var order in Model.RecentOrders)
                    {
                        var statusColor = order.Status switch
                        {
                            "Delivered" => "text-emerald-600",
                            "Cancelled" => "text-red-500",
                            "Confirmed" or "Processing" => "text-blue-600",
                            _ => "text-neutral-400"
                        };
                        <div class="flex items-center gap-3 py-5 -mx-4 px-4 hover:bg-neutral-50 transition-colors group">
                            <a asp-action="OrderDetail" asp-route-id="@order.Id" class="flex items-center justify-between flex-1 min-w-0">
                                <div>
                                    <p class="text-sm text-neutral-800 font-medium font-mono">@order.OrderNumber</p>
                                    <p class="text-xs text-neutral-400 mt-0.5">
                                        @order.CreatedAt.ToString("d MMM yyyy") &nbsp;·&nbsp;
                                        @order.ItemCount piece@(order.ItemCount == 1 ? "" : "s")
                                    </p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-neutral-700 font-medium">@order.FormattedTotal</p>
                                    <span class="text-[10px] tracking-widest uppercase @statusColor">@order.Status</span>
                                </div>
                            </a>
                            <form asp-controller="Cart" asp-action="Reorder" method="post" class="shrink-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@order.Id" />
                                <button type="submit" class="text-[10px] tracking-widest uppercase text-neutral-500 hover:text-white hover:bg-neutral-900 border border-neutral-200 rounded-md px-3 py-2 transition-colors whitespace-nowrap">Reorder</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </section>
    }

    <!-- ─── Addresses Tab ────────────────────────────────────────────────── -->
    @if (tab == "addresses")
    {
        <section>
            <h2 class="font-cormorant text-2xl font-light mb-6">Saved Addresses</h2>

            @if (Model.Addresses.Any())
            {
                <div class="grid sm:grid-cols-2 gap-4 mb-8">
                    @foreach (var a in Model.Addresses.OrderByDescending(x => x.IsDefault).ThenBy(x => x.Id))
                    {
                        <div class="border @(a.IsDefault ? "border-neutral-900" : "border-neutral-200") rounded-sm p-5">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs tracking-[0.15em] uppercase text-neutral-500">@a.Label</span>
                                @if (a.IsDefault)
                                {
                                    <span class="text-[10px] bg-neutral-900 text-white px-2 py-0.5 rounded-full">Default</span>
                                }
                            </div>
                            <p class="text-sm text-neutral-800">@a.FullName</p>
                            <p class="text-sm text-neutral-500 mt-1">@a.Line1@(string.IsNullOrEmpty(a.Line2) ? "" : ", " + a.Line2)</p>
                            <p class="text-sm text-neutral-500">@a.City, @a.State@(string.IsNullOrEmpty(a.PostalCode) ? "" : " " + a.PostalCode)</p>
                            <p class="text-sm text-neutral-500">@a.Phone</p>

                            <div class="flex items-center gap-3 mt-4 text-xs">
                                @if (!a.IsDefault)
                                {
                                    <form asp-action="SetDefaultAddress" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <button type="submit" class="text-neutral-500 hover:text-neutral-900 underline underline-offset-2">Set as default</button>
                                    </form>
                                }
                                <details class="inline-block">
                                    <summary class="cursor-pointer text-neutral-500 hover:text-neutral-900 underline underline-offset-2 list-none">Edit</summary>
                                    <form asp-action="SaveAddress" method="post" class="mt-3 space-y-2 text-left">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <input name="label" value="@a.Label" placeholder="Label" class="form-input text-sm" />
                                        <input name="fullName" value="@a.FullName" placeholder="Full name" required class="form-input text-sm" />
                                        <input name="phone" value="@a.Phone" placeholder="Phone" required class="form-input text-sm" />
                                        <input name="line1" value="@a.Line1" placeholder="Address line 1" required class="form-input text-sm" />
                                        <input name="line2" value="@a.Line2" placeholder="Address line 2 (optional)" class="form-input text-sm" />
                                        <div class="grid grid-cols-2 gap-2">
                                            <input name="city" value="@a.City" placeholder="City" required class="form-input text-sm" />
                                            <input name="state" value="@a.State" placeholder="State" required class="form-input text-sm" />
                                        </div>
                                        <input name="postalCode" value="@a.PostalCode" placeholder="Postal code (optional)" class="form-input text-sm" />
                                        <label class="flex items-center gap-2 text-xs text-neutral-600"><input type="checkbox" name="isDefault" value="true" @(a.IsDefault ? "checked" : "") /> Default address</label>
                                        <button type="submit" class="btn-primary text-xs py-2 px-5">Save</button>
                                    </form>
                                </details>
                                <form asp-action="DeleteAddress" method="post" class="inline" onsubmit="return confirm('Remove this address?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@a.Id" />
                                    <button type="submit" class="text-red-500 hover:text-red-700 underline underline-offset-2">Delete</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-neutral-400 font-light mb-8">You don't have any saved addresses yet.</p>
            }

            <details class="border-t border-neutral-100 pt-6">
                <summary class="cursor-pointer text-sm tracking-widest uppercase text-neutral-500 hover:text-neutral-900 list-none">+ Add a new address</summary>
                <form asp-action="SaveAddress" method="post" class="mt-5 space-y-3 max-w-sm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="0" />
                    <input name="label" placeholder="Label (e.g. Home, Office)" class="form-input" />
                    <input name="fullName" placeholder="Full name" required class="form-input" />
                    <input name="phone" type="tel" placeholder="Phone" required class="form-input" />
                    <input name="line1" placeholder="Address line 1" required class="form-input" />
                    <input name="line2" placeholder="Address line 2 (optional)" class="form-input" />
                    <div class="grid grid-cols-2 gap-3">
                        <input name="city" placeholder="City" required class="form-input" />
                        <input name="state" placeholder="State" required class="form-input" />
                    </div>
                    <input name="postalCode" placeholder="Postal code (optional)" class="form-input" />
                    <label class="flex items-center gap-2 text-xs text-neutral-600"><input type="checkbox" name="isDefault" value="true" /> Set as default address</label>
                    <button type="submit" class="btn-primary text-sm py-3 px-8">Save Address</button>
                </form>
            </details>
        </section>
    }

    <!-- ─── Security Tab ─────────────────────────────────────────────────── -->
    @if (tab == "security")
    {
        <section>
            <h2 class="font-cormorant text-2xl font-light mb-6">Change Password</h2>

            <form asp-action="ChangePassword" method="post" class="space-y-4 max-w-sm">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 px-4 py-3 border border-red-100 rounded-sm"></div>

                <div>
                    <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Current Password</label>
                    <input name="CurrentPassword" type="password" autocomplete="current-password" required class="form-input" />
                </div>
                <div>
                    <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">New Password</label>
                    <input name="NewPassword" type="password" autocomplete="new-password" required minlength="8" class="form-input" />
                    <p class="text-[11px] text-neutral-400 mt-1">Minimum 8 characters.</p>
                </div>
                <div>
                    <label class="block text-xs tracking-[0.15em] uppercase text-neutral-500 mb-2">Confirm New Password</label>
                    <input name="ConfirmNewPassword" type="password" autocomplete="new-password" required minlength="8" class="form-input" />
                </div>
                <div class="pt-2">
                    <button type="submit" class="btn-primary text-sm py-3 px-8">Update Password</button>
                </div>
            </form>
        </section>
    }
</div>
