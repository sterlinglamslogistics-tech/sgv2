@using SterlingLams.Web.Services
@inject ISettingsService SettingsService
@{
    ViewData["Title"] = "Contact Us";
    ViewData["Description"] = "Get in touch with Sterlin Glams. Visit any of our three Lagos boutiques or reach us by phone and email.";
    Layout = "_Layout";

    var contactEmail = await SettingsService.GetAsync("general.contact_email", "info@sterlinglams.com");
    var contactPhone = await SettingsService.GetAsync("general.contact_phone", "+234 1 234 5678");
}

<!-- Hero -->
<section class="relative h-56 flex items-center justify-center bg-neutral-100">
    <div class="text-center">
        <p class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-4">Sterlin Glams</p>
        <h1 class="font-cormorant text-5xl font-light text-neutral-900">Contact Us</h1>
    </div>
</section>

<!-- Contact Content -->
<section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16">

        <!-- Info -->
        <div>
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Get In Touch</p>
            <h2 class="font-cormorant text-3xl font-light text-neutral-900 mb-8">We'd love to hear from you</h2>

            <div class="space-y-8">
                <!-- Email -->
                <div class="flex gap-4">
                    <div class="w-10 h-10 border border-neutral-200 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs tracking-widest uppercase text-neutral-400 mb-1">Email</p>
                        <a href="mailto:@contactEmail" class="text-sm text-neutral-700 hover:text-neutral-900 transition-colors">@contactEmail</a>
                    </div>
                </div>

                <!-- Phone -->
                <div class="flex gap-4">
                    <div class="w-10 h-10 border border-neutral-200 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs tracking-widest uppercase text-neutral-400 mb-1">Phone</p>
                        <a href="tel:@contactPhone.Replace(" ", "")" class="text-sm text-neutral-700 hover:text-neutral-900 transition-colors">@contactPhone</a>
                    </div>
                </div>

                <!-- WhatsApp -->
                <div class="flex gap-4">
                    <div class="w-10 h-10 border border-neutral-200 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4 text-neutral-500" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs tracking-widest uppercase text-neutral-400 mb-1">WhatsApp</p>
                        <a href="https://wa.me/2348000000000" target="_blank" rel="noopener" class="text-sm text-neutral-700 hover:text-neutral-900 transition-colors">Chat with us on WhatsApp</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Store Locations -->
        <div>
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Our Boutiques</p>
            <div class="space-y-6">
                @foreach (var store in new[] {
                    new { Name = "Sterlin Glams Abuja", Address = "Elboogie Place Adjacent Kilimanjaro, 3rd Avenue, Gwarinpa, Abuja", Hours = "Mon–Sat: 8am–8pm, Sun: 12pm–8pm", Phone = "+234 1 234 5678" },
                    new { Name = "Sterlin Glams Allen", Address = "47 Allen Avenue, Studio 24 Building, Opp Item7go Restaurant, Ikeja, Lagos", Hours = "Mon–Sat: 8am–8pm, Sun: 12pm–8pm", Phone = "+234 1 234 5679" },
                    new { Name = "Sterlin Glams Ikota", Address = "Shop J22, Ikota Shopping Complex, Ikota Ajah, Lagos", Hours = "Mon–Sat: 8am–8pm, Sun: 12pm–8pm", Phone = "+234 1 234 5680" }
                })
                {
                    <div class="border border-neutral-100 p-6">
                        <h3 class="font-cormorant text-xl font-light text-neutral-900 mb-3">@store.Name</h3>
                        <div class="space-y-1.5 text-xs text-neutral-500 font-light">
                            <p>@store.Address</p>
                            <p class="text-neutral-400">@store.Hours</p>
                            <a href="tel:@store.Phone.Replace(" ", "")" class="block text-neutral-700 hover:text-neutral-900 transition-colors">@store.Phone</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
