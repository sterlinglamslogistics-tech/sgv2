@{
    ViewData["Title"] = "Something went wrong";
    ViewData["Robots"] = "noindex, nofollow";
}

<section class="bg-[#faf8f6]">
    <div class="max-w-2xl mx-auto px-6 py-24 md:py-32 text-center">

        <!-- Faceted diamond (matches the 404 page) -->
        <div class="flex justify-center mb-9">
            <svg viewBox="0 0 24 24" class="w-16 h-16 md:w-20 md:h-20" fill="none" stroke="#ed028b"
                 stroke-width="0.9" stroke-linejoin="round" stroke-linecap="round"
                 style="filter: drop-shadow(0 6px 14px rgba(237,2,139,.25));">
                <path d="M5.5 3h13l3.5 5.5L12 21 3 8.5 5.5 3z" />
                <path d="M3 8.5h18" />
                <path d="M8.5 3 6 8.5M15.5 3 18 8.5" />
                <path d="M6 8.5 12 21M18 8.5 12 21" />
                <path d="M8.5 3 12 8.5 15.5 3" />
            </svg>
        </div>

        <p class="text-[11px] tracking-[0.4em] uppercase text-brand-500 mb-4">Error 500</p>
        <p class="font-cormorant text-[6.5rem] md:text-[9rem] font-light text-neutral-200 leading-[0.85] select-none" aria-hidden="true">500</p>
        <h1 class="font-cormorant text-3xl md:text-5xl font-light text-neutral-900 mt-2 mb-5">Something went wrong</h1>
        <p class="text-sm md:text-base text-neutral-400 font-light leading-relaxed mb-10 max-w-md mx-auto">
            An unexpected error occurred on our end. Please try again in a moment — if it keeps happening, we'd be glad to help.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Home" asp-action="Index" class="btn-primary">Return Home</a>
            <a asp-controller="Home" asp-action="Contact" class="btn-outline">Contact Us</a>
        </div>
    </div>
</section>
