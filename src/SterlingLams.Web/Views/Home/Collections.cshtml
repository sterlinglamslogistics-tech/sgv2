@using SterlingLams.Web.Services
@inject ISettingsService SettingsService
@{
    ViewData["Title"] = "Collections";
    ViewData["Description"] = "Explore our curated jewellery collections — rings, necklaces, bracelets and earrings crafted for the discerning woman.";
    Layout = "_Layout";
    var collectionCards = new[]
    {
        ("Rings", "rings", await SettingsService.GetAsync("collections.image_rings", "")),
        ("Necklaces", "necklaces", await SettingsService.GetAsync("collections.image_necklaces", "")),
        ("Bracelets", "bracelets", await SettingsService.GetAsync("collections.image_bracelets", "")),
        ("Earrings", "earrings", await SettingsService.GetAsync("collections.image_earrings", "")),
    };
}

<!-- Hero -->
<section class="relative h-72 flex items-center justify-center bg-neutral-100">
    <div class="text-center">
        <h1 class="font-cormorant text-5xl font-light text-neutral-900">Our Collections</h1>
    </div>
</section>

<!-- Collections Grid (card images are admin-editable in Settings → Collections) -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-8">
            @foreach (var (title, cat, img) in collectionCards)
            {
                var hasImg = !string.IsNullOrWhiteSpace(img);
                <a asp-controller="Products" asp-action="Index" asp-route-category="@cat"
                   class="group relative overflow-hidden @(hasImg ? "bg-neutral-200" : "bg-stone-50") aspect-[4/3] flex items-end">
                    @if (hasImg)
                    {
                        <img src="@img" alt="@title" loading="lazy"
                             class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/70 via-neutral-900/20 to-transparent"></div>
                    }
                    else
                    {
                        <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    }
                    <div class="relative z-10 p-8 w-full">
                        <h2 class="font-cormorant text-3xl font-light mb-1 transition-colors duration-300 @(hasImg ? "text-white" : "text-neutral-900 group-hover:text-white")">@title</h2>
                        <p class="text-xs tracking-widest uppercase transition-colors duration-300 @(hasImg ? "text-neutral-200" : "text-neutral-500 group-hover:text-neutral-300")">
                            Shop Collection →
                        </p>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- New Arrivals CTA -->
<section class="py-20 bg-neutral-900 text-white text-center">
    <p class="text-xs tracking-[0.4em] uppercase text-neutral-400 mb-4">Just In</p>
    <h2 class="font-cormorant text-4xl font-light mb-6">New Arrivals</h2>
    <p class="text-neutral-400 font-light text-sm max-w-md mx-auto mb-8">
        Discover our latest pieces, crafted with the finest materials and timeless elegance.
    </p>
    <a asp-controller="Products" asp-action="Index" asp-route-isNewArrival="true"
       class="inline-block border border-white text-white text-xs tracking-[0.2em] uppercase px-12 py-4 hover:bg-white hover:text-neutral-900 transition-colors duration-300">
        View New Arrivals
    </a>
</section>
